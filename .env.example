# Neo4j Configuration
# Local instance (default):
NEO4J_URI=neo4j://127.0.0.1:7687
# For Neo4j Aura (cloud), use: neo4j+s://<your-instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=mossec

# Runtime (hosts/ports)
# Keep these in .env (no hardcoding in scripts/config).
# Use 0.0.0.0 for Azure VM or remote access; use 127.0.0.1 for local-only.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3001

# Base URLs (optional)
# PUBLIC_BASE_URL is used when constructing absolute resource URIs (OSLC/TRS notifications).
# If omitted, the backend falls back to API_BASE_URL (or BACKEND_HOST/BACKEND_PORT).
# PUBLIC_BASE_URL=http://127.0.0.1:5000

# FRONTEND_URL is used by the backend for redirects (/) and the /info endpoint.
# If omitted, the backend falls back to http://FRONTEND_HOST:FRONTEND_PORT.
# FRONTEND_URL=http://127.0.0.1:3001

# CORS origins (comma-separated). If omitted, the backend allows FRONTEND_URL.
# For convenience, when FRONTEND_HOST is a loopback interface, the backend also
# allows http://localhost:FRONTEND_PORT.
# CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Frontend dev proxy target (Vite)
API_BASE_URL=http://127.0.0.1:5000

# Vite behavior
# If true, Vite will fail if FRONTEND_PORT is already in use.
# If false/omitted, Vite may auto-select the next available port.
VITE_STRICT_PORT=false

# Application Configuration
LOG_LEVEL=INFO
DATA_DIR=./data
OUTPUT_DIR=./data/output

# API Key Authentication
# Backend expects API_KEY (checked against X-API-Key header). If API_KEY is unset, backend allows requests (dev mode).
# Frontend should use the same value via VITE_API_KEY.
API_KEY=
VITE_API_KEY=

# XMI Processing Configuration
XMI_SOURCE_URL=https://standards.iso.org/iso/10303/smrl/v12/tech/
BATCH_SIZE=100

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Redis (optional)
# By default, Redis is disabled and the backend will not attempt to connect.
# Set REDIS_ENABLED=true (and optionally REDIS_URL) to enable.
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379/0

# OpenAI API (for LangGraph agent)
# Select which LLM provider the backend agent uses:
#   - openai  (default; requires OPENAI_API_KEY)
#   - ollama  (local; requires Ollama running and OLLAMA_* configured)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_API_KEY=your-openai-api-key-here

# Ollama (local LLM + embeddings)
# Install: https://ollama.com/  then pull models:
#   ollama pull llama3:latest
#   ollama pull nomic-embed-text:latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TEMPERATURE=0.7

# OpenSearch (vector search / RAG)
# Install: https://opensearch.org/downloads.html
# Disable security plugin in opensearch.yml: plugins.security.disabled: true
OPENSEARCH_URL=http://localhost:9200
# Override default install path (used by start_opensearch.ps1):
# OPENSEARCH_HOME=D:\Software\opensearch-3.3.1

# -----------------------------------------------------------------------------
# Azure AI Baseline (optional, for Azure deployments)
# -----------------------------------------------------------------------------

# Azure OpenAI (preferred for Azure baseline deployments)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Search (RAG)
AZURE_AI_SEARCH_ENDPOINT=https://your-search-name.search.windows.net
AZURE_AI_SEARCH_INDEX=your-index-name
AZURE_AI_SEARCH_API_KEY=your-search-api-key

# Identity / Secrets
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-managed-identity-or-app-id
AZURE_KEY_VAULT_URL=https://your-kv-name.vault.azure.net/

# Observability (Application Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-appinsights-connection-string

