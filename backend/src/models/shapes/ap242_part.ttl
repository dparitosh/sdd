@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aplm: <https://standards.iso.org/iso/10303/-242/ed-3/tech/ontology#> .

aplm:PartShape
    a sh:NodeShape ;
    sh:targetClass aplm:Part ;
    sh:property [
        sh:path aplm:partNumber ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Part must have a unique Part Number." ;
    ] ;
    sh:property [
        sh:path aplm:version ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:defaultValue "1.0" ;
    ] ;
    sh:property [
        sh:path aplm:lifecycleState ;
        sh:in ( "IN_WORK" "RELEASED" "OBSOLETE" ) ;
        sh:message "Lifecycle state must be one of: IN_WORK, RELEASED, OBSOLETE." ;
    ] ;
    sh:property [
        sh:path aplm:mass ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "Mass cannot be negative." ;
    ] .
