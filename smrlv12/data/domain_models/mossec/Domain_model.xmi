      <packagedElement xmi:id="_18_4_1_1b310459_1505839733786_17631_14563" xmi:uuid="43287041-5e64-4979-adbb-1b0cdb4193ec" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734056_789907_15748" xmi:uuid="3844245a-754e-46a0-9fd2-5c99ce9c1112" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733786_17631_14563"/>
          <body>An AssumptionRelationship represents a relationship between different Assumptions.&#13; &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of relationship.&lt;/note&gt; &#13; </body>
        </ownedComment>
        <name>AssumptionRelationship</name>
        <ownedRule xmi:id="_18_4_1_13110319_1521710172498_419139_38464" xmi:uuid="262863b0-ead8-4714-a402-86a688dbc038" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1521710172513_458753_38466" xmi:uuid="34f273c1-f0db-43b9-8bda-fabb0ba70df2" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1521710172498_419139_38464"/>
            <body>Circularity. The RequirementRelationship From shall be different from the To.</body>
          </ownedComment>
          <name>FromNotTo</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733534_120594_14163"/>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733786_17631_14563"/>
          <specification xmi:id="_18_4_1_13110319_1521710172513_707950_38465" xmi:uuid="d4c881d9-e9e0-43bc-8a6c-e4ea947c7ea7" xmi:type="uml:OpaqueExpression">
            <body>self.From &lt;&gt; self.To</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_990628_14913" xmi:uuid="7ab75523-dada-46f8-bc44-7581a0ad4b3c" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734056_180108_15749" xmi:uuid="1f631a46-715d-430e-a25e-c6c9f0fefe04" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512731096953_273017_33041" xmi:uuid="e36b9d75-e079-48da-a61c-10d0f77e6d4c" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734056_180108_15749"/>
            <body>the parent or source Assumption of the relationship. &lt;note&gt;This Assumption should have the same ClassifiedAs type as the other Assumption though this is intentionally not constrained.&lt;/note&gt;</body>
          </ownedComment>
          <name>From</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733786_336966_14559"/>
          <association xmi:idref="_18_4_1_1b310459_1505839733786_345299_14578"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734056_575142_15750" xmi:uuid="31c4e31c-f839-4103-b8e3-6cd162f19d98" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512731108528_165357_33042" xmi:uuid="efc5a1ef-5342-4331-b2b1-243154b837b5" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734056_575142_15750"/>
            <body>the child or target Assumption of the relationship. &lt;note&gt;If one Assumption in the relationship is dependent upon the other, this attribute shall be the dependent one.&lt;/note&gt; &lt;note&gt;This Assumption should have the same ClassifiedAs type as the other Assumption though this is intentionally not constrained.&lt;/note&gt;</body>
          </ownedComment>
          <name>To</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733786_336966_14559"/>
          <association xmi:idref="_18_4_1_1b310459_1505839733786_166154_14575"/>
