      <packagedElement xmi:id="_18_4_1_13110319_1588007040161_630931_73788" xmi:uuid="45a768b1-06ec-4fe3-8fa6-282eb6f2da80" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_13110319_1588007040161_596857_73789"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1576082871330_707486_58093"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1588007040161_596857_73789" xmi:uuid="769dda45-dd0e-47d5-95f9-c1d50b3d857b" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733756_501084_14482"/>
          <association xmi:idref="_18_4_1_13110319_1588007040161_630931_73788"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_13110319_1588057751522_489746_66698" xmi:uuid="46ee6ff9-2f2e-43c8-8b1a-61b491ff5b30" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1588057751600_952183_66748" xmi:uuid="49255caf-f7d2-463f-b6a5-20429985a2ee" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1588057751522_489746_66698"/>
          <body>A PortInstanceRelationship identifies an InterfacePortInstance hierarchy. It has a Type property that defines the type of hierarchy, and hence how the port properties or their realizations may be delegated or collated. &#13; &lt;note&gt;A port may be referenced by many PortRelationships.&lt;/note&gt; &lt;note&gt;The IsAnInstanceOf property need not reference the same InterfacePortType.&lt;/note&gt; &lt;example&gt;A power port can have a hierarchical relationship to electrical power port and a thermal power port.&lt;/example&gt; &lt;note&gt;The PortOn property need not reference the same object.&lt;/note&gt; &lt;example&gt;A PortInstanceRelationship of Type "delegation" is where the port on one system "delegates" it's properties to the port on one of its subsystems, for example the port on an aircraft engine system delegates to a port on the stator front case subsystem of the engine.&lt;/example&gt; &lt;note&gt;The PortInstanceRelationship is an IdentifiableObject and ProgrammeObject because it may need a description for what is expected between the ports.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1590664948281_642164_69770" xmi:uuid="8cbfdc6d-8a83-4431-927f-7954d9d85b67" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1588057751600_671596_66752"/>
          <body>interface connector occurrence relationship</body>
        </ownedComment>
        <name>PortInstanceRelationship</name>
        <ownedRule xmi:id="_18_4_1_13110319_1588057751522_902039_66699" xmi:uuid="7d96d4d3-4da4-4f7c-95fb-342afdf64e8f" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1588057751600_328917_66763" xmi:uuid="f8837af5-d5cd-42cf-81a8-25f18b30dbfa" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588057751522_902039_66699"/>
            <body>the parent PortInstanceRelationship shall be different from the child PortInstanceRelationship.</body>
          </ownedComment>
