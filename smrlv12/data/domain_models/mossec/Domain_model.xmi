      <packagedElement xmi:id="_18_4_1_1b310459_1505839733876_902089_14808" xmi:uuid="8f838123-c34c-49f3-8f3c-f3ff34f96dac" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734586_925883_16889" xmi:uuid="5d61837a-1396-45f0-9c9d-3934948fb8b7" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733876_902089_14808"/>
          <body>&lt;note&gt;These designated data types may realize an InterfacePortType or InterfaceConnectionType.&lt;/note&gt;</body>
        </ownedComment>
        <name>InterfaceTypeRealizationItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660211365_337958_50548" xmi:uuid="4f9e3939-50af-4be5-af1d-6944d7e650b1" xmi:type="uml:Port">
          <name>interfaceTypeRealizationItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/Collection/Collection.xmi#_18_4_1_1b310459_1581932043631_158459_57465"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733756_561274_14483" xmi:uuid="91de9bfc-b31e-4b41-b3df-4ea3f7d30829" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734026_323664_15628" xmi:uuid="79729fdc-35ed-41b6-a399-0989aff8c89e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733756_561274_14483"/>
          <body>An InterfaceConnectionInstance represents a connection between instances of InterfacePortInstance. The connection definition InterfaceConnectionType is referenced using the IsAnInstanceOf property. &lt;note&gt;If the connection is directional, it is implied that the flow is from the object referenced by the "From" property and to the object referenced by the "To" property.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;It is a type of ObjectWithPropertyValues therefore, it may have PropertyValues&lt;/note&gt; &lt;note&gt;Links between an InterfaceConnectionInstance and items that realize the connection are represented by InterfaceConnectionRealizationAssociation.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt;</body>
        </ownedComment>
        <name>InterfaceConnectionInstance</name>
        <ownedRule xmi:id="_18_4_1_13110319_1512983847967_720826_35654" xmi:uuid="2f6f8b4f-f645-43f9-8de2-3ca62782b6a0" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1512983932604_373534_35664" xmi:uuid="fc238698-b944-4bd3-924a-f5ea7cb29107" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1512983847967_720826_35654"/>
            <body>An InterfaceConnectionInstance shall connect two different InterfacePortInstances.</body>
          </ownedComment>
          <name>FromNotTo</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733756_561274_14483"/>
          <specification xmi:id="_18_4_1_13110319_1512983847967_212933_35655" xmi:uuid="31186b3b-abad-45b0-8f07-73d10bc0d5e8" xmi:type="uml:OpaqueExpression">
            <body>self.From &lt;&gt; self.To</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
