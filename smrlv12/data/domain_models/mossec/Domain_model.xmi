          <body>A ModelInstanceIsDerivedFrom is a relationship between a ModelInstance and the item from which it is derived. Many ModelInstanceIsDerivedFrom may reference the same ModelInstance. &#13; &lt;note&gt;The DerivedFrom reference and Model reference shall be different&lt;/note&gt; &#13;</body>
        </ownedComment>
        <name>ModelInstanceIsDerivedFrom</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510146051509_706401_34789" xmi:uuid="7eb6b9d1-b096-4be6-8c22-5b788f3e4b26" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513008697562_257129_35379" xmi:uuid="05438782-f0b3-48b0-91f5-58a4f426aa17" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510146051509_706401_34789"/>
            <body>a ModelInstance shall not be derived from itself.</body>
          </ownedComment>
          <name>notDerivedFromSelf</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733696_829544_14328"/>
          <specification xmi:id="_18_4_1_13110319_1510146051509_46198_34790" xmi:uuid="58df0bc2-4da0-4ec3-9e11-a2c90865861b" xmi:type="uml:OpaqueExpression">
            <body>self.Model &lt;&gt; self.DerivedFrom</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
