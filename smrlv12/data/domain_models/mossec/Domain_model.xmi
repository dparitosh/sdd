      <packagedElement xmi:id="_18_4_1_1b310459_1505839733656_287576_14227" xmi:uuid="db717860-3e31-4910-9a4a-40525a656580" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1582115509375_230636_74938" xmi:uuid="124d59c3-ad5f-4f0b-b428-d02d09a3693d" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1510061646063_490779_63617"/>
          <body>collaborative model template UUID from CollaborativeModelTemplate subclass of corev1#collection </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1583774109899_716701_82588" xmi:uuid="35d664b5-8df9-48a6-9fac-17847b1efbd8" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1583774260736_225599_82628"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1583774327649_900206_82715"/>
          <body>collaborative model template is composed of relationship UUID from CollaborativeModelTemplate.IsComposedOf property subclassof core_v1#collection version sequence relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733926_569344_15165" xmi:uuid="6da1aeb7-e226-4f22-9f47-e03986028b5a" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733656_287576_14227"/>
          <body>A CollaborativeModelTemplate represents a template for a collaborative modelling process. It provides the context and methods for how specific ModelTypes can be derived from other ModelTypes, and the KeyValueTypes that can be extracted from those ModelTypes in that context.&#13; &lt;note&gt;A CollaborativeModelTemplate may be composed of other CollaborativeModelTemplates.&lt;/note&gt; &lt;example&gt;A team for one discipline may have several alternative templates for generating the same ModelType with different fidelity computations. Another team may require a specific fidelity ModelType as input to their template and create a CollaborativeModelTemplate that IsComposedOf the other template with the required fidelity.&lt;/example&gt; &lt;note&gt;It is a type of VersionableObject therefore, it shall have at least one VersionIdentifiers property.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject. The Identifiers or Names are used to identify the constituent.&lt;/note&gt; &lt;note&gt;Identification that it is deployed by a Study is represented by Study property Deploys.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt; </body>
        </ownedComment>
        <name>CollaborativeModelTemplate</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510142925103_544178_34243" xmi:uuid="15f1fd24-4d34-497e-afa9-1a70c98f4e78" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1512734500452_253211_34557" xmi:uuid="0a054158-c6ef-4646-890b-cb8fb9e8402f" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510142925103_544178_34243"/>
            <body>Circularity: A CollaborativeModellingTemplate shall not be composed of itself.</body>
          </ownedComment>
          <name>notComposedOfSelf</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733656_287576_14227"/>
          <specification xmi:id="_18_4_1_13110319_1510142925103_475856_34244" xmi:uuid="71a8e56f-bdf0-44da-a029-163bdc05a8a8" xmi:type="uml:OpaqueExpression">
            <body>self.IsComposedOf-&gt;excludes(self)</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_13110319_1586182857448_467526_84181" xmi:uuid="113d28df-b90e-4c11-bdcd-dda5d72cfa7a" xmi:type="uml:Generalization">
