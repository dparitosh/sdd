          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <association xmi:idref="_18_4_1_1b310459_1505839733706_242527_14333"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733956_854789_15316" xmi:uuid="c428222d-a5dd-4b4b-8ccf-2c8677472c2a" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734616_602306_17266" xmi:uuid="237dfe79-a761-4e6f-936a-b82f91d80d38" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_854789_15316"/>
            <body>the references to Person or Organization that are interested in the AssociativeModelNetwork. The value of this attribute need not be specified. &lt;example&gt;A business rule can be to notify them when any changes to the ModelInstance are made.&lt;/example&gt;</body>
          </ownedComment>
          <name>WatchersOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733876_143414_14785"/>
