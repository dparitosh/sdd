        <memberEnd xmi:idref="_18_4_1_13110319_1588005876082_997167_70746"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1588005882283_165690_71561" xmi:uuid="61905cb3-eb94-4422-8a49-14ed26bbca13" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733756_627640_14479"/>
