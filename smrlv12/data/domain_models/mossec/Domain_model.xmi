        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734026_648859_15638" xmi:uuid="e5500066-db4c-4234-be9d-049d6156fcfb" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1512987157753_275940_36210" xmi:uuid="3dfaba22-7c91-46a8-aa1c-d38fef36ead6" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734026_648859_15638"/>
            <body>the item for which the InterfacePortType may provide an interface capability. The value of this attribute need not be specified.</body>
          </ownedComment>
