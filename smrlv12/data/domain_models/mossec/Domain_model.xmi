      <packagedElement xmi:id="_18_4_1_1b310459_1505839733686_591537_14289" xmi:uuid="2bd42b78-f852-4ee1-b461-aa485e0fbb26" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1578468336791_965012_56845" xmi:uuid="0002b2df-3b67-452f-9364-429720073f13" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733946_522481_15225"/>
          <body>Reference Data: subclass of core_v1#planned activity (of which ap243_v1#study is a sub class) Sub classes (including study): directed planned activity, planned amendment activity, planned analysis activity, planned cancellation activity, planned delivery change activity, planned design activity, planned design change activity, planned logistics activity, planned mock-up creation activity, planned operational activity, planned prototype building activity, planned rectification activity, planned restructuring activity, planned spare part creation activity, planned stop notice activity, planned testing activity, planned work definition activity, study, study integration activity; study methodology development activity; study modelling activity; study trade activity; study validation activity.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576754061280_102210_63743" xmi:uuid="07ffdf71-6229-4ce5-b012-b05c92a4476e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507043074908_794286_36502"/>
          <body>Reference Data: study sub class of#planned activity</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1578468745881_575213_57656" xmi:uuid="156b504f-b5a9-4dd5-a547-47201e78bcbd" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733936_993026_15213"/>
          <body>Reference Data: core_rd_v1# state of planned activity Named Individuals (including state of study): planned activity happening, planned activity new, planned activity planned. state of study unknown; study assessment complete; study paused, study proposed; study recommendations validated; study stopped.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576756042308_835520_64834" xmi:uuid="18d01699-0ca1-4b07-a075-ce49c5d1c4b1" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508329521346_836441_44400"/>
          <body>study report document assignment sub class of: core_rd_v1#description document assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576495777786_228547_68958" xmi:uuid="313fadf6-7f81-4912-b99f-81a0f5dbce1f" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508322173275_109298_38624"/>
          <body>Reference Data: actual watcher assignment sub class of: actual observer assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576515511801_912047_75256" xmi:uuid="35bbe236-68d9-4cb2-bf31-50499ed9f74b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508324011361_856021_40616"/>
          <body>activity concept assignment sub class of: activity input (subclass of activity assignment)</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576754985641_189366_64271" xmi:uuid="531a9702-5cb6-4d32-b488-90c0ad804c95" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1510134998658_677535_46659"/>
          <body>core_rd_v1#activity input</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576756368889_102139_65023" xmi:uuid="65a99392-b16f-4f12-a563-01f072d41ccc" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508329153681_134622_43592"/>
          <body>activity requirement sub class of: core_v1#activity assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576754757118_390217_64134" xmi:uuid="6f3bc7fd-f000-43f3-baef-2d36bf7c2f51" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1510134926052_342300_46637"/>
          <body>activity creates assignment sub class ofcore_rd_v1#activity output</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576755160833_733660_64321" xmi:uuid="9bc015d2-5b8e-4f9c-8ff6-36ab0512f1a0" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508322360655_979458_38878"/>
          <body>Reference Data: planned deadline date assignment subclass of core_rd_v1#planned end date assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576754565110_141139_63777" xmi:uuid="adbd5bd1-5c25-44f2-8812-363bcfc46227" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508322004875_163966_38344"/>
          <body>Reference Data: actual controller assignment sub class of core_rd_v1#actual person organization assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733936_882453_15212" xmi:uuid="be950e09-36d8-4912-87a9-c96cd6d94890" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <body>A Study is a package of work controlled and managed at the collaboration level. A Study may be in a hierarchy of studies represented by the Manages property. The objectives for a study are represented by the Requirements property. The study scope is represented by the Concepts property. Documents may be directly added to the Study by the StudyReports property. &lt;note&gt;A Study may be a RequirementSource.&lt;/note&gt; &lt;note&gt;It is a type of ProgrammeObject therefore, it may have Approvals, Assumptions, Justifications, Contracts and SecurityTrust information.&lt;/note&gt; &lt;example&gt;Examples of Studies are: &lt;ul&gt;&lt;li&gt;to evolve a design;&lt;/li&gt;&lt;li&gt;for change;&lt;/li&gt;&lt;li&gt;trade-off;&lt;/li&gt;&lt;li&gt;sensitivity;&lt;/li&gt;&lt;li&gt;optimization;&lt;/li&gt;&lt;li&gt;integration;&lt;/li&gt;&lt;li&gt;design of experiments.&lt;/li&gt;&lt;/ul&gt;&lt;/example&gt; &lt;example&gt;The concepts may be used to identify for example which product concept is to be varied; added; recommended; or decided by the study. These may be for example shapes; layout; technology standard; design concept; loading philosophy.&lt;/example&gt; &lt;example&gt;The study objective may be Requirements defining for example targets, limits, method fidelity.&lt;/example&gt; </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576754856721_208000_64151" xmi:uuid="c76fd6fb-1ea8-4d36-88ee-08f8025aa7c9" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1510134964487_529655_46650"/>
          <body>activity deploys assignment sub class ofcore_rd_v1#activity input</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576755839022_578111_64661" xmi:uuid="cdad2964-32fe-4fe6-a9b7-883b0bd7e325" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1510135042995_843671_46668"/>
          <body>activity input managed subclass of: core_rd_v1#activity input Note this is the same reference data used for the AssociativeModelNetwork ManagedBy Activity Assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1578492585758_286871_66328" xmi:uuid="f9f4e69b-25d5-471b-a630-241bac9b018c" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1578492294638_986710_66273"/>
          <body>Reference Data: activity context sub class of core:v1#activity assignment</body>
        </ownedComment>
        <name>Study</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590665253828_798574_70806" xmi:uuid="111c85e3-1f97-4dfe-8fa7-c8053954553c" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590665253831_355674_70808" xmi:uuid="48b354cd-55a7-425d-b712-66e9828118f8" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590665253828_798574_70806"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>StatusConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733936_993026_15213"/>
          <specification xmi:id="_18_4_1_13110319_1590665253831_110648_70807" xmi:uuid="0f2ff08a-dcd8-4e2e-a8ad-9a484f00bbee" xmi:type="uml:OpaqueExpression">
            <body>Status.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#c7fbaa91-079b-0136-7602-01ff90f87e13')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1590667313451_188190_71463" xmi:uuid="3135c9f8-a041-403d-8f19-3535cc51e9b6" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590667313455_225135_71465" xmi:uuid="b0c9d2a0-eb15-4134-a706-ca4413280c3b" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590667313451_188190_71463"/>
            <body>values shall be subClassof the reference data class.</body>
          </ownedComment>
          <name>TypeConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733946_522481_15225"/>
          <specification xmi:id="_18_4_1_13110319_1590667313454_562625_71464" xmi:uuid="eb939afa-08f4-43c3-8e10-54e8bc9844f8" xmi:type="uml:OpaqueExpression">
            <body>Type.mustBeSubClassOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b72f5420-130a-0135-b552-598f1b1392ae')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1510151971071_620305_37535" xmi:uuid="39c266f4-2d2d-457e-bb9d-5973a4dcfcc4" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1511196338813_358185_38208" xmi:uuid="f6b3510a-8836-4ea6-a0fa-8e527e4af2b3" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510151971071_620305_37535"/>
            <body>The elements of Inputs and Manages in a Study should be mutually exclusive. It shall not manage an input.</body>
          </ownedComment>
          <name>InputsNotManaged</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <specification xmi:id="_18_4_1_13110319_1510151971071_7346_37536" xmi:uuid="3a72f694-5a4b-4901-a13d-86cb589e652b" xmi:type="uml:OpaqueExpression">
            <body>self.Manages-&gt;forAll(m | self.Inputs-&gt;forAll(i | i &lt;&gt; m))</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1513074067460_825494_36003" xmi:uuid="563e5726-396d-4678-9eb8-8b76111ffdda" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513074089907_905540_36005" xmi:uuid="4d4a98da-5a67-494f-b195-90d77fc50cc8" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1513074067460_825494_36003"/>
            <body>Study Manages references shall be unique. That is an object may only be managed by one study.</body>
          </ownedComment>
          <name>ManagedByOne</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <specification xmi:id="_18_4_1_13110319_1513074067460_180127_36004" xmi:uuid="77aaefd0-598c-4b81-be01-4118674c639d" xmi:type="uml:OpaqueExpression">
            <body>Study::allInstances()-&gt;isUnique(Manages) </body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1513074019148_316048_36000" xmi:uuid="a9ef4e1f-f1ba-4544-8169-03cbcfa45e11" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513074060190_116673_36002" xmi:uuid="3d7859e8-2656-47f5-a65c-ab0238ad872e" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1513074019148_316048_36000"/>
            <body>Study Creates references shall be unique. That is an object may only be created by one study.</body>
          </ownedComment>
          <name>CreatedByOne</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <specification xmi:id="_18_4_1_13110319_1513074019163_838134_36001" xmi:uuid="d9795105-a3e2-4fd8-bae4-e2011c67e43f" xmi:type="uml:OpaqueExpression">
            <body>Study::allInstances()-&gt;isUnique(Creates)</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_1b310459_1511198109856_452369_38900" xmi:uuid="b7a2439b-248d-4d86-90fd-7a701f759575" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513067482912_873272_35836" xmi:uuid="a737eb08-67e7-4edf-a531-5c60dc38bcd0" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1511198109856_452369_38900"/>
            <body>The elements of Deploys and Manages in a Study should be mutually exclusive. It shall not manage what is deploys.</body>
          </ownedComment>
          <name>DeploysNotManaged</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <specification xmi:id="_18_4_1_1b310459_1511198109856_932288_38901" xmi:uuid="e0d8aa9d-5aa5-46c8-b2eb-8415f49c2dfe" xmi:type="uml:OpaqueExpression">
            <body>self.Manages-&gt;forAll(m | self.Deploys-&gt;forAll(d | d &lt;&gt; m))</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_1b310459_1511197304615_206448_38458" xmi:uuid="dd926be1-47f9-4ee5-8442-312d41657604" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513067391995_251970_35835" xmi:uuid="109a20dc-80a8-450e-a242-9de37990b2d7" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1511197304615_206448_38458"/>
            <body>The elements of Inputs and Creates in a Study should be mutually exclusive. It shall not create an input.</body>
          </ownedComment>
          <name>InputsNotCreates</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733686_591537_14289"/>
          <specification xmi:id="_18_4_1_1b310459_1511197304615_978696_38459" xmi:uuid="de034294-7a17-49e0-8bdb-ccbf80969a9a" xmi:type="uml:OpaqueExpression">
            <body>self.Creates-&gt;forAll(c | self.Inputs-&gt;forAll(i | i &lt;&gt; c))</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_13110319_1586180725864_70939_82708" xmi:uuid="14c73fac-1d6e-438e-b2f4-fee88289371b" xmi:type="uml:Generalization">
