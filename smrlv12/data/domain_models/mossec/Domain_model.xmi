      <packagedElement xmi:id="_18_4_1_1b310459_1505839733484_14350_14062" xmi:uuid="1b7e9d94-ba20-4cfc-b4a7-17eeb9f3eef1" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733886_156468_14831" xmi:uuid="04664066-4a85-4d1d-87f9-a764ae1f6e49" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733484_14350_14062"/>
          <body>A PropertyValue is the representation of PropertyDefinition by a value. &lt;note&gt;Properties do not have individual traceability outside of the object to which they are part. If traceability is needed, or exposure of the properties to other objects, then DistributionValueType for Uncertainty, KeyValueType or Verification Status should be used.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1590582782159_701386_92352" xmi:uuid="b365df4d-7c49-472d-a329-8eed26cfd6dc" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_914747_14833"/>
          <body>core_v1#type qualifier Named individuals: delta tolerance, increment, initial, kurtosis, maximum value, mean, minimum value, skewness, variance.</body>
        </ownedComment>
        <name>PropertyValue</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590582275444_810294_92173" xmi:uuid="f23f9f91-e711-4827-ac34-ec624f04974a" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590582275448_787451_92175" xmi:uuid="08e85694-1c71-485f-9223-355b135cf31c" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590582275444_810294_92173"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>CharacteristicConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733886_914747_14833"/>
          <specification xmi:id="_18_4_1_13110319_1590582275448_755973_92174" xmi:uuid="b56b8db6-7bfb-475d-be82-ae59e84ef337" xmi:type="uml:OpaqueExpression">
            <body>Characteristic.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b9130840-130a-0135-b552-598f1b1392ae')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_267247_14830" xmi:uuid="185bdd12-6c72-460a-8c89-2cd616aa6ca0" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733886_679074_14832" xmi:uuid="1fcf2bf2-f410-4a5b-ada6-f49e032d442d" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513011855671_907667_36517" xmi:uuid="26266b20-6984-4371-a036-c5ac0c54cc7b" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_679074_14832"/>
            <body>The property that expresses quantity or measured property. It is a string. &lt;note&gt;The PropertyDefinition declares the Type of the string for the property using ValueTypeEnum.&lt;/note&gt;</body>
          </ownedComment>
          <name>Value</name>
          <visibility>public</visibility>
          <type href="../../../DataTypes.xmi#STRING"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733886_914747_14833" xmi:uuid="6e502eb6-da11-47eb-9324-a462a78d8049" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513011632905_702082_36494" xmi:uuid="b26eb48a-7982-4122-b785-30550b3bb491" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_914747_14833"/>
            <body>the additional distinguishing feature that the value represents. The value is restricted by reference data. The value of this attribute need not be specified. &lt;example&gt;A ParametricDistribution may have two properties of the same PropertyDefinition, one characterized as "upper bound" and the other "lower bound"&lt;/example&gt;</body>
          </ownedComment>
          <name>Characteristic</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/CommonResources/CommonResources.xmi#_ExternalOwlObject"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734596_94937_16960" xmi:uuid="9db2e603-b9b1-4de1-8e8c-7a0827155b39" xmi:type="uml:LiteralInteger"/>
          <aggregation>composite</aggregation>
          <association xmi:idref="_18_4_1_1b310459_1505839733484_325576_14076"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733886_126392_14834" xmi:uuid="3bf26912-ed10-4c05-80a9-8fd6a7c653ba" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513011878041_149866_36518" xmi:uuid="62c91833-3e76-453a-92a4-eb92b6b2b7ea" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_126392_14834"/>
            <body>The reference to the PropertyDefinition that is the definition for the property.</body>
          </ownedComment>
