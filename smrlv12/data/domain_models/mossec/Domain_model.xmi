          <ownedComment xmi:id="_18_4_1_13110319_1513012665714_453761_36610" xmi:uuid="aec8ad4d-0917-4e40-8164-b076c0e1e8eb" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733906_497088_15034"/>
            <body>one of the pair of RequirementObjects for the relationship. If the type of relationship implies a hierarchy or flow this is the "parent" or "from" object.</body>
          </ownedComment>
          <name>From</name>
          <visibility>public</visibility>
