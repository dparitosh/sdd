      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839734406_877846_16450" xmi:uuid="10f94d2e-49b8-4ef5-a60b-32e75a3613c8" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576753538733_799067_62865" xmi:uuid="1c6f6814-d2c1-48d9-b4cd-3aa4d8aa24a9" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1549279114743_75291_45524"/>
          <body>activity method sensitivity assignment sub class of: activity method assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734886_703453_18318" xmi:uuid="ce7ebd0a-4b9d-4afa-881b-b297d504504f" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734406_877846_16450"/>
          <body>A SensitivityAssignment is the assignment of a sensitivity to the Input MethodInputAssignment for a Method or an ApplicableMethod. An Output may be referenced to indicate the sensitivity is between the input and output for the ApplicableMethod.&#13; &lt;note&gt;It is a type of ObjectWithPropertyValues therefore, it may have PropertyValues specific to the sensitivity.&lt;/note&gt; &lt;note&gt;The MethodInputAssignment referenced InputFor and the SensitivityAssignment Output are normally, but not always, of the same object. They may be different objects when the Method referenced by MethodInputAssignment InputFor is the same as SensitivityAssignment Output ApplicableMethod Method.&lt;/note&gt; &lt;note&gt;&#13;3 There may be many SensitivityAssignment between same objects, but each shall have a different ClassifiedAs.&lt;/note&gt; &lt;example&gt;Classifications may be "Duration" sensitivity, or "Propagation" sensitivity.&lt;/example&gt;</body>
        </ownedComment>
        <name>SensitivityAssignment</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1551253416283_198498_39256" xmi:uuid="ee4c65b7-dd19-40c2-986e-5ce04df67324" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1551253726975_873241_39258" xmi:uuid="243c829e-da6b-4ee4-8c52-e72aaf0ddef2" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1551253416283_198498_39256"/>
            <body>the referenced Input MethodInputAssignment InputFor reference shall be the same as either the referenced Output, or if the referenced Output is an ApplicableMethod, shall be the same as the referenced Output ApplicableMethod Method reference.</body>
          </ownedComment>
          <name>UniqueMethod</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839734406_877846_16450"/>
          <specification xmi:id="_18_4_1_1b310459_1551253416283_599372_39257" xmi:uuid="594923cc-90d5-4fbc-b4ef-2c6bdf0541e7" xmi:type="uml:OpaqueExpression">
            <body>(self.Input.InputFor = self.Output) or ( self.Input.InputFor = self.Output.Method)</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839734886_765250_18317" xmi:uuid="0de75dae-f6d9-468e-be74-5c07e4b33180" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
        <generalization xmi:id="_18_4_1_13110319_1549019930707_877623_39926" xmi:uuid="c48e75c0-312d-45d5-a511-a6e59487a405" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_456222_14065"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734886_647324_18319" xmi:uuid="1caef511-5927-4d03-aec0-b3253076033d" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1549451469613_327447_40658" xmi:uuid="bedb8a69-06b4-4392-ae6b-67da03b074c5" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734886_647324_18319"/>
            <body>the MethodInputAssignment to which the sensitivity is assigned.</body>
          </ownedComment>
          <name>Input</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734406_899082_16447"/>
          <association xmi:idref="_18_4_1_1b310459_1505839734406_858781_16462"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734886_890488_18320" xmi:uuid="29a0db9d-f5b7-470c-a445-db3786703523" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1549451575045_173700_40659" xmi:uuid="756792b3-1138-4da7-8a38-3d4f02fc3089" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734886_890488_18320"/>
            <body>the output to the method (referenced from the ApplicableMethod OutputType property) that is the context for the sensitivity on the Input. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>Output</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734406_995789_16448"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1548862208326_103980_50729" xmi:uuid="17e4c3bc-e591-48b0-91b6-abe7ba8eeb69" xmi:type="uml:LiteralInteger"/>
          <association xmi:idref="_18_4_1_1b310459_1505839734406_571799_16456"/>
        </ownedAttribute>
