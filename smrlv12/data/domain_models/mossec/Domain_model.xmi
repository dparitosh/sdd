          <general xmi:idref="_18_4_1_1b310459_1505839733876_637735_14799"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839734886_347944_18296" xmi:uuid="f5220d8f-eb63-4fa3-932c-14516f9e142d" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_456222_14065"/>
