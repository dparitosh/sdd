          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733484_453986_14066"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734616_349735_17241" xmi:uuid="50275635-5f88-4eb2-845b-405e88b9c4f3" xmi:type="uml:LiteralInteger"/>
