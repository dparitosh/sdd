      <packagedElement xmi:id="_18_4_1_1b310459_1505839733776_545711_14528" xmi:uuid="9ac0b926-a13d-4c40-9b20-22fe8cf8a0ee" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1585639514793_280865_66674" xmi:uuid="349ac8ed-f55a-4be0-9fdf-cb7e9ae31fba" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1583764603492_344675_72894"/>
          <body>architecture inclusion relationship UUID from ArchitectureElementInclusionAssociation subclass of core_v1# collection membership relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734036_362939_15704" xmi:uuid="f4d0f154-72f1-44cc-ab29-c8b88ab09406" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733776_545711_14528"/>
          <body>An ArchitectureElementInclusionAssociation is a link between Elements that are included in the architecture.&#13; &lt;note&gt;An ArchitectureElementInclusionAssociation may be used to represent a historical sequence of ArchitectureElementInclusions.&lt;/note&gt; &lt;example&gt;ItemA1 in architecture v1 is to be replaced by itemA2 in architecture v2.&lt;/example&gt; &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of relationship.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;It is a type of ObjectWithApprovals therefore, it may have approvals.&lt;/note&gt; &lt;note&gt;It is a type of JustifiedItem therefore, it may be the subject of Justifications.&lt;/note&gt;</body>
        </ownedComment>
        <name>ArchitectureElementInclusionAssociation</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1511199472079_159236_39837" xmi:uuid="2ec6c02a-5b5d-43f1-9691-59673ac5d930" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1512573562262_407621_33649" xmi:uuid="829b79bf-498b-4af5-a469-6396c4d5141d" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1511199472079_159236_39837"/>
            <body>AssociatedTo shall not be the same as the Source</body>
          </ownedComment>
          <name>ToNotSource</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733776_545711_14528"/>
          <specification xmi:id="_18_4_1_1b310459_1511199472079_851611_39838" xmi:uuid="3faafcdd-b972-418b-af05-acbf91272525" xmi:type="uml:OpaqueExpression">
            <body>self.AssociatedTo &lt;&gt; self.Source</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1515145932913_367048_40087" xmi:uuid="0bef7010-de70-44b4-8b1d-839d407652f0" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733786_981753_14561"/>
        </generalization>
