      <packagedElement xmi:id="_18_4_1_1b310459_1505839733806_857232_14624" xmi:uuid="9d12ac7b-269f-4bf6-a9de-ddcc1c872648" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576518121846_729048_77028" xmi:uuid="58f099ba-778e-492c-b5b6-1957ca4cec60" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1521740601462_981870_66490"/>
          <body>distribution part subclass of core_rd_v1#general part</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734066_468394_15788" xmi:uuid="a894d0ee-594e-4ce2-a369-ccf3e0e011ba" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733806_857232_14624"/>
          <body>DistributionObjectType is the format of a distribution. &lt;note&gt;It is a type of ObjectWithPropertyDefinitions therefore, it may define the PropertyDefinitions for a ParametricDistribution.&lt;/note&gt; &lt;note&gt;It is a type of MethodologyObject therefore, it may define the specification format for NonParametricDistributions using FormalDocumentation.&lt;/note&gt; &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of distribution.&lt;/note&gt; &lt;example&gt;The distribution may be ClassifiedAs for example "Continuous" or "Discrete", then other classifications for the type of distribution for example "Normal" "Uniform" "Triangular".&lt;/example&gt;</body>
        </ownedComment>
        <name>DistributionObjectType</name>
