      <packagedElement xmi:id="_18_4_1_1b310459_1505839733876_143414_14785" xmi:uuid="75cb928d-394a-4942-9649-49dc9154b7c7" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1515483205456_931535_38705" xmi:uuid="8e1cd699-471d-4ab3-b2d3-5907d408440d" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733876_143414_14785"/>
          <body>&lt;note&gt;The designated data types used for selecting a management-like object.&lt;/note&gt;</body>
        </ownedComment>
        <name>PersonOrOrganizationItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660249353_661125_50632" xmi:uuid="fc75e81f-3d6e-46b6-b616-aeab5b0258ac" xmi:type="uml:Port">
          <name>personOrOrganizationItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/ManagementResources/ManagementResources.xmi#_OrganizationOrPersonInOrganizationSelect"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733514_450704_14138" xmi:uuid="76a0a31a-0194-4580-a2dc-210057ec66ea" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733906_312688_15014" xmi:uuid="a1f854c0-5ca8-4d98-b502-0951b143729b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733514_450704_14138"/>
          <body>A Person is an individual human being who has some relationship to modelling and simulation in a collaborative systems engineering context. The Person shall always be identified in the context of one or more organizations. &lt;note&gt;It has two string properties FirstName and LastName.&lt;/note&gt;&#13; &lt;note&gt;Person is used for Approvals.&lt;/note&gt; &lt;note&gt;It is a specialization of PersonOrOrganizationItem therefore, it may be used everywhere that PersonOrOrganizationItem is specified.&lt;/note&gt;</body>
        </ownedComment>
        <name>Person</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839733906_349636_15013" xmi:uuid="12a94ac5-7f2f-498f-b09d-9e2d3f61c7e3" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733876_143414_14785"/>
        </generalization>
