      <packagedElement xmi:id="_18_4_1_1b310459_1505839733816_26027_14652" xmi:uuid="10d0022a-f0dd-4d98-81d3-86543b299ae6" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1512736896147_6485_35956" xmi:uuid="71f5673b-4cfb-491d-b9f2-1aa8fe9427c9" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733816_26027_14652"/>
          <body>A DistributionValueType is the definition of the type of a distribution value. &lt;note&gt;It is a type of MethodologyObject therefore, it may reference a detailed definition using FormalDocumentation or InFormalDocumentation Documents.&lt;/note&gt; &lt;note&gt;It is a type of ValueTypeObject therefore, it may be extracted from ModelTypes (or AccessibleModelTypeConstituent) in the context of a CollaborativeModelTemplate.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576604449923_588643_58276" xmi:uuid="e426be64-13ce-4ee8-af67-5c42434157da" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509706863430_990864_47528"/>
          <body>UUID from DistributionValueType distribution value part subclass of core_rd_v1#general part</body>
        </ownedComment>
        <name>DistributionValueType</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1511200349990_946654_40781" xmi:uuid="9f792a69-d6a3-416b-ac51-f1d45a6e7275" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1513759125668_202560_32622" xmi:uuid="3907a752-38a4-4531-8d09-3ec261dfe1cc" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1511200349990_946654_40781"/>
            <body>A DistributionValueType shall not inherit from itself.</body>
          </ownedComment>
          <name>NotInheritsFromSelf</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733816_26027_14652"/>
          <specification xmi:id="_18_4_1_1b310459_1511200349990_600104_40782" xmi:uuid="b72e771e-4c97-4e52-9f1a-bcf263b90e55" xmi:type="uml:OpaqueExpression">
            <body>self.InheritsFrom-&gt;excludes(self)</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733926_717863_15097" xmi:uuid="685ec7c2-a002-4f28-a4d5-ee95599ac3e8" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733656_958837_14221"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734076_692673_15808" xmi:uuid="ab744296-acb1-4e70-896c-1d27e719b3b5" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512737088591_951798_35958" xmi:uuid="1f89c34d-6ea7-4612-b609-7c15953266a0" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734076_692673_15808"/>
            <body>the DistributionValueType from which characteristics are inherited. This is like inheritance, but not in the computing language sense. The value of this attribute need not be specified. &lt;example&gt;a discrete distribution with a step-size property may inherit from a continuous linear distribution with a maximum and minimum properties.&lt;/example&gt; </body>
          </ownedComment>
          <name>InheritsFrom</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733816_26027_14652"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734656_658998_17610" xmi:uuid="2905abe6-9306-43cf-9546-368d7977c1ac" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734656_674792_17609" xmi:uuid="deb35ed9-e856-4e7b-9c10-ac47767fcbf7" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
          </upperValue>
          <association xmi:idref="_18_4_1_1b310459_1505839733816_33137_14654"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734076_430368_15809" xmi:uuid="2489334b-3566-4dfa-bb7d-2a388e9bd3b2" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512737167995_793168_36094" xmi:uuid="a748610d-c797-4e34-91af-437276418453" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734076_430368_15809"/>
            <body>a reference to the format for the distribution. The value of this attribute need not be specified. &lt;note&gt;This is the equivalent to the property of the same name in KeyValueType where it is string ValueTypeEnum.&lt;/note&gt;</body>
          </ownedComment>
