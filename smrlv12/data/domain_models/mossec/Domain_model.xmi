        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733886_266698_14905" xmi:uuid="25735b15-8aa7-4551-9b4a-b8ab91c68fb8" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733484_31712_14067"/>
          <body>A DigitalFile is a reference to a file that is stored on an electronic device. This may be a file or a uniform resource identifier.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576486810969_418339_59209" xmi:uuid="c6ac589a-2cc0-4966-bab6-51294623cd19" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1510043586961_399092_39832"/>
