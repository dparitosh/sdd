          </upperValue>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733956_157664_15317" xmi:uuid="33e13866-621c-488a-b572-9860935fa114" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512664272927_984524_32919" xmi:uuid="9cafe9f0-1706-40b0-add7-192ef669fd26" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_157664_15317"/>
            <body>the Person or Organization responsible for executing the AssociativeModelNetwork. &lt;note&gt;This is often the same as the SynchronizerOf, but a separate property is available if needed.&lt;/note&gt;</body>
          </ownedComment>
          <name>ExecutorOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733876_143414_14785"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733956_664620_15318" xmi:uuid="2241f1b1-183f-4035-b534-4478d4cdecea" xmi:type="uml:Property">
