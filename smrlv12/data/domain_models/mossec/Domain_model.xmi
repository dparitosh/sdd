      <packagedElement xmi:id="_18_4_1_1b310459_1521620924466_185800_44236" xmi:uuid="8e88c4d2-a3a9-466b-bc27-1bd2e8dfd2a7" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1521621055396_543804_44310" xmi:uuid="a902c861-145b-462d-a43a-ed094d863be4" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1521620924466_185800_44236"/>
          <body>A KeyValueType is the definition of a key piece of information available at the collaboration level. &lt;note&gt;It is a type of MethodologyObject therefore, it may reference a detailed definition using FormalDocumentation or InFormalDocumentation Documents.&lt;/note&gt; &lt;note&gt;It is a type of ValueTypeObject therefore, it may be extracted from ModelTypes (or AccessibleModelTypeConstituent) in the context of a CollaborativeModelTemplate.&lt;/note&gt; &lt;example&gt;In a CollaborativeModelTemplate for a preliminary design a component weight key value may be extracted from a geometric layout ModelType, but in CollaborativeModelTemplate for detailed design the component weight may be extracted from a complex weight accounting ModelType.&lt;/example&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576678104952_630754_62495" xmi:uuid="b270d456-ace2-480e-b653-d875cdd88bb8" xmi:type="uml:Comment">
          <annotatedElement href="../../../Core_model/ProductDataManagement/ProductDataManagement.xmi#_2_attr_Part-PartTypes"/>
          <body>mapped at subclass</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576678799110_743665_63704" xmi:uuid="b864bc04-2da8-4984-bd60-2a3daebcb431" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508158485522_332277_33140"/>
          <body>key value part sub class of: core_rd_v1#detail part</body>
        </ownedComment>
        <name>KeyValueType</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590581387735_453763_91250" xmi:uuid="a39f6fa4-75a1-4118-9c17-80576b3cc574" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590581387739_174768_91252" xmi:uuid="ab966171-79c3-4b30-a7ee-feda20958b66" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590581387735_453763_91250"/>
            <body>values shall be subClassof the reference data class.</body>
          </ownedComment>
          <name>ValueTypeConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733926_69301_15100"/>
          <specification xmi:id="_18_4_1_13110319_1590581387739_995506_91251" xmi:uuid="1500a45a-fc3b-4042-a9c0-36a9be8a21ec" xmi:type="uml:OpaqueExpression">
            <body>ValueType.mustBeSubClassOf('http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#83615252-c407-47c3-bec5-9b3c1945703e')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1521620974058_872359_44304" xmi:uuid="2167bfeb-518e-447f-af61-1aec112cbdec" xmi:type="uml:Generalization">
