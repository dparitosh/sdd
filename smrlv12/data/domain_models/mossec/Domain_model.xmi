      <packagedElement xmi:id="_18_4_1_13110319_1585811437842_698354_66426" xmi:uuid="96c8e871-c5fa-4236-8dd0-cdcb76825f2f" xmi:type="uml:Package">
        <name>Constraints</name>
        <packagedElement xmi:id="_18_4_1_1b310459_1509381524016_2890_48425" xmi:uuid="24907798-d2d3-40ac-8f65-86463bd3b8ee" xmi:type="uml:Class">
          <ownedComment xmi:id="_18_4_1_1b310459_1509381622079_420386_48444" xmi:uuid="b70c4a7b-eda7-48a2-8f93-0b7b4db9b5fa" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1509381524016_2890_48425"/>
            <body>A mapping constraint to extract suitable flow ports from the input collection which may be of type: Architecture ArchitectureElementInclusion BreakdownElement BreakdownElementAssociation ValueInstanceObject ModelInstance </body>
          </ownedComment>
          <name>SelectValueOfItem</name>
          <ownedRule xmi:id="_18_4_1_1b310459_1509457320113_885795_37476" xmi:uuid="2bac6ba1-f955-4165-9d63-224c21e71939" xmi:type="uml:Constraint">
            <ownedComment xmi:id="_18_4_1_13110319_1515486650205_650781_40743" xmi:uuid="06e35297-12a4-4b7d-8799-5e06ac41aa3b" xmi:type="uml:Comment">
              <annotatedElement xmi:idref="_18_4_1_1b310459_1509457320113_885795_37476"/>
              <body>for all the type Architecture in the input collection this constraint extracts the appropriate flow port and sets the outCollectionView port.</body>
            </ownedComment>
            <constrainedElement xmi:idref="_18_4_1_1b310459_1509381524016_2890_48425"/>
            <specification xmi:id="_18_4_1_1b310459_1509457320113_614606_37477" xmi:uuid="56bd0705-6f8c-4329-89ac-be74afc23e45" xmi:type="uml:OpaqueExpression">
              <body>outCollectionView = input-&gt;select(voi : ValueOfItem | voi.oclIsTypeOf(Architecture)).targetView -- remove all the things from input that are not Architecture and then select the targetView port </body>
              <language>OCL2.0</language>
            </specification>
          </ownedRule>
          <ownedRule xmi:id="_18_4_1_1b310459_1509457596664_157103_37490" xmi:uuid="454a8e9e-d66d-49ce-9a4f-3e0f60aa96dc" xmi:type="uml:Constraint">
            <ownedComment xmi:id="_18_4_1_13110319_1515486596883_776048_40742" xmi:uuid="201fd421-1281-4b40-a13b-8a23daf20911" xmi:type="uml:Comment">
              <annotatedElement xmi:idref="_18_4_1_1b310459_1509457596664_157103_37490"/>
              <body>for all the type ArchitectureElementInclusion in the input collection this constraint extracts the appropriate flow port and sets the outCollectionMembership port.</body>
            </ownedComment>
            <constrainedElement xmi:idref="_18_4_1_1b310459_1509381524016_2890_48425"/>
            <specification xmi:id="_18_4_1_1b310459_1509457596664_405018_37491" xmi:uuid="adbc1bfe-cb2f-48e9-8a24-31a9e9b2d4b2" xmi:type="uml:OpaqueExpression">
              <body>outCollectionMembership = input-&gt;select(voi : ValueOfItem | voi.oclIsTypeOf(ArchitectureElementInclusion)).target -- remove all the things from input that are not ArchitectureElementInclusion and then select the target port </body>
              <language>OCL2.0</language>
            </specification>
          </ownedRule>
          <ownedRule xmi:id="_18_4_1_1b310459_1509381524037_488760_48427" xmi:uuid="b6af3f9d-526a-4abb-9c06-c9543b0babd3" xmi:type="uml:Constraint">
            <ownedComment xmi:id="_18_4_1_13110319_1515486720093_344410_40744" xmi:uuid="c2a8600e-51fe-4f6d-a955-46cd952e2462" xmi:type="uml:Comment">
              <annotatedElement xmi:idref="_18_4_1_1b310459_1509381524037_488760_48427"/>
              <body>for all the type ModelInstance or ValueInstanceObject (and their subtypes) in the input collection this constraint extracts the appropriate flow port and sets the outRealizedIndividualPart port.</body>
            </ownedComment>
            <constrainedElement xmi:idref="_18_4_1_1b310459_1509381524016_2890_48425"/>
            <specification xmi:id="_18_4_1_1b310459_1509381524037_422722_48428" xmi:uuid="3efff712-c9b2-4675-b33d-b91ff6d93c04" xmi:type="uml:OpaqueExpression">
              <body>outRealizedIndividualPart = input-&gt;select(voi : ValueOfItem | voi.oclIsKindOf(ModelInstance) or voi.oclIsKindOf(ValueInstanceObject)).targetVersion -- remove all the things from input that are not ModelInstance or ValueInstanceObject (or subtype of) and then select the targetVersion port </body>
              <language>OCL2.0</language>
            </specification>
          </ownedRule>
          <ownedRule xmi:id="_18_4_1_1b310459_1509452428803_56829_35095" xmi:uuid="c8aa74c5-f77e-4bc8-be00-c6f39d093ae2" xmi:type="uml:Constraint">
            <ownedComment xmi:id="_18_4_1_13110319_1515486463299_728862_40740" xmi:uuid="38560a37-efc6-410d-a780-9e44e52ea96f" xmi:type="uml:Comment">
              <annotatedElement xmi:idref="_18_4_1_1b310459_1509452428803_56829_35095"/>
              <body>for all the type BreakdownElement or BreakdownElementAssociation in the input collection this constraint extracts the appropriate flow port and sets the outBreakdownElementWithRealization port. </body>
            </ownedComment>
            <constrainedElement xmi:idref="_18_4_1_1b310459_1509381524016_2890_48425"/>
            <specification xmi:id="_18_4_1_1b310459_1509452428803_61274_35096" xmi:uuid="43d20a65-ddf6-4209-9176-c8893b854df6" xmi:type="uml:OpaqueExpression">
              <body>outBreakdownElementWithRealization = input-&gt;select(voi : ValueOfItem | voi.oclIsTypeOf(BreakdownElement)).targetVersion-&gt;union(input-&gt;select(voi : ValueOfItem | voi.oclIsTypeOf(BreakdownElementAssociation)).targetView) -- remove all the things from input that are not BreakdownElement and then select the targetVersion port -- unioned with all the things from input that are not BreakdownElementAssociation and then select the targetView port </body>
