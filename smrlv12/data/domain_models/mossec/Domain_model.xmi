          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
          <body>IdentifiableObject is an abstract entity that is inherited by entities that have Identifiers and may have Names and Descriptions.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576487667472_732576_60003" xmi:uuid="c7ba2136-c897-4ec0-bd82-849184d0c3a2" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1506585483634_975002_29323"/>
          <body>Class: identifier (core)</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1509637280702_61308_35371" xmi:uuid="ed0043f4-b250-4316-9074-75eac7745b50" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507544414229_708864_35068"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509635610338_831916_34231"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509636535769_987364_34815"/>
          <body>need 0..1 for all name and descriptions, therefore if only one provided, use that, if more than one then make a set and use that. Although these are abstract they will in fact be either Descriptor or DescriptorSet</body>
        </ownedComment>
        <name>IdentifiableObject</name>
        <ownedRule xmi:id="_18_4_1_13110319_1512982061855_738299_34902" xmi:uuid="40ace655-2794-4a40-a9bf-6d1f05c7beb0" xmi:type="uml:Constraint">
