          <upperValue xmi:id="_18_4_1_1b310459_1505839734616_426027_17244" xmi:uuid="643f3774-2839-44e5-bf10-deb60c144438" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
