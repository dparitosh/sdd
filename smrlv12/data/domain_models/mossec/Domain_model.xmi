          <ownedComment xmi:id="_18_4_1_13110319_1513008160283_545030_35330" xmi:uuid="c68c79d7-7afb-4cc3-bd14-41b95af3f2fc" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_68764_15295"/>
            <body>the items that are part of the ModelInstance but are accessible. The value of this attribute need not be specified. &lt;example&gt;Publication of a surface by name in a geometry model.&lt;/example&gt;</body>
          </ownedComment>
          <name>Constituents</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733696_607128_14329"/>
