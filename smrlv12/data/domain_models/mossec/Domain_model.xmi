      <packagedElement xmi:id="_18_4_1_1b310459_1505839733756_248281_14494" xmi:uuid="cd8398f8-248d-4e40-b3c3-bb7dcfef8582" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734026_35282_15652"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734016_466759_15610"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1505839734026_35282_15652" xmi:uuid="6024f516-882c-48b7-bcf0-aea3c0c03575" xmi:type="uml:Property">
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733756_975971_14480"/>
          <lowerValue xmi:id="_18_4_1_13110319_1584625811718_139670_70114" xmi:uuid="a6fe3657-d90a-4645-9032-0aab2edbcadd" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_13110319_1584625811719_317372_70115" xmi:uuid="774db515-7dac-47cb-acde-1f86b04c4dd6" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
