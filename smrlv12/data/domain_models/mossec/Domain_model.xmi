      <packagedElement xmi:id="_18_4_1_1b310459_1505839733806_906267_14625" xmi:uuid="387bbf17-7a94-41d9-bdef-e33aa6df1733" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576747243541_248826_60406" xmi:uuid="1ab3851b-dfdc-425b-a732-e4cf5f9d9fc2" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509695292444_45974_34726"/>
          <body>statistical moment property value assignment sub class of core_v1#property value assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734066_126499_15790" xmi:uuid="3c178ffd-9664-45a9-9dd2-ba2c1600f8f3" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733806_906267_14625"/>
          <body>A ParametricDistribution is a distribution that may be defined using parameters. &lt;note&gt;A distribution defined using defined using DistributionData Documents is a NonParametricDistribution.&lt;/note&gt; &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of distribution.&lt;/note&gt; &lt;example&gt;A distribution classification may be "Continuous" or "Discrete", then other classifications for the type of distribution such as "Normal" "Uniform" "Triangular". This may be different from the DistributionObjectType of which it is an instance.&lt;/example&gt; </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576489066880_505618_62278" xmi:uuid="7754b011-cb51-4264-918e-637011cb72cf" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509702992297_540267_42245"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509703335511_26956_42625"/>
          <body>Class: parametric distribution part UUID from ParametricDistribution Sub Class of: realized individual part</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1509695566193_866838_35089" xmi:uuid="a917f75d-4f48-41f1-8da9-0342baa595b0" xmi:type="uml:Comment">
          <annotatedElement href="../../../Core_model/CommonResources/CommonResources.xmi#_2_attr_AssignmentObject-Role"/>
          <body>role not provided as it is "property"</body>
        </ownedComment>
        <name>ParametricDistribution</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839734066_161526_15781" xmi:uuid="713c376f-f70e-4b03-8343-ad0330045ef0" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733806_578798_14622"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734066_125869_15791" xmi:uuid="516bad2f-f3d8-46dc-8f82-f5720c12ae8b" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1513759168739_386724_32623" xmi:uuid="19ac719c-fa1d-49f9-bf91-bfb9dc615543" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734066_125869_15791"/>
            <body>the properties that define the distribution. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>Property</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733484_14350_14062"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734656_801613_17593" xmi:uuid="fe6cf0d4-47aa-427b-af2d-fcbf4cc0cb05" xmi:type="uml:LiteralInteger"/>
