      <packagedElement xmi:id="_18_4_1_1b310459_1505839733886_706204_14815" xmi:uuid="6194fd31-a05f-454b-85ce-982b8c059b0e" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734596_799746_16922" xmi:uuid="9e2b41f6-1f71-4adc-a1b6-7621e2a38d78" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_52989_14816"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_706204_14815"/>
          <body>&lt;note&gt;These are the designated data types for an InformationUsageRightAssignment. Excludes: &lt;ul&gt;&lt;li&gt;DigitalFile;&lt;/li&gt; &lt;li&gt;RequirementShouldBeSatisfied, Verification;&lt;/li&gt; &lt;li&gt;Person, Organization;&lt;/li&gt; &lt;li&gt;PropertyDefinition, PropertyValue;&lt;/li&gt; &lt;li&gt;Approval;&lt;/li&gt; &lt;li&gt;All SecurityTrust (Contract, SecurityClassification &amp; InformationRight);&lt;/li&gt; &lt;li&gt;various relationship objects that just use ManagedObject.&lt;/li&gt;&lt;/ul&gt;&lt;/note&gt;</body>
        </ownedComment>
        <name>InformationUsageRightItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660268151_467696_50656" xmi:uuid="1102fa76-bc85-4ce5-8e84-d90139c720f1" xmi:type="uml:Port">
          <name>informationUsageRightItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/ManagementResources/ManagementResources.xmi#_InformationUsageRightAssignmentSelect"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733886_52989_14816" xmi:uuid="68722431-9f51-4b3b-b71e-d71f206d5f81" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1519203454462_346330_39903" xmi:uuid="381ad69e-753e-4e28-8d2e-337c4acbceef" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_52989_14816"/>
          <body>&lt;note&gt;These designated data types to which a SecurityClassification may be assigned. Excludes: &lt;ul&gt;&lt;li&gt;DigitalFile&lt;/li&gt; &lt;li&gt;RequirementShouldBeSatisfied, Verification&lt;/li&gt; &lt;li&gt;Person, Organization&lt;/li&gt; &lt;li&gt;PropertyDefinition, PropertyValue&lt;/li&gt; &lt;li&gt;Approval&lt;/li&gt; &lt;li&gt;All SecurityTrust (Contract, SecurityClassification &amp; InformationRight)&lt;/li&gt; &lt;li&gt;+ various relationship objects that just use ManagedObject&lt;/li&gt;&lt;/ul&gt;&lt;/note&gt;</body>
        </ownedComment>
        <name>SecurityClassificationItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660269370_361914_50662" xmi:uuid="c704f978-d339-4731-9aec-6bd752a0977f" xmi:type="uml:Port">
          <name>securityClassificationItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/CommonResources/CommonResources.xmi#_SecurityClassificationAssignmentSelect"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733826_416892_14683" xmi:uuid="7ead6128-cf89-486a-b13f-d20af1fbaef3" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576514791453_565117_74356" xmi:uuid="0226f95e-1f70-4d77-9588-3b77c4557718" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509967389980_573747_50596"/>
          <body>information right source sub class of: contractual document assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734086_16024_15840" xmi:uuid="a0aedd7d-d6fd-4c00-8f69-5775fe3c4cb0" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733826_416892_14683"/>
          <body>An InformationRight is a definition of what may or may not be done with information in the sense of legal rights and obligations. &lt;note&gt;This is a general purpose definition of a right that may be applied to many things. The usage of the InformationRight is represented by InformationUsageRight. The application of that right to information is represented by InformationUsageRightAssignment.&lt;/note&gt; &lt;example&gt;  A standard clause in a contract&lt;/example&gt; &lt;example&gt;Copyright is an InformationRight&lt;/example&gt; &lt;example&gt; The right to make copies during the life-cycle of a Study but those copies shall be destroyed at the end of the Study.&lt;/example&gt; &lt;example&gt;For the purposes of developing a new system, details of government furnished equipment may be made available to a particular project team. The team may copy and use the information internally, but may not share it with others, and must destroy the information at the end of the contract.&lt;/example&gt; </body>
        </ownedComment>
        <name>InformationRight</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_246410_14865" xmi:uuid="6fce52dc-cb58-46f3-916c-6cf400795b94" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734086_349507_15841" xmi:uuid="6cf5b2e4-199d-4ab5-844e-ba968a034460" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1512982464199_468704_34930" xmi:uuid="b00ae10a-244f-45c2-91bf-51ae839c6e54" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734086_349507_15841"/>
            <body>the Document or documents that are the source of the InformationRight. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>InformationSource</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733484_453986_14066"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734656_582142_17635" xmi:uuid="96203000-4fa4-47c8-beed-850ef3cb092d" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734656_132510_17634" xmi:uuid="001dac61-48d8-4bff-8207-ca5e38491de3" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
          </upperValue>
          <association xmi:idref="_18_4_1_1b310459_1505839733826_505868_14687"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734086_170541_15842" xmi:uuid="7f8f522d-f9e6-4f66-94fe-71f304eff6a9" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1512982800834_44791_34931" xmi:uuid="c38aca8b-5b4a-4ca1-adca-5811ada5da5f" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734086_170541_15842"/>
            <body>the text that describes any conditions and limitations that apply to the exercise of the InformationRight. The value of this attribute need not be specified. &lt;example&gt;The description of the right states that copying is permitted within the project team only, whereas the restriction notes the additional constraint that the information shall be destroyed at the end of the project.&lt;/example&gt;</body>
          </ownedComment>
          <name>Restriction</name>
          <visibility>public</visibility>
          <type href="../../../DataTypes.xmi#STRING"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734656_147021_17638" xmi:uuid="1eb03a37-c548-4ab3-bb3b-14c3ec2c414a" xmi:type="uml:LiteralInteger"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
