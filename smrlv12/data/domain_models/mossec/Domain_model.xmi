        <memberEnd xmi:idref="_18_4_1_13110319_1508343029419_850800_51396"/>
        <memberEnd xmi:idref="_18_4_1_13110319_1508343019029_411616_51370"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1508343029419_850800_51396" xmi:uuid="9e0868f2-3a17-4325-a253-28a345e9f536" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733534_949088_14165"/>
