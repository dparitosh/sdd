      <packagedElement xmi:id="_18_4_1_1b310459_1505839733696_133644_14326" xmi:uuid="0a44f54f-e2aa-42e2-878f-9eb62cf4c1fa" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576660315131_108494_55937" xmi:uuid="0fc49b03-471d-42ca-91f3-1988865e104a" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508337790966_479327_48213"/>
          <body>actual synchronizer assignment subclass of: core_rd_v1#actual person organization assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576490665377_605445_64217" xmi:uuid="1cdbc19f-a995-464b-a323-c2ae46c11ba6" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508426310783_454925_45980"/>
          <body>instance to type association sub class of part to individual part association</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576495664498_959857_68916" xmi:uuid="2757e9c2-9cc1-4e68-b239-7d05757e0d16" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508322173275_109298_38624"/>
          <body>actual watcher assignment sub class of: core_rd_v1#actual observer assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576659671328_913372_55529" xmi:uuid="4418bb21-fe29-400f-bc44-e96afa4341ed" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508337571607_430066_47898"/>
          <annotatedElement xmi:idref="_18_4_1_13110319_1508337790966_479327_48213"/>
          <body>actual executor assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1508495762749_523262_44443" xmi:uuid="8487f08f-fa48-4aed-bc21-122f6ba20163" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508495161491_188441_43907"/>
          <body>mapping rationale: PartVersionToIndividualPartVersion rather than PartToIndividualPart because not all MI versions will implement the same concept</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576492040055_16509_66011" xmi:uuid="86934b0c-0a98-431b-bcd5-9ba8b4344f84" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508154097931_246752_29836"/>
          <body>individual assembly constituent relationship sub class of: core_rd_v1# individual assembly relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576676659864_452174_60036" xmi:uuid="9647c190-659a-4b42-8253-6e448ece5c3f" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508428524334_796899_48198"/>
          <body>individual part version evolved from relationship sub class of: individual part version sequence relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576491885424_356136_65839" xmi:uuid="9a1d6f8e-71db-4f9f-a9a8-67eb97a89072" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508426425540_273450_46048"/>
          <body>model instance result documents assignment sub class of: description document assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1583767095262_60225_75091" xmi:uuid="9a5ca032-0555-451b-9bab-8f5a5acb5c37" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1562660236758_355773_50608"/>
          <body>this is an output port not a select port, therefore does not need mapping from a target</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1508495352773_667160_44160" xmi:uuid="a372fcb2-4378-405e-8b39-82d409bfa01e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508425814779_111503_45705"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508495161491_188441_43907"/>
          <body>mapping rationale: PartToIndividualPart rather than PartVersionToIndividualPartVersion because all MI versions are instances of same ModelType</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733956_311503_15291" xmi:uuid="d3c3fe1a-ffc6-43d5-b00d-f1c6ca34677e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733696_133644_14326"/>
          <body>A ModelInstance is model managed at the collaborative level and BelongsTo one AssociativeModelNetwork. It is defined by a ModelType. &lt;note&gt;A ModelInstance may have a references to Documents containing the model data for the instance. These is need not be specified because during the planning phase of the life-cycle a ModelInstance represents the identification of something needs to be modelled or simulated.&lt;/note&gt; &lt;note&gt;It is a type of ObjectWithPropertyValues therefore, it may have PropertyValues.&lt;/note&gt; &lt;note&gt;The audit trail for the derivation of the ModelInstance is represented by ModelInstanceIsDerivedFrom that references an input ModelInstance or KeyValueInstance. The ModelInstance or KeyValueInstance referenced may belong to a different AssociativeModelNetwork.&lt;/note&gt; &lt;note&gt;The audit trail for the evolution of the ModelInstances is represented by the IsEvolvedFrom reference property. This is similar to versions but allows a branching, diverging and converging evolution, and therefore, multiple "latest" evolutions as different solution options are investigated simultaneously.&lt;/note&gt; &lt;note&gt;A reference to Person or Organization shall be specified for the roles of ExecutorOf and SynchronizerOf. References to Person or Organization may be specified for the role of WatchersOf. These are also assumed to apply to every the ValueInstanceObject that IsExtractedFrom this ModelInstance.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;It is a type of ProgrammeObject therefore, it may have Approvals, Assumptions, Justifications, Contracts and SecurityTrust information.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt; &lt;note&gt;Identification that it is evidence needed to verify that something satisfies the Requirement is represented by Verification.&lt;/note&gt; &lt;note&gt;Identification that this is a realization of a BreakdownElement is represented by BreakdownElementRealizationAssociation.&lt;/note&gt; &lt;note&gt;Identification that this is a realization of a Component is represented by ComponentRealizationAssociation.&lt;/note&gt; &lt;note&gt;Identification that this is a realization of an InterfaceConnectionInstance is represented by InterfaceConnectionRealizationAssociation.&lt;/note&gt; &lt;note&gt;Identification that this is a realization of an InterfacePortInstance is represented by InterfacePortRealizationAssociation.&lt;/note&gt; &lt;note&gt;Identification that this is a realization of an Architecture is represented by ArchitectureRealizationAssociation.&lt;/note&gt; &lt;note&gt;Identification that this is a resource for a Method represented by MethodResourceAssignment.&lt;/note&gt; &lt;note&gt;It can be the Subject of a PlannedActivity or an ActualActivity.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576661657310_744833_56400" xmi:uuid="e151ba9e-9808-40dc-b1b5-045eed5d91ef" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508495600063_811801_44344"/>
          <body>instance to concept implements association subclass of core_rd_v1#part version to individual part version association</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576491112705_897681_65678" xmi:uuid="fb655f91-2ee4-4699-aca3-cf53fab447a6" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508489078210_959535_38273"/>
          <body>Class: model instance sub class of: realized individual part</body>
        </ownedComment>
        <name>ModelInstance</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1581338175166_953155_69496" xmi:uuid="3db0bee9-24cf-4901-b042-c1a901f17f2d" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1581338175182_310077_69498" xmi:uuid="de33966f-21c9-4fc8-99e2-175f44373549" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1581338175166_953155_69496"/>
            <body>when it has an EvolvedFrom reference it shall not point to itself.</body>
          </ownedComment>
          <name>notEvolvedFromSelf</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733746_683739_14437"/>
          <specification xmi:id="_18_4_1_1b310459_1581338175182_546930_69497" xmi:uuid="cacee300-204d-42e6-8359-b97525d36e46" xmi:type="uml:OpaqueExpression">
            <body>self.EvolvedFrom &lt;&gt; self</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1590589330839_305880_97904" xmi:uuid="8953137f-d1be-44bf-8f7e-765294593772" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590589330844_118618_97906" xmi:uuid="6d926cfb-fcd3-4a82-9e45-b10cc802ee50" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590589330839_305880_97904"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>StatusConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733956_809479_15300"/>
          <specification xmi:id="_18_4_1_13110319_1590589330844_473939_97905" xmi:uuid="7bae2095-43aa-459e-a38d-5ed1cee5f493" xmi:type="uml:OpaqueExpression">
            <body>Status.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#5ac94c00-f0ae-4bb7-8f15-04713ca419fb')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
