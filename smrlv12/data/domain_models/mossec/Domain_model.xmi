          <ownedComment xmi:id="_18_4_1_13110319_1513008115614_760053_35329" xmi:uuid="301c48ab-7bae-4fee-977a-88b575690321" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_266002_15294"/>
            <body>the ModelType that is the definition for the ModelInstance.</body>
          </ownedComment>
