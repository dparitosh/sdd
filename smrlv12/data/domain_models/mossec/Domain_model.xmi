      <packagedElement xmi:id="_18_4_1_1b310459_1505839733876_638863_14792" xmi:uuid="0142c2e5-5e06-4755-ab37-eb059b0eddb0" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734586_744363_16847" xmi:uuid="b5125695-29aa-4901-80ec-ea40bb32255e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733876_638863_14792"/>
          <body>&lt;note&gt;These designated data types may be derived in the context of a CollaborativeModelTemplate.&lt;/note&gt;</body>
        </ownedComment>
        <name>CollaborativeModelTemplateItem</name>
        <isAbstract>true</isAbstract>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733656_866256_14223" xmi:uuid="09eb765e-8dc2-40bd-aa46-2a150f72024d" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733926_687755_15114" xmi:uuid="2186bed0-59c8-40d0-98d9-4ee30513a92c" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733656_866256_14223"/>
          <body>The ModelTypeIsDerivedFrom represents a derivation relationship between different instances of ModelType or between a ModelType and a KeyValueType. These are in the context of a CollaborativeModelTemplate which means that the relationship is only applicable for that template. &lt;note&gt;If a relationship is needed between the same two items in more than one template, the preferred option is to use the CollaborativeModelTemplate IsComposedOf property incorporating the relationships from that other template. However duplication of ModelTypeDerivedFrom may be used.&lt;/note&gt; </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576746117016_746363_59712" xmi:uuid="60f19c83-f801-4431-b6cc-6d6fc422c9b4" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508165918911_996374_41682"/>
          <body>core_rd_v1#derivation part version relationship</body>
        </ownedComment>
        <name>ModelTypeIsDerivedFrom</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510143025361_283395_34256" xmi:uuid="4fc18561-6396-481a-838f-48a1b8950fb3" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513009198179_23376_35451" xmi:uuid="89244a96-636b-48a7-a944-51ae70ecc3ce" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510143025361_283395_34256"/>
            <body>A ModelType shall not be derived from itself.</body>
          </ownedComment>
          <name>DerivedFromNotModel</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733656_866256_14223"/>
          <specification xmi:id="_18_4_1_13110319_1510143025361_488741_34257" xmi:uuid="7586a6bc-81e9-470a-b8d1-616d07f6e1dd" xmi:type="uml:OpaqueExpression">
            <body>self.Model &lt;&gt; self.DerivedFrom</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_146151_14917" xmi:uuid="1632d540-1baf-4ca5-8fca-cb74c76e35af" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733926_765593_15115" xmi:uuid="0d9aa021-3a7a-4160-9cee-db70587cae7c" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513009142850_690168_35448" xmi:uuid="131e33f4-69d0-4a5c-9e25-217fa37ff7a1" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733926_765593_15115"/>
            <body>the item from which the ModelType is derived.</body>
          </ownedComment>
          <name>DerivedFrom</name>
