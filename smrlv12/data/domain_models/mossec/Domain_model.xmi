        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733966_393870_15370" xmi:uuid="ed394e2b-6d81-4dfd-b6f0-b55e4a7594f6" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513003824385_651765_33570" xmi:uuid="04aee2ad-a7f9-4820-a449-88c37431c5fb" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733966_393870_15370"/>
            <body>As part of a study, a ValueInstanceObject may be identified as implementing one or more Concepts. The value of this attribute need not be specified. &lt;example&gt;If a Concept was an instruction from an architect to "Try thickening the joint area", then the expert may assign a specific value to the KeyValueInstance representing the joint thickness.&lt;/example&gt;</body>
          </ownedComment>
          <name>Implements</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733686_154265_14288"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734626_206803_17305" xmi:uuid="5d1f34ff-7956-4afc-a7cf-72d373e8cb3a" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734626_569808_17304" xmi:uuid="d90b86ce-239b-4121-a79a-7472a3d6374c" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
          </upperValue>
          <association xmi:idref="_18_4_1_1b310459_1505839733706_79290_14352"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733966_997016_15371" xmi:uuid="91751038-0240-408f-a46c-4e4bf40d1c55" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734626_107013_17308" xmi:uuid="fe6c6b62-de23-4bb9-bb62-90abe2a8ae56" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733966_997016_15371"/>
            <body>the identification that this is a value of a particular referenced item. The value of this attribute need not be specified. &lt;example&gt;The KeyValueType may identify that is a joint thickness measures in mm, but this points to the actual joint in a breakdown.&lt;/example&gt; &lt;example&gt;The DistributionValueType may identify that it is a random uncertainty in a tolerance, but this points to the KeyValueInstance of the tolerance and provides the uncertainty for that tolerance.&lt;/example&gt;</body>
          </ownedComment>
          <name>ValueOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733876_649165_14810"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734626_863342_17309" xmi:uuid="4fc6d696-32ea-4a6f-8c05-049d1c41a25f" xmi:type="uml:LiteralInteger"/>
