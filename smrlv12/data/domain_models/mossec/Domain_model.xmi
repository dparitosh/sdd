            <annotatedElement xmi:idref="_18_4_1_13110319_1510139402667_82393_32567"/>
            <body>The AssociatedTo shall not be the same as the AssociatedFrom</body>
          </ownedComment>
          <name>toNotFrom</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733746_683739_14437"/>
          <specification xmi:id="_18_4_1_13110319_1510139402667_516285_32568" xmi:uuid="9d02ac27-c0fd-4852-867b-06d68b290c9f" xmi:type="uml:OpaqueExpression">
            <body>self.AssociatedTo &lt;&gt; self.AssociatedFrom</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
