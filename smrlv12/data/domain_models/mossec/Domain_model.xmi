            <annotatedElement xmi:idref="_18_4_1_13110319_1512982061855_738299_34902"/>
            <body>the Names ContextString shall be in different Contexts.</body>
          </ownedComment>
          <name>DifferentContextsName</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733886_844422_14882"/>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
