      <packagedElement xmi:id="_18_4_1_13110319_1588679145005_618468_71584" xmi:uuid="36b1ce81-0153-4a33-8065-023497b5df07" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_13110319_1588679145005_752116_71585"/>
        <memberEnd xmi:idref="_18_4_1_13110319_1588679140973_183941_70977"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1588679145005_752116_71585" xmi:uuid="09ccadc2-0215-4aad-9b0b-6166806c7cb5" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733766_700222_14526"/>
