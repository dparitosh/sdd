    <packagedElement xmi:id="_18_4_1_1b310459_1505839733484_639685_14054" xmi:uuid="e2c27bd4-a7d4-42cf-8191-ad3572289533" xmi:type="uml:Package">
      <ownedComment xmi:id="_18_4_1_1b310459_1576516765933_879756_76210" xmi:uuid="3718964b-b416-45a6-85b2-3b5401949f46" xmi:type="uml:Comment">
        <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733836_410940_14696"/>
        <body>AP243 question: should we change this to Contractors and have another Contractee property?</body>
      </ownedComment>
      <ownedComment xmi:id="_18_4_1_1b310459_1512638697339_673787_32556" xmi:uuid="60e5555f-3c4d-4659-b080-8e61aae0389e" xmi:type="uml:Comment">
        <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733484_639685_14054"/>
        <body>This capability used for capturing information used for Security and Trust in a collaborative context. the information is used by individual organizations to enforce their own human resources and security policies. Because these policies are not common across the organizations, what is recorded is the information about security and trust. Implementation platforms then use the security and trust information to enforce the local policies. &lt;example&gt;One company may require a senior manager to approve the release of a model with a security classification of “confidential” model and only to organizations in the EU. For the same security classification another organization may require two senior managers to approve the release and only to organizations that have signed a “risk sharing partnership” agreement.&lt;/example&gt; The Figure below provides an overview of this capability. &lt;figuresysml&gt;&lt;id&gt;_18_4_1_1b310459_1578993492867_664867_74343&lt;/id&gt;Overview of the Security and Trust capability&lt;/figuresysml&gt;</body>
      </ownedComment>
      <ownedComment xmi:id="_18_4_1_13110319_1588667969223_251283_70408" xmi:uuid="696203cf-4357-49c4-a13f-457f688df82f" xmi:type="uml:Comment">
        <annotatedElement xmi:idref="_18_4_1_1b310459_1509982512248_807119_58610"/>
        <body>core_v1#SecurityClassificationLevel</body>
      </ownedComment>
      <name>SecurityTrust</name>
      <packagedElement xmi:id="_18_4_1_1b310459_1509960293410_754930_36889" xmi:uuid="047cdb95-0ce7-48e3-9f37-eafeba9dcc07" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1509960293410_558828_36890"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1509960237980_446601_36864"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1509960293410_558828_36890" xmi:uuid="828a6f9b-cea0-4b70-912d-6fe2ce5504e2" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733826_344400_14684"/>
          <association xmi:idref="_18_4_1_1b310459_1509960293410_754930_36889"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733886_892420_14814" xmi:uuid="0ee666dc-e2f5-4f81-b48f-6ce357380fc7" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734596_883030_16915" xmi:uuid="890e1f49-51fc-428a-96e9-be92fed1a0b1" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733886_892420_14814"/>
          <body>&lt;note&gt;These designated data types to which a contract may be assigned.&lt;/note&gt;</body>
        </ownedComment>
        <name>ContractItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660266526_349548_50650" xmi:uuid="cbf0fc1d-afc6-4609-b7c3-8957c9544397" xmi:type="uml:Port">
          <name>contractItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/ManagementResources/ManagementResources.xmi#_ContractAssignmentSelect"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733826_688180_14682" xmi:uuid="13b71d58-cf14-45d4-80a2-f8cae802cfea" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734086_213459_15834" xmi:uuid="ee9a7385-3853-471f-9167-c36c3928e886" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733826_688180_14682"/>
          <body>An InformationUsageRight is an application of an InformationRight to a particular usage context. &lt;note&gt;One view of the distinction between an InformationRight and an InformationUsageRight is that the InformationRight represents a standard clause in a contract, whereas an InformationUsageRight represents the fact that the clause is used in a particular contract.&lt;/note&gt; &lt;note&gt;The context for the usage may be defined through the Contract which defines the right, the Organization that grants the right, the Person or Organization that is granted the right, and any dates such as the EffectiveFromDate and EffectiveToDate for the assigned right. The meaning of each association is identified through the roles of the assignments, and these are defined through reference-data used for the ClassifiedAs.&lt;/note&gt; &lt;note&gt;It is a type of ObjectWithApprovals therefore, it may have Approvals. The Approval of an InformationUsageRight carries the meaning that the right is granted to all information items in the relevant context, as opposed to the approval of an InformationUsageRightAssignment that is limited to particular items.&lt;/note&gt; &lt;note&gt;InformationUsageRight provides a mechanism for recording significant rights within a product database. The legal significance of the presence or absence of a right is outside the scope of this part of ISO 10303&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject. The Descriptions may be used to provide further information about the InformationUsageRight.&lt;/note&gt;</body>
        </ownedComment>
        <name>InformationUsageRight</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_51342_14843" xmi:uuid="185901ee-aa38-410f-9201-5b15e52a9db2" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839734086_181030_15832" xmi:uuid="5939b2d9-5e9d-41cb-9b86-b43634ec4e60" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733886_892420_14814"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839734056_296661_15736" xmi:uuid="ef7c5ec2-00a7-4a45-a502-4d5c45d3aef4" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733786_981753_14561"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734086_777268_15835" xmi:uuid="b44e2fc5-813f-4ce7-9363-5fe3b992bffe" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1512983018267_15798_35252" xmi:uuid="b3bac49f-916d-429c-8b79-4690857aa3b8" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734086_777268_15835"/>
            <body>the set of InformationRight granted under this usage.</body>
          </ownedComment>
          <name>GrantsRight</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733826_416892_14683"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734656_366935_17625" xmi:uuid="870c2ead-1cf3-4cbf-9858-0e4b2354d21e" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
