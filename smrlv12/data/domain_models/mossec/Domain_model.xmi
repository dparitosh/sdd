            <annotatedElement xmi:idref="_18_4_1_13110319_1551107893870_66739_44392"/>
            <body>a KeyValueType shall be ExtractedFrom at most one item in the Context of a CollaborativeModelTemplate. </body>
          </ownedComment>
          <name>UniqueForContext</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733656_171926_14220"/>
          <specification xmi:id="_18_4_1_13110319_1551107893874_9816_44393" xmi:uuid="ad6a3340-3934-4f80-a5e5-789b3b395297" xmi:type="uml:OpaqueExpression">
            <body>KeyValueTypeIsExtractedFrom::allInstances()-&gt;isUnique(Sequence{Context, KeyValue})</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_696840_14914" xmi:uuid="318b0e81-593f-4f12-8829-063936517c53" xmi:type="uml:Generalization">
