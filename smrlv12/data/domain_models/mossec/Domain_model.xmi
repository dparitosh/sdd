      <packagedElement xmi:id="_18_4_1_1b310459_1505839733876_922520_14812" xmi:uuid="3c61c5b9-748a-475b-b5c7-caec99f5a57f" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734596_697583_16904" xmi:uuid="ad0d1b80-45a4-4daf-ab49-668a9831452f" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733876_922520_14812"/>
          <body>&lt;note&gt;These designated data types may realize ComponentRealizationItems.&lt;/note&gt; </body>
        </ownedComment>
        <name>ComponentItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660181206_806065_50518" xmi:uuid="19a8ad61-6008-48d0-8068-5c4e9bb8adab" xmi:type="uml:Port">
          <name>componentItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/Collection/Collection.xmi#_18_4_1_1b310459_1581931100237_951444_56750"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733746_904505_14432" xmi:uuid="403c96ab-7320-4186-a0f9-bda593aad5c0" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1568725204606_969104_50482" xmi:uuid="44ec17cb-93a9-47d2-a1a0-347adfd4670d" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733996_980238_15496"/>
          <body>subClassOf= core_v1: breakdown element prefLabel=functional breakdown element prefLabel=physical breakdown element prefLabel=logical breakdown element prefLabel=spatial breakdown element</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733996_781786_15495" xmi:uuid="63dcd78b-039b-4da6-a394-9e1c0fb0c81d" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733746_904505_14432"/>
          <body>A BreakdownElement is a constituent in one or more Breakdown objects. In such a structure a BreakdownElement may play the role of a parent or a child or both, and it may be allocated to other BreakdownElements. The Type property is an enumeration representing the purpose of the BreakdownElement. &lt;note&gt;The Type property can be used to apply business rules to control the types of Elements [BreakdownElements] that can be added to the Breakdowns. Alternatively the Breakdown may use theClassifiedAs property inherited from ManagedObject to allow tailoring by business rules.&lt;/note&gt; &lt;note&gt;It is a type of VersionableObject therefore, it shall have at least one VersionIdentifiers property.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;Parent-child relationships are represented by BreakdownElementStructuralAssociation.&lt;/note&gt; &lt;note&gt;Links, allocations or associations between BreakdownsElements are represented by BreakdownElementAssociation.&lt;/note&gt; &lt;note&gt;Links between a BreakdownElement and items that realize it are represented by BreakdownElementRealizationAssociation.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt; &lt;note&gt;It may be a RequirementSource.&lt;/note&gt; &lt;note&gt;They are used extensively in the InterfacesManagement capability.&lt;/note&gt; &lt;note&gt;They may be the ValueOf a ValueInstanceObject therefore, allowing traceable properties for likelihood of change to be applied to an element in a breakdown&lt;/note&gt;</body>
        </ownedComment>
        <name>BreakdownElement</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590591834858_575992_99748" xmi:uuid="57dc7a37-3578-40f5-8c31-28df811b0480" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590591834863_553589_99750" xmi:uuid="027e4b99-bab8-469c-8e49-636bdd61f924" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590591834858_575992_99748"/>
            <body>values shall be subClassof the reference data class.</body>
          </ownedComment>
          <name>TypeConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733996_980238_15496"/>
          <specification xmi:id="_18_4_1_13110319_1590591834862_556086_99749" xmi:uuid="d7cd868e-cdc8-4af4-a158-97fca781daf7" xmi:type="uml:OpaqueExpression">
            <body>Type.mustBeSubClassOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89919ff0-130a-0135-b552-598f1b1392ae')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
