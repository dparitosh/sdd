      <packagedElement xmi:id="_18_4_1_1b310459_1505839733746_600380_14436" xmi:uuid="7d2ec6be-5408-478a-9dab-b056f4ec2a4a" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734006_596732_15526" xmi:uuid="29dc6074-5c26-42d8-b36d-72bc369d20bc" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733746_600380_14436"/>
          <body>ComponentAssemblyUsage is the relationship that structures the components, establishing a relationship between a component and its immediate parent assembly in a product structure. &lt;note&gt;Links between ModelInstances and usage of Components are represented by ComponentRealizationAssociation.&lt;/note&gt; &lt;example&gt;A fuel pump in a particular location in a wing.&lt;/example&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576498300480_732318_69842" xmi:uuid="a0c04bb6-46a5-4c38-8519-821ab1ad5524" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1521566880569_101211_47612"/>
          <body>component assembly usage sub class of: next assembly view usage</body>
        </ownedComment>
        <name>ComponentAssemblyUsage</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510139521607_753323_32653" xmi:uuid="de87db80-7eab-4e7d-ad44-eaa62017b2ec" xmi:type="uml:Constraint">
