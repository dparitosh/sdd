      <packagedElement xmi:id="_18_4_1_1b310459_1505839734116_392243_15882" xmi:uuid="7fb3a82d-3ffa-48a0-84a7-f1da9c00d96f" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576749616902_569956_61797" xmi:uuid="47665a61-2a31-437c-b2a9-27219ff6230e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1549280458829_82759_47488"/>
          <body>quality report instance subclass of ap243_v1#model instance</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734676_580264_17726" xmi:uuid="e300c94e-9d3f-4da4-87bd-08ac0bd2bcfc" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734116_392243_15882"/>
          <body>A QualityReportInstance is report on the quality of a ModelInstance. &lt;note&gt;It is a type of ModelInstance therefore: &lt;ul&gt;&lt;li&gt;the audit trail for the derivation is represented by ModelInstanceIsDerivedFrom and there is no restriction in the use of QualityReportInstance in the audit trail, therefore, a ModelInstance may be derived from a QualityReportInstance and a QualityReportInstance may be derived from a ModelInstance;&lt;/li&gt; &lt;li&gt;a reference to Person or Organization shall be specified for the roles of ExecutorOf and SynchronizerOf. References to Person or Organization may be specified for the role of WatchersOf;&lt;/li&gt; &lt;li&gt;ValueInstanceObjects may be extracted from a QualityReportInstance.&lt;/li&gt; &lt;/ul&gt;&lt;/note&gt; &lt;note&gt;The ModelInstance properties for IsAnInstanceOf and IsEvolvedFrom are redefined to restrict them only to other QualityReportInstances.&lt;/note&gt; &lt;note&gt;The link between a ModelInstance and a QualityReportInstance is represented by ModelIInstanceHasQualityReport. There may be many ModelIInstanceHasQualityReport referencing the same ModelInstance to allow different types of report for the same model. Similarly there may be many ModelIInstanceHasQualityReport referencing the same QualityReportInstance to allow one report for more than one model.&lt;/note&gt; &lt;example&gt;Two ModelInstance may have the same QualityReport when checking if the two things are modelled sufficiently well that they will fit together.&lt;/example&gt; &lt;example&gt;A ModelInstance may have one QualityReport for the format and a different one for content.&lt;/example&gt; &lt;note&gt;The BelongsTo AssociativeModelNetwork reference of a QualityReportInstance may different to the BelongsTo AssociativeModelNetwork reference of ModelInstance for which it is a report.This allows the management of the quality reporting to be separated from the management of the models.&lt;/note&gt; </body>
        </ownedComment>
        <name>QualityReportInstance</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839734676_113120_17724" xmi:uuid="95812c48-96d1-43c7-9c9a-c528dac79e97" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733696_133644_14326"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734676_119963_17727" xmi:uuid="0da30603-37e1-490f-85fa-d601c2f486ae" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1549364486581_418289_40000" xmi:uuid="3c6d02ce-23dd-4bb2-9093-a30842235229" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734676_119963_17727"/>
            <body>the QualityReportType that is the definition for the QualityReportInstance.</body>
          </ownedComment>
          <name>IsAnInstanceOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734116_471735_15883"/>
          <association xmi:idref="_18_4_1_1b310459_1505839734126_273882_15891"/>
          <redefinedProperty xmi:idref="_18_4_1_1b310459_1505839733956_266002_15294"/>
        </ownedAttribute>
