            <annotatedElement xmi:idref="_18_4_1_13110319_1587972877398_403051_65728"/>
            <body>MimeType shall be rdfs:subClassOf the reference data class.</body>
          </ownedComment>
          <name>MimeTypeConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733886_429155_14907"/>
          <specification xmi:id="_18_4_1_13110319_1587972877413_471477_65729" xmi:uuid="90e6d265-be7a-411f-9f7c-7077aca81fb9" xmi:type="uml:OpaqueExpression">
            <body>MimeType.mustBeSubClassOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#d43cf954-6073-4e1f-bf09-c8c17e16c0f3')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
