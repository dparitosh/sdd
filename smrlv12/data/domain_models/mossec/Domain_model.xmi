        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733966_662792_15364" xmi:uuid="697bda6b-f69c-403e-9540-b5c6eadaf0f9" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513003585271_964149_33566" xmi:uuid="faac0fa3-d7b7-4136-bfa0-afe406b50d09" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733966_662792_15364"/>
            <body>a reference to another ValueInstanceObject from which this ValueInstanceObject is evolved. The value of this attribute need not be specified. &lt;note&gt;The reference is the equivalent of instance versions. Versions were not used because they imply a linear progression, where the evolution allows a diverging and converging progression, therefore, there may be more one "latest version".&lt;/note&gt; &lt;note&gt;The IsEvolvedFrom relationship contributes to the audit trail.&lt;/note&gt; &lt;note&gt;In most cases the ValueInstanceObject and the ValueInstanceObject from which it is evolved are IsAnInstanceOf the same type.&lt;/note&gt; </body>
          </ownedComment>
          <name>IsEvolvedFrom</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733706_13852_14331"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734626_958782_17297" xmi:uuid="12177c88-2b4c-46ab-8753-6781de770629" xmi:type="uml:LiteralInteger"/>
          <association xmi:idref="_18_4_1_1b310459_1505839733706_730148_14344"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733966_209631_15368" xmi:uuid="8d15024a-6725-4b38-802f-70f30fb9d43c" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513003702644_118040_33569" xmi:uuid="d00eea4c-8fed-47ca-b420-0ec274c718da" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733966_209631_15368"/>
            <body>The instance from which the ValueInstanceObject is to be, or was, extracted. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>IsExtractedFrom</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733876_432914_14794"/>
