          <general xmi:idref="_18_4_1_1b310459_1505839733876_892641_14802"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734046_303912_15727" xmi:uuid="96f3907e-9688-48fe-883f-fac34f4094ed" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512562991099_320462_33509" xmi:uuid="34a85c61-f9b1-4038-8bee-ed2608ea5d00" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734046_303912_15727"/>
            <body>the references to Person or Organization who actually approved or rejected the Approval. The value of this attribute need not be specified. &lt;note&gt;If more than one, then they all have the same status. If different status are needed for each approver then an individual Approval should be used for each approver.&lt;/note&gt; </body>
          </ownedComment>
          <name>ActualApprover</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733514_450704_14138"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734646_293482_17539" xmi:uuid="2b178504-5910-4367-804f-81caafa90925" xmi:type="uml:LiteralInteger"/>
