      <packagedElement xmi:id="_18_4_1_1b310459_1505839733826_286874_14680" xmi:uuid="3ab5e1c8-f6bf-4abf-a0c2-af67414c0f41" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1578921058011_120467_55230" xmi:uuid="2004a4d9-38ca-4110-8519-982e079520b7" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509969794673_959483_54452"/>
          <body>Reference Data core_rd_v1#assignment of required effectivity subclass of core_v1#effectivity assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734086_750855_15824" xmi:uuid="86cead90-b0c8-4865-a762-ecb14b0c2b17" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733826_286874_14680"/>
          <body>An InformationUsageRightAssignment is an assignment of a specific usage right to a set of items. &lt;note&gt;It is a type of ObjectWithApprovals therefore, it may have Approvals. If an Approval is applied to this entity, it carries the meaning that the specific set of items is approved for the given usage. This approval generally indicates that the approval is exceptional. There is a further implication that the set of entities should not be changed once the approval is given.&lt;/note&gt; &lt;example&gt;   Where the information belongs to another project, and that project can have an approval to agree to share some particular items of information.&lt;/example&gt;</body>
        </ownedComment>
        <name>InformationUsageRightAssignment</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839734056_336036_15738" xmi:uuid="1ba65456-2089-4a69-b856-e37488d5f30a" xmi:type="uml:Generalization">
