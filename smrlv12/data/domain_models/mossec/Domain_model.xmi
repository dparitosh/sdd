      <packagedElement xmi:id="_18_4_1_1b310459_1505839733756_269933_14502" xmi:uuid="0b630c15-1426-4cd9-9b6d-fcedaa150615" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734026_607275_15664"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734016_528730_15604"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1505839734026_607275_15664" xmi:uuid="cf0e7ce6-f3b8-4a1f-9bac-27668a84a25b" xmi:type="uml:Property">
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733756_627640_14479"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734636_699230_17461" xmi:uuid="f01fcaf5-b0dc-411b-bd5b-3f09f4505ec7" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734636_879228_17460" xmi:uuid="d26a2b84-2cd5-45db-91f5-97dc0a6f0279" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
          </upperValue>
          <association xmi:idref="_18_4_1_1b310459_1505839733756_269933_14502"/>
