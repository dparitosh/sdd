      <packagedElement xmi:id="_18_4_1_1b310459_1505839734406_21182_16446" xmi:uuid="89768be1-1638-4ee2-b911-ca6ad9956a57" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734876_548275_18291" xmi:uuid="102261e1-2fa7-48d0-ad4b-25e09688ff3f" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734406_21182_16446"/>
          <body>The PreferredMethod association is used to indicate which ApplicableMethod should be used for a ModelType in the context of the CollaborativeModelTemplate [CMT]. If the same ApplicableMethod is preferred for more than one CMT, then separate PreferredMethod objects are created, or one CMT may be composed of another CMT.&#13; A PreferredMethod does not have to be specified. If there is only one ApplicableMethod, then the PreferredMethod is superfluous. Or it may be that there is no opinion on which method should be used&#13;. </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576681940564_356926_66065" xmi:uuid="2d9daaa7-f6ac-4d34-9ab8-246aa92f5635" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1548954210325_123247_87183"/>
          <body>UUID from PreferredMethod preferred activity method assignment subclass of: core_v1#activity method assignment</body>
        </ownedComment>
        <name>PreferredMethod</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1551196384025_848510_40642" xmi:uuid="86fa905e-c3cb-4f01-940a-3090cf74598b" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1551196608977_632824_40644" xmi:uuid="2bd0f0fb-bc1c-4d2a-87a3-9e7b55f39271" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1551196384025_848510_40642"/>
            <body>the combination of the Context and the ApplicableMethod OutputType reference property shall be unique. </body>
          </ownedComment>
          <name>UniqueForContext</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839734406_21182_16446"/>
          <specification xmi:id="_18_4_1_1b310459_1551196384198_486567_40643" xmi:uuid="b8cb1367-fb8d-4fc1-b051-29b068d3819a" xmi:type="uml:OpaqueExpression">
            <body>PreferredMethod::allInstances()-&gt;isUnique(Sequence{Context, ApplicableMethod.OutputType})</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839734876_268438_18290" xmi:uuid="61b392ac-cc5e-4ba8-bcfa-0d663c7c026a" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734876_982060_18292" xmi:uuid="b6f304bd-4726-49a1-b67d-67964d257784" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839735186_568068_19401" xmi:uuid="e9f5bfbb-dfc7-44f0-8e79-bee4b16ded14" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734876_982060_18292"/>
            <body>the reference to the applicable method that is preferred for this context.</body>
          </ownedComment>
          <name>ApplicableMethod</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734406_995789_16448"/>
          <association xmi:idref="_18_4_1_1b310459_1505839734406_927495_16453"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734886_595074_18293" xmi:uuid="11630e9f-168c-4d38-a8c4-db87ba90277a" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839735186_112262_19403" xmi:uuid="547d78a8-0bf5-4078-b9a3-c68ccc8ca164" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734886_595074_18293"/>
            <body>the item that is the context in which the method is preferred.</body>
