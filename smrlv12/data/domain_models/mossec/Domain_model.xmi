        </generalization>
        <generalization xmi:id="_18_4_1_13110319_1586182837272_269893_84173" xmi:uuid="f4d45af9-6582-47c7-aff1-dba3e092f1ff" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733886_892420_14814"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734006_487608_15553" xmi:uuid="f35b12bd-4b0e-47e1-a5dc-f433e1bcf6f9" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512731423676_360624_33066" xmi:uuid="e14c1e2b-0c0e-47c9-8185-f9592ffecbf5" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734006_487608_15553"/>
            <body>the BreakdownElement objects that are the constituents of the Breakdown. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>Element</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733746_904505_14432"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734626_821711_17379" xmi:uuid="291d06d1-c87d-4e0e-a8ef-1997f8dfdf60" xmi:type="uml:LiteralInteger"/>
          <upperValue xmi:id="_18_4_1_1b310459_1505839734626_369000_17378" xmi:uuid="46a463c8-2e9c-4683-9424-34101d577662" xmi:type="uml:LiteralUnlimitedNatural">
            <value>*</value>
          </upperValue>
          <association xmi:idref="_18_4_1_1b310459_1505839733746_820077_14444"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734006_582132_15554" xmi:uuid="3cda7b14-d773-47d8-926a-6d714a65141e" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512731206855_234669_33065" xmi:uuid="33636c62-48ea-4a5e-9023-bcccec883d11" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734006_582132_15554"/>
            <body>the item that is broken down by the Breakdown.</body>
          </ownedComment>
          <name>BreakdownOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733876_908706_14804"/>
          <association xmi:idref="_18_4_1_1b310459_1505839733746_324719_14451"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734006_252689_15555" xmi:uuid="091a9ca4-2d66-461f-a070-47c86ed1d95b" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512731502502_179617_33067" xmi:uuid="57fa6298-83e1-4e49-a7e2-85b69244b039" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734006_252689_15555"/>
            <body>the string representing the purpose of the Breakdown where the value is restricted reference data. &lt;note&gt;The Type property can be used to apply business rules to control the types of Element that can be added to the Breakdown. Alternatively the Breakdown may use theClassifiedAs property inherited from ManagedObject to allow tailoring by business rules.&lt;/note&gt;</body>
          </ownedComment>
