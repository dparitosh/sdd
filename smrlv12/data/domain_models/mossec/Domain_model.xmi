      <packagedElement xmi:id="_18_4_1_1b310459_1505839733746_299318_14443" xmi:uuid="fa66831a-cdbe-4e1b-8f7c-d6d2ad50a2f6" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734006_317536_15562"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734006_429341_15538"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1505839734006_317536_15562" xmi:uuid="8ec3c111-a351-4fe7-beaa-f7f6589603e7" xmi:type="uml:Property">
