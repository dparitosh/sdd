          <aggregation>composite</aggregation>
          <association xmi:idref="_18_4_1_1b310459_1505839733706_430551_14341"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733956_536500_15296" xmi:uuid="d798b3f3-edfd-4fcc-bbd3-b169c25a6b7d" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513008263382_616531_35331" xmi:uuid="1c178565-6066-40a7-9767-a4412201aceb" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_536500_15296"/>
            <body>a reference to another ModelInstance from which this ModelInstance is evolved. The value of this attribute need not be specified. &lt;note&gt;The reference is the equivalent of instance versions. Versions were not used because they imply a linear progression, where the evolution allows a diverging and converging progression, therefore, there may be more than one "latest version".&lt;/note&gt; &lt;note&gt;The IsEvolvedFrom relationship contributes to the audit trail.&lt;/note&gt; &lt;note&gt;In most cases the ModelInstance and the ModelInstance from which it is evolved are IsAnInstanceOf the same ModelType.&lt;/note&gt;</body>
          </ownedComment>
          <name>IsEvolvedFrom</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733696_133644_14326"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734616_800147_17248" xmi:uuid="51881ae4-1ae1-4893-a358-325e2742ddc0" xmi:type="uml:LiteralInteger"/>
