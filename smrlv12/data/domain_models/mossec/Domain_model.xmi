      <packagedElement xmi:id="_18_4_1_1b310459_1505839733746_797891_14433" xmi:uuid="625330f6-ccf9-4faa-873a-c406032a2cfa" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576498987027_202772_70492" xmi:uuid="4fe87fed-2606-4ca2-b6e7-16b660f281ed" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1521565835706_25578_46153"/>
          <body>component sub class of: individual part</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734006_701655_15507" xmi:uuid="ec730082-1593-4223-a8e4-878de137e7ec" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733746_797891_14433"/>
          <body>A Component is something that represents something in the product. &lt;note&gt;It is a type of VersionableObject therefore, it shall have at least one VersionIdentifiers property.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;They are used extensively in the InterfacesManagement capability.&lt;/note&gt; &lt;note&gt;Parent-child relationships are represented by ComponentAssemblyUsage.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt; &lt;note&gt;Links between ModelInstances and Components are represented by ComponentRealizationAssociation.&lt;/note&gt; &lt;example&gt;Examples of Components are physicals things like a common fuel pump, an aircraft, fuselage, wing, engine, or a systems like a fuel system, electrical system.&lt;/example&gt;</body>
        </ownedComment>
        <name>Component</name>
        <generalization xmi:id="_18_4_1_13110319_1586182839639_392615_84175" xmi:uuid="0d20a1ec-d9c4-4e8d-9c75-04fd9a886ce5" xmi:type="uml:Generalization">
