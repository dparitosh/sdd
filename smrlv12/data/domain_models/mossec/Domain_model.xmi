    <packagedElement xmi:id="_18_4_1_1b310459_1548859088106_989943_43826" xmi:uuid="cac618cc-31f2-497b-a305-9b6ef8d4f675" xmi:type="uml:Package">
      <ownedComment xmi:id="_18_4_1_1b310459_1549365660179_200873_40440" xmi:uuid="5ed75a18-1582-43c3-8db7-72b59b369431" xmi:type="uml:Comment">
        <annotatedElement xmi:idref="_18_4_1_1b310459_1548859088106_989943_43826"/>
        <body>The QualityManagement capability provides the definition and identification of models that are quality specific, and the links between the quality models and other models in a collaborative context. It is an extension of the MethodologyManagement and ModelManagement capabilities, reusing their audit trail and management capabilities. The igure below provides an overview of this capability. &lt;figuresysml&gt;&lt;id&gt;_18_4_1_1b310459_1548862282807_979420_50895&lt;/id&gt;Overview of the Quality Management capability&lt;/figuresysml&gt; </body>
      </ownedComment>
      <name>QualityManagement</name>
      <packagedElement xmi:id="_18_4_1_1b310459_1582117095796_245989_78980" xmi:uuid="05afad05-d10c-4b3f-a66b-298f427d151d" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1582117095796_170734_78981"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1582117093562_184007_78883"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1582117095796_170734_78981" xmi:uuid="f178f9a4-387c-4eb4-9f77-7a8df261a996" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734126_401011_15889"/>
          <association xmi:idref="_18_4_1_1b310459_1582117095796_245989_78980"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839734126_401011_15889" xmi:uuid="1c7a0d41-7d3c-41ff-9e39-a73feaf06407" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734676_753816_17768" xmi:uuid="779cfaa6-a176-4969-b907-56b34dc88413" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734126_401011_15889"/>
          <body>A ModelTypeHasQualityReport relationship identifies that a QualityReportType is for a particular ModelType in the context of a CollaborativeModelTemplate . It is ManagedObject therefore, it has management information and may be classified. </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576744513163_631359_57684" xmi:uuid="a5d4b629-fa59-4351-846c-ff411e619b80" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1549281623681_304069_49754"/>
          <body>model type to quality report type relationship subclass of core_rd_v1 hierarchy part version relationship</body>
        </ownedComment>
        <name>ModelTypeHasQualityReport</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839734676_781958_17767" xmi:uuid="29260489-e7c8-45a4-bd4e-272545bc6f5f" xmi:type="uml:Generalization">
