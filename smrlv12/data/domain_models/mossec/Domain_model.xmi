        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733926_78457_15166" xmi:uuid="6d989614-ce38-4a09-8e01-6a0ed78d9720" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512734376339_936345_34556" xmi:uuid="e11f0170-cab1-46d9-8000-d02c7651db0a" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733926_78457_15166"/>
            <body>other instances of CollaborativeModelTemplate that composed together make up the full template. The value of this attribute need not be specified. &lt;example&gt;A team for one discipline may have several alternative templates for generating the same ModelType with different fidelity computations. Another team may require a specific fidelity ModelType as input to their template and therefore create a CollaborativeModelTemplate that IsComposedOf the other template with the required fidelity.&lt;/example&gt;</body>
          </ownedComment>
          <name>IsComposedOf</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733656_287576_14227"/>
