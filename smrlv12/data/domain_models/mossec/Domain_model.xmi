      <packagedElement xmi:id="_18_4_1_13110319_1585648163633_321525_76274" xmi:uuid="ed47f797-c9b4-489c-b35c-704c4977ce57" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_13110319_1585648163633_59214_76275"/>
        <memberEnd xmi:idref="_18_4_1_13110319_1585648140741_672470_76243"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1585648163633_59214_76275" xmi:uuid="cb506421-2a28-4a32-9763-df26e603d1b4" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733746_797891_14433"/>
          <association xmi:idref="_18_4_1_13110319_1585648163633_321525_76274"/>
