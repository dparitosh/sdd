      <packagedElement xmi:id="_18_4_1_1b310459_1505839733484_301280_14069" xmi:uuid="17ed5bbc-8643-441d-b4ce-3375a9867864" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733896_780601_14945" xmi:uuid="2d18da59-988c-4df0-ae79-4ea6e7ade03b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733484_301280_14069"/>
          <body>VersionableObject is an abstract entity that is inherited by entities that have one or more VersionIdentifiers.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1509612775971_319431_38073" xmi:uuid="3013a38e-141e-4cdf-a035-3f3ebfb1b42b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507556639470_569789_40392"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509612665214_374106_37864"/>
          <body>Even though this is an abstract object it will in fact always be with Identifier or IdentifierSet.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1509630354902_537514_45986" xmi:uuid="cd4e49cc-0ff5-4b70-8b99-fb4978d9ac74" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507556870106_850253_40675"/>
          <body>version identifier</body>
        </ownedComment>
        <name>VersionableObject</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1512735807764_160050_34753" xmi:uuid="e74f45e0-604a-4f70-94b0-29f5ddeb4c33" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1512735834861_748484_34755" xmi:uuid="b66b88f6-0817-4891-acdc-8edb49c38bef" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1512735807764_160050_34753"/>
            <body>The VersionIdentifiers context strings shall be in different contexts.</body>
          </ownedComment>
          <name>DifferentContexts</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733484_301280_14069"/>
          <specification xmi:id="_18_4_1_1b310459_1512735807764_89506_34754" xmi:uuid="78daac00-d186-4e2f-93e4-c4fabbf56ace" xmi:type="uml:OpaqueExpression">
            <body>The VersionIdentifiers ContextString instances shall be in different contexts.</body>
            <language>English</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_460864_14869" xmi:uuid="7f91de38-34f0-4a6e-b50b-6163dcb218b7" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
        </generalization>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733896_792550_14946" xmi:uuid="f44806eb-a469-417a-8f91-972b966dc45f" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513076108813_509932_36196" xmi:uuid="d292ae11-77fe-46ee-b85d-f6565350a7ff" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733896_792550_14946"/>
            <body>the ContextStrings identifying the versions for the object, this is the combination of the identifier and the version. &lt;note&gt;If more than one is specified, then the additional ones shall have a Context property that shall not be duplicated for the set of Identifiers.&lt;/note&gt; &lt;note&gt;The identifiers is required to distinguish the identifier from the version.&lt;/note&gt;</body>
          </ownedComment>
          <name>VersionIdentifiers</name>
          <visibility>public</visibility>
