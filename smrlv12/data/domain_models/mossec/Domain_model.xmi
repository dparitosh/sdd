      <packagedElement xmi:id="_18_4_1_1b310459_1505839733876_793148_14786" xmi:uuid="b715d37a-c1cc-4a7c-9b5c-da6bfb074c74" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1513073593109_895936_35907" xmi:uuid="90f789cf-f22d-4d6d-906d-b449933a94f4" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733876_793148_14786"/>
          <body>&lt;note&gt;These designated data types may be inputs to a study. They are used to identify previous work that is relevant to, or reused by the Study.&lt;/note&gt;</body>
        </ownedComment>
        <name>StudyItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660276792_936624_50680" xmi:uuid="5cc09397-7c90-41c3-b666-1658b08bc2bc" xmi:type="uml:Port">
          <name>studyItem</name>
          <visibility>public</visibility>
          <type href="../../../Core_model/Activity/Activity.xmi#_ActivityAssignmentSelect"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733686_154265_14288" xmi:uuid="b73f82ca-420d-42f2-87b2-a69cb5f86a99" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733936_779481_15204" xmi:uuid="9280620c-2e73-4006-bc2f-9ac68d58ed6b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733686_154265_14288"/>
          <body>A Concept is a textual description that identifies what is to be varied, added, investigated, recommended or decided by the Study. It may have SupportingDocuments containing more details about the Concept. A Concept is not itself part of a product definition, but is implemented by a ModelInstance or KeyValueInstance in an AssociativeModelNetwork ManagedBy a Study. &lt;note&gt;In addition to instances of Concept, a Study may directly reference ModelInstance or KeyValueInstance as a Concepts for the Study.&lt;/note&gt; &lt;example&gt;Examples of Concepts are: shape; layout; technology standard; design concept; loading philosophy.&lt;/example&gt; &lt;example&gt;Concepts may be specific values such as "Try thickness of joint area = 200 mm" that the JointThickness KeyValueInstance Implements, or specific models such as "Investigate this DMU" that the DMU ModelInstance Implements.&lt;/example&gt; &lt;example&gt;Concepts may be textual descriptions such as "Thicken the joint area" or "Investigate alternative materials".&lt;/example&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576515532829_681220_75272" xmi:uuid="abcd71ec-8ee3-42bd-8b00-5c6ef500bb51" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508325041834_72586_42352"/>
          <body>concept part sub class of: general part</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576516177335_771641_75306" xmi:uuid="eb9c9b88-6507-450a-b209-e347380b7fba" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508325521137_324064_42946"/>
          <body>concept supporting document assignment subclass of core_rd_v1#additional information document assignment</body>
        </ownedComment>
        <name>Concept</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_117259_14845" xmi:uuid="50c3bd17-f0a6-4bb5-a441-b02b0f276181" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
        </generalization>
        <generalization xmi:id="_18_4_1_13110319_1586183808597_148872_85113" xmi:uuid="d487dbf3-af33-4f62-97b6-503055a287c0" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733876_892641_14802"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839733936_330897_15203" xmi:uuid="f5eb443c-385e-4464-aa7c-9b45219ea3b4" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733876_868930_14796"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733936_718953_15205" xmi:uuid="f541ee14-1650-4c6d-8c20-2d8210a7dd23" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512735175433_21411_34676" xmi:uuid="94ac1864-245e-4a06-b3fe-492919231be7" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733936_718953_15205"/>
            <body>When the concepts are textual descriptions they are not part of the product definition, therefore, are not included in the managed AssociativeModelNetwork. To provide more detail than a simple description, associated supporting documents may be added if needed. The value of this attribute need not be specified. &lt;example&gt;Examples of documents supporting a concept are a technology standard or graphs.&lt;/example&gt;</body>
          </ownedComment>
          <name>SupportingDocuments</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733484_453986_14066"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734616_88370_17187" xmi:uuid="5a61b9b4-212b-4ede-b9a4-6e66f5da97d4" xmi:type="uml:LiteralInteger"/>
