      <packagedElement xmi:id="_18_4_1_1b310459_1505839733826_738394_14686" xmi:uuid="c31a4429-076c-4214-846d-76cb94bb3658" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734096_27773_15860" xmi:uuid="1c47dbb3-1e66-4c1e-82dc-82eb5eeddd72" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733826_738394_14686"/>
          <body>A SecurityClassification is a level of confidentiality that may be applied to protect activity or product data against unauthorized usage. &lt;note&gt;It is an ObjectWithApprovals therefore, it may have Approvals and Authorizations to enable the sign-off of the classification.&lt;/note&gt; &lt;note&gt;The assignment of a SecurityClassification to an item is represented by SecurityClassificationAssignment.&lt;/note&gt;</body>
        </ownedComment>
        <name>SecurityClassification</name>
        <ownedRule xmi:id="_18_4_1_13110319_1588667801834_897386_70362" xmi:uuid="58bd96cc-0ad7-4450-98ed-e287b092dab6" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1588667801849_542697_70366" xmi:uuid="a9264cfd-ef13-4e37-b769-c91d9f18626e" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588667801834_897386_70362"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>LevelConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1509982512248_807119_58610"/>
          <specification xmi:id="_18_4_1_13110319_1588667801849_387491_70365" xmi:uuid="a2550af2-c307-4e94-9656-5fbd4c127cf8" xmi:type="uml:OpaqueExpression">
            <body>Level.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#de420483-9e8a-41af-9000-69c124abb275')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839734056_477109_15737" xmi:uuid="06843813-7734-41f7-8af5-d7b09efd0a9b" xmi:type="uml:Generalization">
