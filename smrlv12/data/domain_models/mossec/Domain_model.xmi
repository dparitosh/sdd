      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733756_501084_14482" xmi:uuid="0cefe0a7-370b-4d42-ad2b-7c4b3c13fa91" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734026_661822_15620" xmi:uuid="16db49fa-fa98-4617-827c-3194fb85eef3" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733756_501084_14482"/>
          <body>A PortTypeRelationship identifies an InterfacePortType hierarchy. It has a Type property that defines the type of hierarchy, and hence how the port properties or their realizations may be delegated or collated. &#13; &lt;note&gt;A port may be referenced by many PortRelationships.&lt;/note&gt; &lt;example&gt;A power port can have a hierarchical relationship to electrical power port and a thermal power port.&lt;/example&gt; &lt;note&gt;The PortOn property need not reference the same object.&lt;/note&gt; &lt;example&gt;A PortTypeRelationship of Type "delegation" is where the port on one system "delegates" it's properties to the port on one of its subsystems, for example the port on an aircraft engine system delegates to a port on the stator front case subsystem of the engine.&lt;/example&gt; &lt;note&gt;The PortTypeRelationship is an IdentifiableObject and ProgrammeObject because it may need a description for what is expected between the ports.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1590664672035_818952_69101" xmi:uuid="2d5e58b1-acfa-4761-9215-a24917f16481" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1588057751600_671596_66752"/>
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734026_852930_15623"/>
          <body>interface connector version relationship</body>
        </ownedComment>
        <name>PortTypeRelationship</name>
        <ownedRule xmi:id="_18_4_1_13110319_1588062804091_962310_68610" xmi:uuid="4d8aa466-8a52-440b-a8d4-07d1a7a1d9a3" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1588062804091_578030_68612" xmi:uuid="d7445541-268e-4aaa-a2cb-d5f0082fb31c" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588062804091_962310_68610"/>
            <body>values shall be subClassof the reference data class.</body>
          </ownedComment>
          <name>typeRD</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839734026_852930_15623"/>
          <specification xmi:id="_18_4_1_13110319_1588062804091_80596_68611" xmi:uuid="c4911f7e-df18-4c51-85ca-dae6943c7466" xmi:type="uml:OpaqueExpression">
            <body>Type.mustbeSubClassOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ca97b6c-c669-45d8-9851-867e50427242')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1512987671012_672360_36247" xmi:uuid="a3d631b3-906e-4e0a-bbd8-ec528c6ca430" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1512987827172_505958_36256" xmi:uuid="a1da6323-e7f4-4e76-a78a-1ef8642aa992" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1512987671012_672360_36247"/>
            <body>the parent PortTypeRelationship shall be different from the child PortTypeRelationship.</body>
          </ownedComment>
          <name>parentNotChild</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733756_501084_14482"/>
          <specification xmi:id="_18_4_1_13110319_1512987671012_643561_36248" xmi:uuid="e2541517-db4f-4d24-a2de-aadd37aaae1a" xmi:type="uml:OpaqueExpression">
            <body>self.Parent &lt;&gt; self.Child</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_13110319_1588082139842_997326_79291" xmi:uuid="325f7655-80f2-44b4-84e7-06f19e0317f7" xmi:type="uml:Generalization">
