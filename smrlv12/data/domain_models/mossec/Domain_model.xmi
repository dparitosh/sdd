      <packagedElement xmi:id="_18_4_1_1b310459_1509379826550_760063_48317" xmi:uuid="4f47bcf5-16bb-4312-9609-495ca1395505" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1509379826550_671118_48318"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1509379818611_424631_48288"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1509379826550_671118_48318" xmi:uuid="8b315b00-42ec-40d7-8fe5-836415bf9513" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733706_13852_14331"/>
