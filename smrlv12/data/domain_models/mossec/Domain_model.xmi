            <annotatedElement xmi:idref="_18_4_1_13110319_1510139521607_753323_32653"/>
            <body>Circularity: the parent shall not be the same as the child.</body>
          </ownedComment>
          <name>parentNotChild</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733746_600380_14436"/>
          <specification xmi:id="_18_4_1_13110319_1510139521607_24431_32654" xmi:uuid="b884d6e5-b503-4fda-98cd-56fd9e525000" xmi:type="uml:OpaqueExpression">
            <body>self.Parent &lt;&gt; self.Child</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
