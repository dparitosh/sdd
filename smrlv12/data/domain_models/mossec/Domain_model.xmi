        <generalization xmi:id="_18_4_1_13110319_1586176040125_224759_75283" xmi:uuid="9e40c4f8-0fe3-4169-bceb-271891171d87" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733786_981753_14561"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839734006_690514_15551" xmi:uuid="a1eb4e89-90c7-4dce-ab94-50eb2a35a0bc" xmi:type="uml:Generalization">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734626_758346_17377" xmi:uuid="2960fa09-d975-4b49-a40f-e8c62ac39830" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734006_690514_15551"/>
            <body>If a Breakdown is included in the architecture then the Breakdown is part of the "definition" of the architecture</body>
          </ownedComment>
          <general xmi:idref="_18_4_1_1b310459_1505839733886_566527_14820"/>
        </generalization>
        <generalization xmi:id="_18_4_1_13110319_1586176038161_154903_75282" xmi:uuid="d77d3ea5-d41b-4970-8035-6fdc69d5e59a" xmi:type="uml:Generalization">
