        <memberEnd xmi:idref="_18_4_1_1b310459_1508247133081_36255_41503"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1508247097416_852507_41474"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1508247133081_36255_41503" xmi:uuid="7eb7a214-ee2d-486c-81b0-1052a76c4767" xmi:type="uml:Property">
