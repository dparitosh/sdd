      <packagedElement xmi:id="_18_4_1_1b310459_1505839734486_398128_16612" xmi:uuid="9ed3dafd-ba17-49fd-b88e-273c3076788e" xmi:type="uml:Association">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734936_392056_18406" xmi:uuid="838b695d-2767-402f-9c53-906195c47229" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734486_398128_16612"/>
          <body>this is to enable a definition to get more info from inherisFrom.&#13; &#13; E.g. USB_spatial_and_info_and_power inheitsFrom USB_spatial_and_info&#13; &#13; The Interfacespecification of what spatial+inof is attached to the second, then only need to add the power bit of the specification to the first&#13; </body>
        </ownedComment>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734936_849079_18405"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734936_117894_18403"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1505839734936_849079_18405" xmi:uuid="9c40f5c5-f898-4ed5-80f0-aeb76652bb23" xmi:type="uml:Property">
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734486_192715_16611"/>
          <association xmi:idref="_18_4_1_1b310459_1505839734486_398128_16612"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733756_627640_14479" xmi:uuid="9f179658-6410-4a5f-a313-eeb1d0456c92" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734016_772177_15603" xmi:uuid="2359b1d7-af77-462e-9f9e-df6d0179d6d8" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733756_627640_14479"/>
          <body>An InterfaceConnectionRealizationAssociation is an association between an instance of InterfaceConnectionInstance and the InterfaceInstanceRealizationItem that realizes the connection. &lt;note&gt;Identification that the association is in the context of an Architecture is represented by ArchitectureElementInclusion.&lt;/note&gt; &lt;example&gt;This can be a ModelInstance representation of the connection. It can be used to compute results that are then used as boundary conditions on the two ports of the interface.&lt;/example&gt; &lt;example&gt;An AccessibleModelInstanceConstituent can be used when the item realizing the connection in internal to the model, for example a beam element inside Finite Element ModelInstance.&lt;/example&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt;</body>
        </ownedComment>
        <name>InterfaceConnectionRealizationAssociation</name>
        <generalization xmi:id="_18_4_1_1b310459_1509954975282_716701_32061" xmi:uuid="69e7ec9c-df27-4d65-9bcd-df17354a3e11" xmi:type="uml:Generalization">
