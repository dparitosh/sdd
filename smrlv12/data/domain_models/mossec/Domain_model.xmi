      <packagedElement xmi:id="_18_4_1_13110319_1588691231016_708070_145526" xmi:uuid="95f4eedb-ba8f-4024-81c6-3ed6a83754c9" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1588691262071_996341_145530" xmi:uuid="d635115e-465c-4cba-86db-43ca6bb6eba5" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1588691231016_708070_145526"/>
          <body>The Language is a proxy specifying a language.</body>
        </ownedComment>
        <name>Language</name>
        <ownedRule xmi:id="_18_4_1_13110319_1588691279620_784243_145535" xmi:uuid="41a9d9d9-9cbd-48c5-b5f2-907142731dd9" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590573486287_799475_67228" xmi:uuid="e2b80e7f-2a4f-4f25-b676-d1546c4cd065" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588691279620_784243_145535"/>
            <body>the language code shall be two characters long.</body>
          </ownedComment>
          <name>WR1</name>
          <specification xmi:id="_18_4_1_13110319_1588691279808_759946_145583" xmi:uuid="d60833b8-539a-4825-bea9-f496c5b07bbe" xmi:type="uml:OpaqueExpression">
            <body>2 &lt;= LanguageCode.size() and LanguageCode.size() &lt;= 3</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_18_4_1_13110319_1588691279620_527208_145534" xmi:uuid="49e037ed-a05d-4794-9aa3-dde45f24350d" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590573460608_441116_67227" xmi:uuid="3c88cf37-f19c-4b0e-9db0-35c6b4cd19ba" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588691279620_527208_145534"/>
            <body>the combination of LanguageCode and CountryCode shall be unique.</body>
          </ownedComment>
          <name>UR1</name>
          <specification xmi:id="_18_4_1_13110319_1588691279808_429016_145582" xmi:uuid="8061c193-1ba1-445c-a662-0e9acfc87517" xmi:type="uml:OpaqueExpression">
            <body> Language::allInstances()-&gt;isUnique(Sequence{LanguageCode, CountryCode})</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <ownedAttribute xmi:id="_18_4_1_13110319_1588691279605_771964_145532" xmi:uuid="76fa9250-e06f-4dd7-b343-247f30812722" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1588691279808_623102_145575" xmi:uuid="a804e415-723b-476b-8efb-e463c5078b20" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588691279605_771964_145532"/>
            <body>the string that specifies the identifier of the Language in the either Alpha-2 code of ISO 639-1 or Alpha-3 bibliographic code of ISO 639-2 if no two-character code exists.</body>
          </ownedComment>
          <name>LanguageCode</name>
          <visibility>public</visibility>
          <type href="../../../DataTypes.xmi#STRING"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_13110319_1588691279605_871392_145533" xmi:uuid="bc047360-1212-4260-b73c-1485643b9555" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1588691279808_325914_145579" xmi:uuid="df22d9e0-204e-4780-9f94-6dc3467522c0" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1588691279605_871392_145533"/>
            <body> the string that specifies the identifier of the country according to the alpha-2 code of ISO 3166-1. The value of this attribute need not be specified.</body>
          </ownedComment>
          <name>CountryCode</name>
          <visibility>public</visibility>
          <type href="../../../DataTypes.xmi#STRING"/>
          <lowerValue xmi:id="_18_4_1_13110319_1588691279808_576646_145580" xmi:uuid="d25b4105-8694-45c0-9259-c2ac4bcfb2a6" xmi:type="uml:LiteralInteger"/>
          <aggregation>composite</aggregation>
        </ownedAttribute>
