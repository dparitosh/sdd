      <packagedElement xmi:id="_18_4_1_1b310459_1505839733534_949088_14165" xmi:uuid="b5b4ba47-a972-4830-b3ca-b034e3367dde" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1552424027265_325010_48580" xmi:uuid="53e2edf0-3b5e-46db-880d-1d2b0ddb3150" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509537520576_144694_53573"/>
          <annotatedElement href="../../../Core_model/RequirementManagement/RequirementManagement.xmi#_18_4_1_8e001ed_1504193508191_160453_26032"/>
          <body>Do not need to map the "VerifiedBy" because it is the reverse.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733916_432792_15046" xmi:uuid="7e842a13-0991-426c-9108-51a035546906" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733534_949088_14165"/>
          <body>A Verification is a relationship linking the RequirementShouldBeSatisfied to the expected or provided evidence that the Requirement is satisfied. &lt;note&gt;The intended usage is initially it has a Status of "to be verified" and is used to identify ModelInstances needed to perform the verification. When the ResultsDocuments for the ModelInstance are available the Status is updated.&#13; The choices for Status are the enumeration VerificationStatusEnum.&lt;/note&gt;</body>
        </ownedComment>
        <name>Verification</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590669055572_707305_73799" xmi:uuid="9f18634c-3e3c-4893-a242-02061ce6797e" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590669055576_210136_73801" xmi:uuid="16cbda75-8b70-4415-b35d-2bc801275f47" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590669055572_707305_73799"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>StatusConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733916_936964_15047"/>
          <specification xmi:id="_18_4_1_13110319_1590669055576_821403_73800" xmi:uuid="c8e7014e-817b-47d7-9155-6b6e440bdb21" xmi:type="uml:OpaqueExpression">
            <body>Status.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#c80c5b11-079b-0136-768b-00ff90f87e13')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733906_546654_15043" xmi:uuid="1d21ba07-f31f-4e43-84bd-8a24ce0d0719" xmi:type="uml:Generalization">
