      <packagedElement xmi:id="_18_4_1_1b310459_1509701736341_950128_40479" xmi:uuid="9d876b90-ffa7-47f4-8fb3-e143d12de139" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_1b310459_1509701736341_73856_40480"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1509701670135_381833_40435"/>
        <ownedEnd xmi:id="_18_4_1_1b310459_1509701736341_73856_40480" xmi:uuid="207edab6-3ea4-4e33-a7fe-59ec622e6220" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733816_5890_14651"/>
          <association xmi:idref="_18_4_1_1b310459_1509701736341_950128_40479"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733816_5890_14651" xmi:uuid="9dbac8c3-f284-4715-afad-093b74a305e8" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576756972285_252609_67239" xmi:uuid="49c45881-d248-4540-8011-22770e06be82" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508498129767_587368_47501"/>
          <body>distribution value relationship UUID from DistributionValueInstance.Value subclassOf core_v1#individual part view relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1590663532447_171347_67931" xmi:uuid="e95eaceb-ffaa-4df3-9d7e-0115284d1083" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734076_334256_15805"/>
          <body>distribution value instance NamedIndividuals: aleatory uncertainty; epistemic uncertainty; random uncertainty.</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734076_186891_15803" xmi:uuid="fb88a487-3df4-404f-b49c-f683a6759ff8" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733816_5890_14651"/>
          <body>A DistributionValueInstance is a value with traceability that is a distribution rather than a single value.&#13; &lt;example&gt;Typical uses of DistributionValueInstance are for specifying likelihood or uncertainty distributions.&lt;/example&gt; &lt;note&gt;It is a type of ValueInstanceObject therefore, it may have a ValueOf reference to the item the value represents and may be IsExtractedFrom from a ModelInstance that was used to compute the distribution. A ModelInstance may be used to compute both a KeyValueInstance and the DistributionValueInstance that is a ValueOf that KeyValueInstance.&lt;/note&gt;&#13; &lt;note&gt;A distribution value may be a user input value rather than computed with a method (the more common occurrence) when it is subjective of a value from experience.&lt;/note&gt; &#13; &lt;note&gt;If rationale is needed, then Justifications may be added where the DistributionValueInstance is the thing being justified.&lt;/note&gt; &lt;note&gt;It may be evolved from KeyValueInstance (where the evolution may be from a known single value to a distribution value) or a DistributionValueInstance .&lt;/note&gt; &lt;note&gt;Identification that it used as an input to a ModelInstance is represented by ModelInstanceIsDerivedFrom.&lt;/note&gt; &lt;note&gt;It IsAnInstanceOf a DistributionValueType that is the definition.&lt;/note&gt; &lt;note&gt;It is assumed that the Person or Organization references ExecutorOf, SynchronizerOf and WatchersOf of the references IsExtractedFrom also apply. If the IsExtractedFrom reference is an AccessibleModelIInstanceConstituent, then the ModelInstance for which it is one of the Constituents is used. If the IsExtractedFrom is not specified, then the BelongsTo AssociativeModelNetwork is used.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;It is a type of ProgrammeObject therefore, it may have Approvals, Assumptions, Justifications, Contracts and SecurityTrust information.&lt;/note&gt; &lt;note&gt;RequirementShouldBeSatisfied is used to indicate that it should satisfy a Requirement.&lt;/note&gt; &lt;note&gt;Identification that it is evidence needed to verify that something satisfies the Requirement is represented by Verification.&lt;/note&gt;</body>
        </ownedComment>
        <name>DistributionValueInstance</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590663435761_292208_67914" xmi:uuid="e1c796d4-9886-45d6-bb14-918eec37edcb" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590663435767_746240_67916" xmi:uuid="34fb085c-3f59-4862-a122-4ecb1181b1f4" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590663435761_292208_67914"/>
            <body>values shall be subClassof the reference data class.</body>
          </ownedComment>
          <name>TypeConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839734076_334256_15805"/>
          <specification xmi:id="_18_4_1_13110319_1590663435765_835793_67915" xmi:uuid="7d05e3df-ff48-4e90-8fc2-94090eb3a2cb" xmi:type="uml:OpaqueExpression">
            <body>Type.mustBeSubClassOf('http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#9dbac8c3-f284-4715-afad-093b74a305e8')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733966_286846_15360" xmi:uuid="3d216cc4-2fe5-4add-8134-1f62a2c1da2d" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733706_13852_14331"/>
        </generalization>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734076_159188_15804" xmi:uuid="9431f112-59de-4e33-b3ec-976d79f5e658" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734656_423721_17603" xmi:uuid="73e8de41-721a-48c0-bbd1-05c7dab72cde" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734076_159188_15804"/>
            <body>the distribution that is the value. The value of this attribute need not be specified. &lt;note&gt;It need not be specified because early in the life-cycle the value is unknown and is planned to be calculated.&lt;/note&gt;</body>
          </ownedComment>
          <name>Value</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733806_578798_14622"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734656_509587_17604" xmi:uuid="d82de32d-f3d2-4365-8712-b914b1862b39" xmi:type="uml:LiteralInteger"/>
          <aggregation>composite</aggregation>
          <association xmi:idref="_18_4_1_1b310459_1505839733816_315068_14655"/>
        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734076_334256_15805" xmi:uuid="a1ec4353-6e58-48c2-a82a-41e026c85fb7" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734656_476354_17606" xmi:uuid="7c3ff390-eb06-411e-a939-75cdb73e3b60" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734076_334256_15805"/>
            <body>the string that indicates whether it is an Epistemic, Random or Aleatoric distribution. The value is restricted by an enumeration using reference data.</body>
          </ownedComment>
