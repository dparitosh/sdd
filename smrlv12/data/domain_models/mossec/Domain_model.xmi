      <packagedElement xmi:id="_18_4_1_1b310459_1505839733534_120594_14163" xmi:uuid="2b75ba89-0af1-41a5-9047-dd4a49527b84" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733906_941663_15033" xmi:uuid="75f969eb-389c-4a16-a033-b1d71c575ec3" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733534_120594_14163"/>
          <body>A RequirementRelationship is a relationship between requirements. &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of relationship.&lt;/note&gt; &lt;example&gt;ClassifiedAs may be used to distinguish between a collection, contradiction, tracing or decomposition relationships.&lt;/example&gt; &lt;note&gt;If the relationship is directional, it is implied that the direction is from the object referenced by the "From" property and to the object referenced by the "To" property.&lt;/note&gt; &lt;example&gt;A decomposition relationship, the "From" is the parent and the "To" is the child.&lt;/example&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1585731286203_240022_72737" xmi:uuid="8a9c35a5-82ee-4da8-8a60-7ed797bab40e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1585731161497_54675_72720"/>
          <body>core_v1#requirement View relationship</body>
        </ownedComment>
        <name>RequirementRelationship</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510151413243_289371_35779" xmi:uuid="b29e21fd-75c9-4640-a3f0-5a7cb5706da5" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513012747484_9539_36656" xmi:uuid="a6444c74-80ea-43b5-ba4d-d7500c72f619" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510151413243_289371_35779"/>
            <body>Circularity. The RequirementRelationship From shall be different from the To.</body>
          </ownedComment>
          <name>FromNotTo</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733534_120594_14163"/>
          <specification xmi:id="_18_4_1_13110319_1510151413243_421929_35780" xmi:uuid="853ce5e5-dec2-4bbf-81fe-88c9ccdce94d" xmi:type="uml:OpaqueExpression">
            <body>self.From &lt;&gt; self.To</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_363219_14852" xmi:uuid="1320a2b8-6664-4640-86a7-a9fa8306d192" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_59641_14064"/>
        </generalization>
