    <packagedElement xmi:id="_18_4_1_1b310459_1505839733474_802605_14053" xmi:uuid="8439885f-49fb-4cca-9944-00130880bd4d" xmi:type="uml:Package">
      <ownedComment xmi:id="_18_4_1_1b310459_1512658882235_58150_32851" xmi:uuid="6f49e743-2d5a-4c3a-97ad-657888f57809" xmi:type="uml:Comment">
        <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733474_802605_14053"/>
        <body>This capability enables the representation of values that are distributions and therefore, need more than a single value for their definition. These use other capabilities to provide the context and traceability for the distributions in a collaborative context. The Figure below provides an overview of this capability. &lt;figuresysml&gt;&lt;id&gt;_18_4_1_1b310459_1505839733816_696741_14659&lt;/id&gt;Overview of the Distribution and Uncertainty capability&lt;/figuresysml&gt;</body>
      </ownedComment>
      <name>DistributionUncertainty</name>
      <packagedElement xmi:id="_18_4_1_1b310459_1505839733816_33137_14654" xmi:uuid="02851be1-e194-445c-855b-fc007e7510cf" xmi:type="uml:Association">
