        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839733926_524988_15137" xmi:uuid="e812979d-98f9-4817-932f-0317e5ecd291" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_13110319_1513008919212_462278_35402" xmi:uuid="fd67c99c-0a5d-43cd-a157-ec8036f314dc" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733926_524988_15137"/>
            <body>the items that are part of the ModelType but are accessible. They are part of the ModelType, and shall not be shared with any other ModelType. The value of this attribute need not be specified. &lt;example&gt;A named surface, or a set of FE nodes following a numbering convention.&lt;/example&gt;</body>
          </ownedComment>
          <name>Constituents</name>
          <visibility>public</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839733666_653781_14228"/>
          <lowerValue xmi:id="_18_4_1_1b310459_1505839734616_291855_17152" xmi:uuid="31c145cf-6dae-4885-aeb7-1fbafe2afb65" xmi:type="uml:LiteralInteger"/>
