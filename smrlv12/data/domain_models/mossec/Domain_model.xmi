      <packagedElement xmi:id="_18_4_1_13110319_1552416569403_572197_41821" xmi:uuid="0a031161-8f62-4233-bcf9-19c8172ce640" xmi:type="uml:Association">
        <memberEnd xmi:idref="_18_4_1_13110319_1552416569404_9626_41822"/>
        <memberEnd xmi:idref="_18_4_1_13110319_1552416541987_782594_41796"/>
        <ownedEnd xmi:id="_18_4_1_13110319_1552416569404_9626_41822" xmi:uuid="00bde88e-9a6f-47d5-9aad-a7e7feda925f" xmi:type="uml:Property">
          <visibility>private</visibility>
          <type xmi:idref="_18_4_1_1b310459_1505839734406_995789_16448"/>
          <association xmi:idref="_18_4_1_13110319_1552416569403_572197_41821"/>
