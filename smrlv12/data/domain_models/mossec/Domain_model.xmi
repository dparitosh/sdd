        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734886_450132_18300" xmi:uuid="da363b58-fd66-4407-9b64-593f1049868d" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1549365423445_882434_40152" xmi:uuid="c5dfeb66-619b-4f48-a3e0-305523144c28" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734886_450132_18300"/>
