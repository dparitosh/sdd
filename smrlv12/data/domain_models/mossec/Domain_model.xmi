        </ownedComment>
        <name>PortTypeItem</name>
        <isAbstract>true</isAbstract>
        <ownedAttribute xmi:id="_18_4_1_13110319_1562660212662_439457_50554" xmi:uuid="b689abad-a3ad-4009-9cde-c64ab71f48fe" xmi:type="uml:Port">
          <name>portTypeItem</name>
