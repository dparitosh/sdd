      <packagedElement xmi:id="_18_4_1_1b310459_1505839733786_640623_14560" xmi:uuid="3bb0d8db-278d-4325-bb49-544f6a76f3a2" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_13110319_1568708532226_957801_48857" xmi:uuid="59b3e48e-d6b0-4f6e-9f8d-f8da076a5e92" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507559256948_651988_41900"/>
          <body>prefLabel=planned aprover subClassOf=core_v1:approving party</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734046_588970_15726" xmi:uuid="62b31a0a-993d-4783-a1be-c98b5d1bb902" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733786_640623_14560"/>
          <body>An Approval is a formal record that requests confirmation, or confirms, that something fulfils agreed criteria. It has properties for the PlannedApprover and ActualApprover, and a status to declare if it is planned, or if it has passed or failed the approval. &#13; &lt;example&gt;A status of "planned" implies that the PlannedApprover has been, or will be, asked to approve the Approval. The PlannedApprover may then decide to delegate to someone else, who is then recorded as the ActualApprover when they change the status. A status of "passed" implies the ActualApprover has approved the Approval. A status of "failed" implies the ActualApprover has not approved the Approval.&lt;/example&gt; Multiple Approvals should be used where a record is needed for the Approval Status from each approver.&#13; Approvals may have rationale documents. &lt;example&gt;Documents can be used for recording physical signatures, or for explaining rationale for failed or passing an approval where a Justification is not used.&lt;/example&gt; &lt;note&gt;All objects that are specializations of ProgrammeObject may have approvals.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1568708575793_189137_48877" xmi:uuid="8586ccda-e904-4eb8-8038-d553f9d458ee" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1509532446525_816688_41835"/>
          <body>preLabel=approval rationale document assignment subClassOf=core_v1:assignment object:document assignment core_rd_v1:additional information document assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1568708479626_334629_48835" xmi:uuid="ab7a015d-745f-4033-a972-fba6b4f1d7cb" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1507559314197_936076_41910"/>
          <body>prefLabel= actual approver assignment subClassOf=core_v1#actual person organization assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1586160941442_512287_67016" xmi:uuid="cf1835e6-2f16-4e06-89e3-9b8998e502ee" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1586160767938_36303_66947"/>
          <body>prefLabel= actual approver date assignment subClassOf=core_v1:actual date assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1586161326610_713271_67513" xmi:uuid="dddf4d3f-deee-49ad-acf0-b400d013b11b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1586161238502_169322_67499"/>
          <body>prefLabel=planned approval date assignment subClassOf=core_v1:planned date assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1568708675242_110150_48905" xmi:uuid="e5e2456d-fd79-478c-a00b-5bb1f30dc86d" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734046_495125_15729"/>
          <body>rdf:type= core_v1:state:state of approval prefLabel=approved prefLabel=approved with comments prefLabel=in progress prefLabel=not approved</body>
        </ownedComment>
        <name>Approval</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590585481321_617546_95236" xmi:uuid="cef2c3b4-2bce-458c-8bc5-ef153aeec7d8" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590585481325_571818_95238" xmi:uuid="707fb6f3-dae4-4335-b808-146e48b62228" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590585481321_617546_95236"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>StatusConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839734046_495125_15729"/>
          <specification xmi:id="_18_4_1_13110319_1590585481325_814342_95237" xmi:uuid="3e71bd3f-6706-450e-990f-12aedc7d7191" xmi:type="uml:OpaqueExpression">
            <body>Status.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#c7fe0ce1-079b-0136-760a-00ff90f87e13')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839734046_87750_15725" xmi:uuid="075d2b34-f898-44ff-b949-d7df1eb23e83" xmi:type="uml:Generalization">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734646_273471_17538" xmi:uuid="123cb51c-8b66-44c2-99ba-64a9b17d2466" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734046_87750_15725"/>
            <body>Justification evidence may be the fact that something else has been approved.</body>
          </ownedComment>
          <general xmi:idref="_18_4_1_1b310459_1505839733876_962512_14800"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_134786_14872" xmi:uuid="c32b7dd2-bf38-48bc-a436-07146ff2b3d3" xmi:type="uml:Generalization">
