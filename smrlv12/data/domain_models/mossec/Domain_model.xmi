          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734446_749563_16543"/>
          <body>This points to the method(s) that is planned to be used.</body>
        </ownedComment>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734916_837303_18379"/>
        <memberEnd xmi:idref="_18_4_1_1b310459_1505839734666_600845_17682"/>
