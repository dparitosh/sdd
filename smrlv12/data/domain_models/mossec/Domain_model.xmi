      <packagedElement xmi:id="_18_4_1_1b310459_1505839733826_4008_14685" xmi:uuid="cf229b10-17bd-4a33-aa9f-a32447ce2824" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839734096_70864_15854" xmi:uuid="759d7b25-f4a9-463a-b917-46bd08d41a9b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733826_4008_14685"/>
          <body>A ContractRelationship is a relationship between Contracts. &lt;note&gt;It is a type of ManagedObject therefore, it may have a ClassifiedAs string to define the type of relationship.&lt;/note&gt; &lt;example&gt;A contract for a specific PlannedActivity or collaborative Study may reference a contract for a generic non-disclosure-agreement.&lt;/example&gt;</body>
        </ownedComment>
        <name>ContractRelationship</name>
        <ownedRule xmi:id="_18_4_1_13110319_1510151673718_987462_36226" xmi:uuid="a641f81f-2bce-41b6-93de-77737a5a14ab" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_1b310459_1512736083527_810914_34781" xmi:uuid="d50bc6c1-845f-4fec-8062-7dd5c5aaee2e" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1510151673718_987462_36226"/>
            <body>Circularity: The From shall be different to the To.</body>
          </ownedComment>
          <name>FromNotTo</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733826_4008_14685"/>
          <specification xmi:id="_18_4_1_13110319_1510151673718_789642_36227" xmi:uuid="f8fc8fb2-f11f-447a-bb40-9489d7f842a3" xmi:type="uml:OpaqueExpression">
            <body>self.From &lt;&gt; self.To</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_20913_14912" xmi:uuid="a7a4aa1b-d1d6-428a-beca-e78190266aa7" xmi:type="uml:Generalization">
