        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734886_900242_18301" xmi:uuid="3e8ae130-aa74-48ff-a7ae-4608a3c0bd47" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839735186_487981_19411" xmi:uuid="07c7f624-bc8d-42ab-b364-60dc54d61126" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734886_900242_18301"/>
            <body>the reference to the method (or ApplicableMethod) to which the input is assigned.</body>
          </ownedComment>
