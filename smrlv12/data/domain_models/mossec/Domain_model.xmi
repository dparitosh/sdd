      <packagedElement xmi:id="_18_4_1_1b310459_1505839733514_262303_14128" xmi:uuid="df814155-be34-493e-ba35-ed82e56fe61b" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576668211334_779761_57809" xmi:uuid="8da1653e-e2a7-4e48-a3d7-3e9ef540a4a6" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1506592683803_42730_30572"/>
          <body>core_rd_v1#hierarchical organization relationship</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733906_874296_14986" xmi:uuid="e49891f3-4c3d-4850-92db-f0a89bca1b5e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733514_262303_14128"/>
          <body>An Organization is a group of people involved in a specific business process. Organizations may be structured using the InOrganization property. &lt;note&gt;It is a specialization of PersonOrOrganizationItem therefore, it may be used everywhere that PersonOrOrganizationItem is specified.&lt;/note&gt; &lt;example&gt;Companies, teams, technical institutions are all examples of organization.&lt;/example&gt; &lt;example&gt;Examples of properties on organizations are for an "AirlineXYZ" organization that are having a "type of fleet" property set to "long range". &lt;/example&gt;</body>
        </ownedComment>
        <name>Organization</name>
        <ownedRule xmi:id="_18_4_1_1b310459_1509471420798_245927_48286" xmi:uuid="4da02463-d588-4bea-abb3-54c191b71c5b" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1513011060614_551636_36381" xmi:uuid="6826351a-4826-40b5-85f1-10d5bee79b21" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1509471420798_245927_48286"/>
            <body>Circularity. An organization shall not be in itself.</body>
          </ownedComment>
          <name>InOrgCircularity</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733514_262303_14128"/>
          <specification xmi:id="_18_4_1_1b310459_1509471420798_14802_48287" xmi:uuid="6d3cefb5-1aa4-40fa-99f9-c26325beb4a9" xmi:type="uml:OpaqueExpression">
            <body>self.InOrganization-&gt;excludes(self)</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_336012_14889" xmi:uuid="051e6c0e-a3e8-4e39-9113-af1bddea5e9d" xmi:type="uml:Generalization">
