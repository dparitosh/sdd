      <packagedElement xmi:id="_18_4_1_1b310459_1505839733534_908768_14164" xmi:uuid="bf499813-d519-4b26-8f8d-a7bf23f97f4d" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733906_524434_15038" xmi:uuid="59d84976-3d46-47c5-9672-6cb8765af10b" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733534_908768_14164"/>
          <body>A RequirementShouldBeSatisfied is a relationship between a Requirement and the objects that should satisfy that requirement. A Requirement may have many objects that should satisfy it, and an object may satisfy many Requirements. It may have many associated Verification objects that specify the expected or provided evidence that the Requirement is satisfied.&#13; &lt;note&gt;The RequirementShouldBeSatisfied may be included in an architecture which identifies the architecture as the context for satisfying requirement.&lt;/note&gt; &lt;example&gt;A functional requirement to provide "x" Newtons of lift is identified that is should be satisfied by a wing system and the evidence provided by an aerodynamics analysis ModelInstance.&lt;/example&gt; &lt;example&gt;A building certification Requirement that "all fire doors shall offer 30 minutes of protection" should be satisfied by all fire-door in the Breakdown of a building. The Evidence that it has satisfied it is shown by the a ModelInstance that uses an approved method that simulates a physical test.&lt;/example&gt;</body>
        </ownedComment>
        <name>RequirementShouldBeSatisfied</name>
        <generalization xmi:id="_18_4_1_1b310459_1505839733906_67197_15037" xmi:uuid="100fa610-c08e-4f92-b16b-15f5a60354c3" xmi:type="uml:Generalization">
          <ownedComment xmi:id="_18_4_1_1b310459_1505839734606_866870_17090" xmi:uuid="be8bbd64-4b44-4bdc-b5a3-a6d8de87881d" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733906_67197_15037"/>
          </ownedComment>
          <general xmi:idref="_18_4_1_1b310459_1505839733886_566527_14820"/>
        </generalization>
        <generalization xmi:id="_18_4_1_1b310459_1505839733886_73171_14916" xmi:uuid="3433d65a-9187-441a-a198-e1ea44571868" xmi:type="uml:Generalization">
          <general xmi:idref="_18_4_1_1b310459_1505839733484_462970_14068"/>
        </generalization>
