      <packagedElement xmi:id="_18_4_1_1b310459_1505839733696_580586_14327" xmi:uuid="47ffe698-99ff-40b2-8f0e-25c6596719f4" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1576680349420_295018_64687" xmi:uuid="3d7542aa-133c-438d-9b15-99c426665ded" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508330976766_513743_45463"/>
          <body>activity input managed subclass of: core_rd_v1#activity input Note this is the same reference data used for the Study manages Activity Assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1582113877325_950907_69707" xmi:uuid="400acde9-a69e-4fdc-8e1b-3fa630d57506" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508330143424_395899_45085"/>
          <body>associative model network subclass of: core_v1#collection</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733956_368220_15314" xmi:uuid="69d78c26-dc44-4f2c-a9ed-1a056674b82a" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733696_580586_14327"/>
          <body>An AssociativeModelNetwork is a container that collects the ModelInstances and KeyValueInstances that together comprise a set of "results" for the Study. &#13; &lt;note&gt;It is ManagedBy a Study, and may be used as an Input to another Study.&lt;/note&gt; &lt;note&gt;It has a Status. The value of the Status can be used to apply business rules to control the changes in Status for each ModelInstance and KeyValueInstance that BelongsTo the AssociativeModelNetwork.&lt;/note&gt; &lt;note&gt;The associativity between instances of ModelInstances and KeyValueInstances is represented by ModelInstanceIsDerivedFrom.&lt;/note&gt; &lt;note&gt;A reference to Person or Organization shall be specified for the roles of ExecutorOf and SynchronizerOf. References to Person or Organization may be specified for the role of WatchersOf.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt;</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1590585976502_381426_96145" xmi:uuid="7378861f-36cb-4ad6-96ce-2c52ad70f0de" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733956_955664_15319"/>
          <body>state of associative model network Named Individuals: associative model network cancelled, associative model network complete, associative model network directed, associative model network failed imported, associative model network paused, associative model network planned imported, associative model network proposed, associative model network started, associative model network unknown. </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576660271487_665948_55921" xmi:uuid="8e6f7a4a-4fdd-4758-8435-7872d03a3aea" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508337790966_479327_48213"/>
          <body>actual synchronizer assignment subclass of: core_rd_v1#actual person organization assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_13110319_1585644229751_888623_72217" xmi:uuid="9e4369a2-7086-4224-b884-cd9a763cda71" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508330855013_809114_45269"/>
          <body>The study is the main object, therefore the AMN is assigned to the study. The study will encapsulate the CollectionAssignment object</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576660055489_613844_55888" xmi:uuid="b4ba6de9-bd90-4457-9631-fe4237ff8b05" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508337571607_430066_47898"/>
          <body>actual executor assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576495758910_926536_68942" xmi:uuid="ebc62667-03ba-481c-bc06-fa85ce069fd9" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_13110319_1508322173275_109298_38624"/>
          <body>actual watcher assignment sub class of: actual observer assignment</body>
        </ownedComment>
        <name>AssociativeModelNetwork</name>
        <ownedRule xmi:id="_18_4_1_13110319_1590585862700_869140_95995" xmi:uuid="ce25e8d1-de03-4f25-841c-dc36541f502e" xmi:type="uml:Constraint">
          <ownedComment xmi:id="_18_4_1_13110319_1590585862704_981884_95997" xmi:uuid="ab7a4b36-41fa-4027-9786-a35ab9ebb634" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_13110319_1590585862700_869140_95995"/>
            <body>values shall be namedIndividual of the reference data class.</body>
          </ownedComment>
          <name>StatusConstraint</name>
          <constrainedElement xmi:idref="_18_4_1_1b310459_1505839733956_955664_15319"/>
          <specification xmi:id="_18_4_1_13110319_1590585862704_659821_95996" xmi:uuid="be795508-53eb-4e9c-a6bd-c6ad6eb7aca2" xmi:type="uml:OpaqueExpression">
            <body>Status.mustBeNamedIndividualOf('http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#e94786c0-167f-4848-a218-3d88c758bb3c')</body>
            <language>OCL2.0</language>
          </specification>
        </ownedRule>
