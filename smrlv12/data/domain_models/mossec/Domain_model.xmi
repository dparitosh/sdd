        </ownedAttribute>
        <ownedAttribute xmi:id="_18_4_1_1b310459_1505839734056_812790_15746" xmi:uuid="9bc85f6f-e37f-4679-a7ec-5f58eb2931d6" xmi:type="uml:Property">
          <ownedComment xmi:id="_18_4_1_1b310459_1512562903048_197127_33508" xmi:uuid="b6cb0cb3-ea3a-457c-b996-e5d2b7300bf6" xmi:type="uml:Comment">
            <annotatedElement xmi:idref="_18_4_1_1b310459_1505839734056_812790_15746"/>
            <body>the references to the item or items providing evidential support for the Justification. The value of this attribute need not be specified.</body>
          </ownedComment>
