      <packagedElement xmi:id="_18_4_1_1b310459_1505839733534_116015_14166" xmi:uuid="a9571729-9961-4488-818b-a320e6c068d1" xmi:type="uml:Class">
        <ownedComment xmi:id="_18_4_1_1b310459_1505839733916_995451_15055" xmi:uuid="0d093a34-2967-4fa1-8c3b-baab64cfdfac" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1505839733534_116015_14166"/>
          <body>RequirementObject is an abstract class from which entities inherit requirement-like properties. &lt;note&gt;Some entities need the same information as a requirement but are not a formal Requirement, and therefore, not be used for verification.&lt;/note&gt; &#13;&lt;note&gt;It is a type of VersionableObject therefore, it shall have at least one VersionIdentifiers property. This can be used to identify the version of the Requirement in a dedicated requirement management package.&lt;/note&gt; &lt;note&gt;It is a type of IdentifiableObject therefore, it shall have Identifiers and may have a Descriptions, Names, other management information from ManagedObject.&lt;/note&gt; &lt;note&gt;It is a type of ObjectWithPropertyValues therefore, it may have PropertyValues specific to the requirement.&lt;/note&gt; &lt;note&gt;It is a type of ProgrammeObject therefore, it may have Approvals, Assumptions, Justifications, Contracts and SecurityTrust information.&lt;/note&gt; </body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1576752866268_100904_62355" xmi:uuid="4563cd62-2a39-4955-a736-e70e6a9bd59c" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508250069551_319654_44290"/>
          <body>requirement definition document assignment sub class of core_rd_v1#description document assignment</body>
        </ownedComment>
        <ownedComment xmi:id="_18_4_1_1b310459_1508249200419_430714_43212" xmi:uuid="c459d44a-172a-4ff6-baca-b1b61ec3e82e" xmi:type="uml:Comment">
          <annotatedElement xmi:idref="_18_4_1_1b310459_1508247087156_428314_41455"/>
          <body>use properties as part of the definition rather than using PropertyValueAssignment</body>
        </ownedComment>
        <name>RequirementObject</name>
