        <dc:creator xml:lang="en">Judith Crockford, Airbus Operations Ltd</dc:creator>
        <dc:date>2020-01-08</dc:date>
        <dc:source>ISO 10303-243</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment>individual part version relationship in which the Relating IndividualPartVersion is an evolution of the Relating IndividualPartVersion</rdfs:comment>
        <owl:versionInfo>v1</owl:versionInfo>
        <skos:changeNote xml:lang="en">[2020-01-08] Judith Crockford, Airbus Operations Ltd: creation</skos:changeNote>
        <skos:note>The relationship is the similar to versioning but does not  imply a linear progression, instead the evolution allows a diverging and converging progression, so there may be more than one &quot;latest version&quot;.</skos:note>
        <skos:prefLabel>individual part version evolved from relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#7518e7ad-1ae6-4aa6-9aef-1df787ea19b3 -->

