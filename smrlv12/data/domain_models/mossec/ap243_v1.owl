    <!-- http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#6d989614-ce38-4a09-8e01-6a0ed78d9720 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#6d989614-ce38-4a09-8e01-6a0ed78d9720">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c284ede-a307-4818-8ef9-3c85376c3ee8"/>
        <dc:creator xml:lang="en">Judith Crockford, Airbus Operations Ltd</dc:creator>
        <dc:date>2020-01-08</dc:date>
        <dc:source>ISO 10303-243</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment>a relationship to other instances of collection that composed together make up the full collection.</rdfs:comment>
        <owl:versionInfo>v1</owl:versionInfo>
        <skos:changeNote xml:lang="en">[2020-01-08] Judith Crockford, Airbus Operations Ltd: creation</skos:changeNote>
        <skos:example>A team for one discipline may have several alternative collections of models that can be used to to generate the same results but with different fidelity computations. Another team may require a specific fidelity model as input to their template and so create a collection for their team that is composed of the other collection with the required fidelity.</skos:example>
        <skos:prefLabel>collaborative model template is composed of relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#6f26a6e6-5e37-4982-aba8-be0393944a47 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-243/tech/refdata/ap243_v1#6f26a6e6-5e37-4982-aba8-be0393944a47">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c284ede-a307-4818-8ef9-3c85376c3ee8"/>
        <dc:creator xml:lang="en">Judith Crockford, Airbus Operations Ltd</dc:creator>
        <dc:date>2020-01-08</dc:date>
        <dc:source>ISO 10303-243</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment>a collection version sequence relationship that indicates that one architecture is evolved from another architecture.</rdfs:comment>
        <owl:versionInfo>v1</owl:versionInfo>
        <skos:changeNote xml:lang="en">[2020-01-08] Judith Crockford, Airbus Operations Ltd: creation</skos:changeNote>
        <skos:note>This enables the tracking of a diverging and converging evolution tree alongside the linear evolutions implied by the architecture (collection) versions.</skos:note>
        <skos:prefLabel>architecture evolved from relationship</skos:prefLabel>
    </owl:Class>
    


