        <skos:changeNote xml:lang="en">[2020-01-08] Judith Crockford, Airbus Operations Ltd: creation</skos:changeNote>
        <skos:note>This may include analyis, design, design change, testing and amendment activities.</skos:note>
        <skos:prefLabel>study trade activity</skos:prefLabel>
    </owl:Class>
    


