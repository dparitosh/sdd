        <owl:imports rdf:resource="http://protege.stanford.edu/plugins/owl/dc/protege-dc.owl"/>
        <owl:imports rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:comment xml:lang="en">This ontology is an OWL representation of the classes derived from ISO 10303-4000.</rdfs:comment>
        <skos:note>ISO/TC 184/SC 4/WG12 N10920</skos:note>
        <owl:versionInfo>v1</owl:versionInfo>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/TR/skos-reference/"/>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:creator xml:lang="en">Phil Spiby</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:coverage xml:lang="en">The classifiable objects from the Core_model.</dc:coverage>
        <dc:language>en</dc:language>
        <dc:type>TS</dc:type>
    </owl:Ontology>
    


