    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing">
        <dc:creator>STEP Harmonization Team</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <owl:versionInfo>1</owl:versionInfo>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6260c30-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricRepresentationRelationship is a type of RepresentationRelationship that specifies an association between a ComposedGeometricModel and an item (specified by GeometricRepresentationSelect). A GeometricRepresentationRelationship is either a GeneralGeometricRepresentationRelationship, a GeometricRepresentationRelationshipWithCartesianTransformation, a GeometricRepresentationRelationshipWithPlacementTransformation or a GeometricRepresentationRelationshipWithSameCoordinateSpace.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric representation relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a031dc70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a031dc70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricRepresentationRelationshipWithCartesianTransformation is a type of GeometricRepresentationRelationship that specifies a CartesianTransformation between the two GeometricCoordinateSpaces of the referenced GeometricModels.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric representation relationship with cartesian transformation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a05da760-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a05da760-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricRepresentationRelationshipWithPlacementTransformation is a type of GeometricRepresentationRelationship that specifies a placement transformation by associating two AxisPlacements of the referenced GeometricModels onto each other.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric representation relationship with placement transformation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0791ea0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0791ea0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricRepresentationRelationshipWithSameCoordinateSpace is a type of GeometricRepresentationRelationship without a geometry transformation between the Related and the Relating GeometricModels.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric representation relationship with same coordinate space</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0a0cae0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0a0cae0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e16c4a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Hardcopy is a type of File that is the actual physical object representing a DocumentVersion. It could be a stack of paper consisting of one or more sheets, on which some product data is written, printed or plotted.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">hardcopy</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0bf538a-5690-4511-a4e8-b1a1eb6375da -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a0bf538a-5690-4511-a4e8-b1a1eb6375da">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Location is a place where an activity or event can occur, or where a product or resource can exist.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">location</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a187f29f-5cbd-4ff3-b1dc-bdd9f2ceb596 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a187f29f-5cbd-4ff3-b1dc-bdd9f2ceb596">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A JustificationRelationship is an association between two instances of Justification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">justification relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a1967580-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a1967580-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Identifier is a mechanism to provide the identifying name or code for the activity or product data.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">identifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a1e2c0c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a1e2c0c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IdentifierRelationship is a relationship between two Identifier objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">identifier relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2321940-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2321940-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualAssemblyRelationship is a relation between two IndividualPartView objects representing a view of the assembly. Both related objects shall share at least one ViewContext.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">individual assembly relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a236446d-6e48-41ab-b5a3-dcce1a4ee3a1 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a236446d-6e48-41ab-b5a3-dcce1a4ee3a1">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisAssignment is an assignment of an Analysis to an item (specified by AnalysisAssignmentSelect) being analyzed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a25ff3eb-4e00-4730-a576-3ed5f557a2a6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a25ff3eb-4e00-4730-a576-3ed5f557a2a6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GlobalPositionLocation is a type of Locator specified through the identification of location on Earth using the geographical coordinates. These coordinates refer to a world geodesic system.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">global position location</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2719b60-dbf3-48e7-be31-ebb8c09491de -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2719b60-dbf3-48e7-be31-ebb8c09491de">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceEvent is an abstract generalization of instances that represents an event or action that affects the balance or availability of a managed resource. A ResourceEvent is the role of a resource event is determined by which is defined by the classifiedAs property.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A resource event can be classified as &quot;Planned&quot; or &quot;Actual&quot;.</skos:example>
        <skos:note xml:lang="en">Only non-abstract specializations of the ResourceEvent can be instantiated.</skos:note>
        <skos:prefLabel xml:lang="en">resource event</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a28912e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a28912e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPart is the identification of an individual artefact that has been made or is planned to be made. It is a collector of data common to all versions of the IndividualPart.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The design of a personal computer is represented by a PartVersion.</skos:example>
        <skos:example xml:lang="en">The personal computer that has been ordered, allocated a serial number for manufacturing planning, but not yet manufactured, is represented by an IndividualPartVersion. An actual personal computer, also represented by an IndividualPartVersion, may be linked to the planed personal computer by an IndividualPartVersionRelationship object.</skos:example>
        <skos:example xml:lang="en">The personal computer with a serial number on a person&apos;s desk is represented by an IndividualPartVersion.</skos:example>
        <skos:note xml:lang="en">It is likely, but not essential, that the artefact, was or will be made from a part design. The part design will be represented by a PartVersion which will be related to the IndividualPart by PartToIndividualPartAssociation.</skos:note>
        <skos:note xml:lang="en">Many physical parts may be produced from a given design. A single Part may lead to many IndividualPart objects.</skos:note>
        <skos:note xml:lang="en">Versions (IndividualPartVersion) of IndividualPart are used to represent whether an individual artefact is planned to be made or has already been made.</skos:note>
        <skos:note xml:lang="en">Where physical parts are being represented, an IndividualPart represents the planned or actual physical realization of a part.</skos:note>
        <skos:prefLabel xml:lang="en">individual part</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2f25c00-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2f25c00-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartRelationship is a relationship between two IndividualPart objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">individual part relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3571140-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3571140-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartVersion is a version of an IndividualPart and acts as a collector of the views of this version.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The car on my drive is represented by an IndividualPart. The current configuration status of the car can be represented by an IndividualPartVersion related to that IndividualPart. If a safety modification is made to the car resulting in a new configuration status of the car, then this may be represented by a new IndividualPartVersion.</skos:example>
        <skos:prefLabel xml:lang="en">individual part version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3c3b5c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3c3b5c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartVersionRelationship is a relationship between two instances of IndividualPartVersion. Unless specified in a specialization of this object, this relationship does not involve inheritance of data between the two related objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">individual part version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a41f4340-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a41f4340-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartView is a characterization view of a version of an IndividualPart.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The IndividualPartView supports the representation of different views of an IndividualPart for different purposes. Multiple views of the same IndividualPart are represented by different instances of IndividualPartView for the same IndividualPartVersion.</skos:note>
        <skos:prefLabel xml:lang="en">individual part view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a4c532ef-e6ef-45eb-9fae-3e047c967cea -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a4c532ef-e6ef-45eb-9fae-3e047c967cea">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DecisionPoint is a type of StructuredTaskElement. It requires a decision that determines which further TaskElement is to be followed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The condition on which the decision is based optionally allows a further TaskElement to be invoked to provide the basis for the decision.</skos:note>
        <skos:prefLabel xml:lang="en">decision point</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a4d96b80-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a4d96b80-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartViewRelationship is a relation between IndividualPartView objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">individual part view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a53fa760-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a53fa760-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InformationRight is a definition of what may or may not be done with an item of information in the sense of legal rights and obligations.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Copyright is an InformationRight.</skos:example>
        <skos:example xml:lang="en">For the purposes of developing a new system, details of government furnished equipment may be made available to a specific project team. The team may copy and use the information internally, but may not pass it on, either to a third part, or to another team, and must destroy the information at the end of the contract.</skos:example>
        <skos:note xml:lang="en">The following additional data can be assigned to an InformationRight: InformationUsageRight.</skos:note>
        <skos:prefLabel xml:lang="en">information right</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a57f0907-bedc-466d-81b0-3a2da1066a52 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a57f0907-bedc-466d-81b0-3a2da1066a52">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskInvocation is a type of TaskElement. It is an instruction to perform another task.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A TaskElement calls a predefined task to perform an instrument calibration.</skos:example>
        <skos:prefLabel xml:lang="en">task invocation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5890c70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5890c70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InformationUsageRight is an application an InformationRight to a specific usage context.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">InformationUsageRight provides a mechanism for recording significant rights within a product database. The legal significance of the presence or absence of a right is outside the scope of this part of ISO 10303.</skos:note>
        <skos:note xml:lang="en">One view of the distinction between an InformationRight and an InformationUsageRight is that the InformationRight represents a standard clause in a contract, whereas an InformationUsageRight represents the fact that the clause is used in a specific contract.</skos:note>
        <skos:note xml:lang="en">The Approval of an InformationUsageRight carries the meaning that the right is granted to all information items in the relevant context, as opposed to the approval of an InformationUsageRightAssignment which is limited to specific items.</skos:note>
        <skos:note xml:lang="en">The context for the usage can be defined through the contract which defines the right, the organization that grants the right, the person or organization which is granted the right, and any dates such as the starting or ending dates for the right. The meaning of each association is identified through the roles of the assignments, and these are defined through reference data.</skos:note>
        <skos:note xml:lang="en">The following additional data can be assigned to an InformationUsageRight: Contract, DateTimeString, Document, DocumentVersion, DocumentDefinition, File, and InformationUsageRight.</skos:note>
        <skos:prefLabel xml:lang="en">information usage right</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5bced84-19bd-411a-ab9e-5d1abc81a290 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5bced84-19bd-411a-ab9e-5d1abc81a290">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceDefinitionFor is a relationship between an InterfaceSpecificationView and an item (specified by InterfaceDefinitionForSelect) that conforms to the specification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The infrared transmitter in a television remote control conforms to the specification that has the identifier 2345/XYZ/001. An instance of the InterfaceDefinitionFor entity data type is necessary to identify this relationship.</skos:example>
        <skos:prefLabel xml:lang="en">interface definition for</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5de7f70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a5de7f70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InformationUsageRightAssignment is an assignment of a specific usage right to a set of items (specified by InformationUsageRightAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">If an Approval is applied to this entity, it carries the meaning that the specific set of items is approved for the given usage. This approval generally indicates that the approval is exceptional and there is an implication that the set of entities should not be changed once the approval is given.</skos:note>
        <skos:prefLabel xml:lang="en">information usage right assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a644bb50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a644bb50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InformationUsageRightRelationship is a relationship of one InformationUsageRight to another.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Where one InformationUsageRight supersedes another, then the original right is pointed to by the relating attribute, its replacement by the related attribute, and the relationType attribute takes the value supersedes.</skos:example>
        <skos:note xml:lang="en">The following additional data can be assigned to an InformationUsageRightRelationship: Effectivity, and InformationUsageRight.</skos:note>
        <skos:prefLabel xml:lang="en">information usage right relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a6e36c50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a6e36c50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InZone is an association between a BreakdownElementView that represents a zone and an item (specified in InZoneSelect) that exists within this zone.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">in zone</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a8535000-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a8535000-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LifeCycleStage is a general stage in the product life cycle to which the concerned items belong.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">life cycle stage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a96471e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a96471e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LotEffectivity is a type of Effectivity for which the domain of applicability is defined as a given batch of items.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">lot effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aaa1d3e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aaa1d3e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Market is a representation of a marketing segment for products.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">market</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aafe1ab1-3865-433a-b81d-475fefd1586f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aafe1ab1-3865-433a-b81d-475fefd1586f">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateTransition represents a transition between two State, identified respectively as a start and an end.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state transition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ab417830-0eae-45bb-9b47-efb2d6d99faa -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ab417830-0eae-45bb-9b47-efb2d6d99faa">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">an Acknowledgement is a response requested for receipt of an Envelope.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">acknowledgement</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ac6001f4-ce24-4918-b379-cb4a37fc7621 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ac6001f4-ce24-4918-b379-cb4a37fc7621">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElementStateRelationship is an association between a state (specified by StateOrStateDefinitionSelect) and a TaskElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the entity is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskElementStateRelationship. Candidate meanings include: Assumed starting state;Required starting state.</skos:note>
        <skos:prefLabel xml:lang="en">task element state relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ac6d1e00-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ac6d1e00-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A MeasureQualification is a means to provide information about measurements in which there is an associated uncertainty. The uncertainty may be specified as precision, qualitative uncertainty, or expanded uncertainty, and the type of the related datum shall be included. The uncertainty is defined in clause 2 of &apos;The Guide to the Expression of Uncertainty in Measurement&apos;.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">measure qualification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#acb6e843-005f-4961-aabe-ef0e74ef9769 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#acb6e843-005f-4961-aabe-ef0e74ef9769">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodStateRelationship is a relationship between a state (specified by StateOrStateDefinitionSelect) and a TaskMethodVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the entity is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskMethodStateRelationship. Candidate meanings include: Assumed starting state;Required starting state.</skos:note>
        <skos:prefLabel xml:lang="en">task method state relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adbb48e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adbb48e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87863f90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A NextAssemblyOccurrenceUsage is a type of AssemblyOccurrenceRelationship that is a relationship where the attribute Related specifies an occurrence of a constituent of an assembly and the attribute Relating specifies a view of the immediate parent assembly of the constituent.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The assembly carburettor may be assembled from single parts. The power train assembly is assembled from other assemblies.</skos:example>
        <skos:note xml:lang="en">A constituent may be a single part or an assembly.</skos:note>
        <skos:prefLabel xml:lang="en">next assembly occurrence usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adc16360-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adc16360-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88035ed0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A NextAssemblyViewUsage is a type of AssemblyViewRelationship that is a relationship where the attribute Related specifies a view of an assembly and the attribute Relating specifies a view of the immediate parent assembly of the constituent.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">next assembly view usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#add3b2e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#add3b2e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A NumericalContext is a context in which the number of significant digits and uncertainties may be defined. These number of significant digits and uncertainties apply to the NumericalValue objects that are used in that context.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">numerical context</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adf0ca52-98c1-4450-9a8b-67fe66e6adeb -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adf0ca52-98c1-4450-9a8b-67fe66e6adeb">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionAssignment is an assignment of a StateDefinition to an item (specified by StateDefinitionAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adfff300-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adfff300-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d75d6570-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A NumericalValue is a type of ValueWithUnit representing a quantity expressed with a numerical value and a unit.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">numerical value</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ae1e7780-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ae1e7780-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Occurrence is an occurrence of an object in a product structure that is defined either by a PartView, another Occurrence, or as a ProductConfiguration.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In the case of a car, the Item &apos;wheel&apos; is defined once. Its PartVersion carries all the information necessary to define the wheel (such as its shape) independent of its usage. Additionally, there are 5 Occurrence objects for this wheel since there are 5 equal wheels used in a car: Front-left, front-right, rear-left, rear-right, and spare wheel. Each of these instances may carry additional information such as placement or function. Each Occurrence is a DefinitionBasedOccurrence, or a SpecifiedOccurrence.</skos:example>
        <skos:prefLabel xml:lang="en">occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aeba1b40-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aeba1b40-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An OccurrenceRelationship is a relationship between two Occurrence objects. Predefined semantics are provided by the two subtypes ReplacedUsageRelationship and SameTimeMachiningRelationship.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">occurrence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#af699520-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#af699520-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Organization is an administrative structure in which persons are active.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">organization</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b0178860-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b0178860-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PersonOrganizationAssignment is an assignment of an organization or a person (specified by PersonOrganizationSelect) to an item (specified by PersonOrganizationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">person organization assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b080d180-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b080d180-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An OrganizationRelationship is a relationship between two instances of Organization.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A team belongs to a department which itself belongs to a company. Such an organizational structure may be described using instances of OrganizationRelationship.</skos:example>
        <skos:prefLabel xml:lang="en">organization relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b0dad860-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b0dad860-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Part is an identification of definition of a part. It collects the definitional information of the versions of a part. A Part shall always be categorized as &apos;piece part&apos;, &apos;product&apos;, &apos;software&apos;, &apos;tool&apos;, or &apos;raw material&apos; using a ClassSelect.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In the context of aeroplanes, a Part may be the airplane as a whole, the assembly of the engine, the body of the airplane, a fender, the side window glass, grease, or a stamping die.</skos:example>
        <skos:example xml:lang="en">In the context of cars, a Part may be the car as a whole, the assembly of the engine, the car body, a fender, the side window glass, grease, or a stamping die.</skos:example>
        <skos:note xml:lang="en">A Part does not represent an actual physical object of the real world.</skos:note>
        <skos:note xml:lang="en">A Part is identified by an organization. The definition of the domain of uniqueness and the mechanism for guaranteeing the uniqueness of Part id are outside the scope of this capability.</skos:note>
        <skos:note xml:lang="en">A Part may be either a single piece part, an assembly of arbitrary complexity, a raw material, or a tool.</skos:note>
        <skos:prefLabel xml:lang="en">part</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b1611f60-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b1611f60-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartRelationship is a relationship between two Part objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2046440-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2046440-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartToIndividualPartAssociation is an association between a design, represented by Part, and the part that is planned to be made or has been made from the design, represented by IndividualPart.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part to individual part association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b24a9500-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b24a9500-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartVersion is an identification of a version of a part. It serves as the collector of the data characterizing a realizable object in various application contexts.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">A PartVersion does not have to be referenced by any PartView.</skos:note>
        <skos:note xml:lang="en">A PartVersion is a part that may be produced, consumed, used to produce other PartVersion objects, or offered to the market.</skos:note>
        <skos:note xml:lang="en">The collection of defining information may be incomplete, i.e., not all of the PartView objects needed to define a PartVersion are associated with the PartVersion.</skos:note>
        <skos:note xml:lang="en">The following additional data can be assigned to a PartVersion: ActivityMethod, Approval, Certification, Contract, DateTimeString, Document, DocumentVersion, DocumentDefinition, File, Effectivity, InformationUsageRight, BreakdownElement, IndividualPartView, Occurrence, PartVersion, RequirementView, Project, PropertyValue, ExternalPropertyDefinition, PropertyDefinition, RequirementView, SecurityClassification, and WorkRequest.</skos:note>
        <skos:note xml:lang="en">The set of all PartVersion objects of a Part represents the history of the Part within a specific life-cycle stage or over its complete life cycle.</skos:note>
        <skos:prefLabel xml:lang="en">part version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b28a5c59-702a-4368-8eac-fa5dde6a1fbd -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b28a5c59-702a-4368-8eac-fa5dde6a1fbd">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionVersion is a revision of a Collection.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2dce9f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2dce9f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartVersionRelationship is a relationship between two instances of PartVersion. Unless specified in a specialization of this object, this relationship does not involve inheritance of data between the two related objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2e7bb78-e7e8-4c36-8f9d-2dc6845e626e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b2e7bb78-e7e8-4c36-8f9d-2dc6845e626e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f36b81-3d5e-48dd-90fc-80eaf4d96f3e"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisModel is used to support the description of Analysis concepts.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b332c8dc-450f-47e2-aa79-ac74fb43d7b3 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b332c8dc-450f-47e2-aa79-ac74fb43d7b3">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodVersionAssignment is a specialization of an AssignmentObject that represents the assignment of a TaskMethodVersion to an item (specified by TaskAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the assignment is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskMethodVersionRelationship.</skos:note>
        <skos:prefLabel xml:lang="en">task method version assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b347e0c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b347e0c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartVersionToIndividualPartVersionAssociation is a PartVersionToIndividualPartVersionAssociation is an association between a version of a design, represented by PartVersion, and the part version that is planned to be made or has been made from the design, represented by IndividualPartVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part version to individual part version association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b35626d3-b304-473d-9394-3e453c8d8bb7 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b35626d3-b304-473d-9394-3e453c8d8bb7">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionEvaluationParameter is an identification of an item (specified by ConditionEvaluationParameterSelect) used in a ConditionEvaluation.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The measured value of oil pressure from gauge 3 on car with VIN 12345678 (value = 1.9 bar).</skos:example>
        <skos:prefLabel xml:lang="en">condition evaluation parameter</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b3911ec0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b3911ec0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartView is a view of a Part with respect to specific criteria.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartViewRelationship is a relation between PartView objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b4baaaa0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b4baaaa0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartViewToIndividualPartViewAssociation is an association between a design, represented by PartView, and a view of the part that is planned to be made or has been made from the design, represented by IndividualPartView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">part view to individual part view association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b5a11300-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b5a11300-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Person is an individual human being.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">person</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b62a6740-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b62a6740-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PersonInOrganization is the specification of a Person in the context of an Organization.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">person in organization</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b636774a-e24a-444c-a45f-aa0fd1928b85 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b636774a-e24a-444c-a45f-aa0fd1928b85">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#19573db2-1baa-4bad-acc6-010eef852d49"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateObserved is a type of State. It represents a state that something has been observed to be in. This may be confirmed by measurement, or simply hypothesized.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state observed</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b6b3bb80-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b6b3bb80-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PersonInOrganizationRelationship specifies a relationship between two instances of PersonInOrganization.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The owner of important product data leaves a company and therefore has a successor. This relationship may be built up using the PersonInOrganizationRelationship.</skos:example>
        <skos:prefLabel xml:lang="en">person in organization relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b70ab520-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b70ab520-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96c60e90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PhysicalDocumentDefinition is a type of DocumentDefinition describing a piece of product data that is archived in a non-digital form.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Paper plots of technical drawings, micro fiche, or paper documents such as calculations or test reports are examples for a PhysicalDocumentDefinition.</skos:example>
        <skos:prefLabel xml:lang="en">physical document definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b72f5420-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b72f5420-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8276c6f0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PlannedActivity is a type of Activity that identifies a predicted Activity that is expected to take place in the future.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">planned activity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b77b9f60-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b77b9f60-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3571140-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PlannedIndividualPart is a type of IndividualPartVersion that represents a version of a planned artefact.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">If the planned artefact (PlannedIndividualPart) is subsequently made into an actual artefact (RealizedIndividualPart) then they are related by the ProductPlannedToRealized relationship.</skos:note>
        <skos:note xml:lang="en">It may be planned to make the artefact from of a version of a part design (PartVersion). If this is the case, then the relationship between the artefact (PlannedIndividualPart) and the design (PartVersion) is represented by PartVersionToIndividualPartVersionAssociation.</skos:note>
        <skos:prefLabel xml:lang="en">planned individual part</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b8f60a60-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b8f60a60-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PrecisionQualifier is a specification of the number of significant digits in the representation of a value.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">precision qualifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b9130840-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b9130840-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TypeQualifier is the specification of a type of a datum.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">type qualifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ba4a7e0b-c3bd-4ca5-b54a-478af53097a9 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ba4a7e0b-c3bd-4ca5-b54a-478af53097a9">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7c082e33-57b4-465b-aaad-04c8977d2353"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SimultaneousElements is a specialization of ConcurrentElements that represents two or more actions to be performed together.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">simultaneous elements</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bc81f040-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bc81f040-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bd177980-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductClass is a type of ProductConcept that represents a set of similar products to be offered to the market. ProductClass objects that are related to each other by a ProductClassRelationship do not inherit any characteristics from each other. example_product_class_hierarchy.gif Example structure from the automotive domain of ProductClass objects in a hierarchy</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In an organization which manufactures cars and engines for cars, the car models will be represented by ProductClass objects.</skos:example>
        <skos:example xml:lang="en">The following figure depicts a detail of an example of a structure that is built up by ProductClass and ProductClassRelationship objects.</skos:example>
        <skos:note xml:lang="en">A ProductClass enables to represent customer-oriented identification of products that are to be delivered to customers, while a Part enables to identify and to track the history of items that are designed and manufactured, as a tangible solution, or component of the solution, for a ProductClass.</skos:note>
        <skos:note xml:lang="en">A ProductClass may be characterized by a set of features or specifications identified by the customers or derived from customers&apos; needs.</skos:note>
        <skos:note xml:lang="en">Depending on the kind of industry and products, a ProductClass might be offered to the customers in one single or in many different configurations.</skos:note>
        <skos:note xml:lang="en">The definition of product classes is driven by market and customer requirements and forecasting. A ProductClass often corresponds to the highest-level item(s) manufactured by an organization for customers.</skos:note>
        <skos:prefLabel xml:lang="en">product class</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bcccb4e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bcccb4e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductClassRelationship is a relationship between two ProductClass objects. The meaning of this relationship is specified further by the attribute RelationType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">product class relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bd177980-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bd177980-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductConcept is a representation of a set of similar products that were, are or will be proposed to customers.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">product concept</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bd748da0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bd748da0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductConfiguration is a manufacturable object or expected as so. A ProductConfiguration is defined with respect to the ProductClass it is a member of. For a ProductConfiguration one or more additional Specification objects may be specified. In this case they enhance the characterization provided for the associated ProductClass.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A ProductConfiguration may represent a component of a contracted product, onto which severe safety rules apply and for which configuration management is therefore rigorously applied.</skos:example>
        <skos:example xml:lang="en">A ProductConfiguration that is associated with a ProductClass that identifies a family of diesel engines is intended to lead to the manufacture of a specific case of diesel engine, and the ProductConfiguration that is associated with a ProductClass that identifies a car family will lead to the manufacture of a car.</skos:example>
        <skos:example xml:lang="en">If the colour is not specified for a given car family, the vehicle resulting from the realization of a ProductConfiguration associated to the ProductClass representing the car family may be without paint or painted in any available colour.</skos:example>
        <skos:note xml:lang="en">A ProductConfiguration can be established prior to the existence of a corresponding product.</skos:note>
        <skos:note xml:lang="en">A ProductConfiguration may identify a variation of a ProductClass, an entire ProductClass, or some portion thereof.</skos:note>
        <skos:note xml:lang="en">The actual set of Specification objects for a ProductConfiguration are obtained by the union of DefiningSpecifications and of the Specification objects related to the ./4_info_reqs_ProductSpecificationAndConfiguration.htm#SpecificationAssignment.AssignedTo AssignedTo through a SpecificationAssignment or a SpecificationConditionAssignment with AssociationType &apos;identification&apos; or &apos;non-replaceable standard&apos;.</skos:note>
        <skos:note xml:lang="en">The entity ProductConfiguration corresponds to the concept of configuration item defined, in some configuration management standards, as an item subject to configuration management.</skos:note>
        <skos:note xml:lang="en">The intent of ProductConfiguration is the identification of one manufacturable object whereas the intent of ProductClass is the gathering of products with similar characteristics.</skos:note>
        <skos:note xml:lang="en">The kind of product that is to be manufactured from the data of the ProductConfiguration, is the kind of product that the MemberOf identifies a class of.</skos:note>
        <skos:note xml:lang="en">The specification of a ProductConfiguration may be incomplete: there may not be in DefiningSpecifications any instance of Specification for some SpecificationCategory declared as mandatory for the ./4_info_reqs_ProductSpecificationAndConfiguration.htm#SpecificationAssignment.AssignedTo AssignedTo. For these SpecificationCategory objects any Specification available in the context of the ./4_info_reqs_ProductSpecificationAndConfiguration.htm#SpecificationAssignment.AssignedTo AssignedTo is considered as valid for the manufacturing of the product characterized by the considered SpecificationAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">product configuration</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be3b3900-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be3b3900-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductConfigurationRelationship is a relationship between two ProductConfiguration objects. The meaning of this relationship is specified further by the attribute RelationType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">product configuration relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be51da23-f07f-49d2-91e7-ce97d34d9fb6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be51da23-f07f-49d2-91e7-ce97d34d9fb6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Justification is the identification and description of the reasons for something. Justification entities may be associated with the data to which they apply.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A justification may be provided for a product design. Similarly, a justification may be provided for why an activity is needed or was undertaken.</skos:example>
        <skos:prefLabel xml:lang="en">justification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be8d9ec0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be8d9ec0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductDesignAssociation is a mechanism to associate a PartVersion with its corresponding ProductConfiguration. It specifies the explicit design that corresponds to the ProductConfiguration. The ProductDesignAssociation represents the statement that, in all definition contexts, the PartVersion is a valid way to implement the ProductConfiguration.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The ProductDesignAssociation might not be valid for other PartVersion objects.</skos:note>
        <skos:prefLabel xml:lang="en">product design association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be9b4170-6aa7-44f1-87b9-8d618d4f8fb9 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#be9b4170-6aa7-44f1-87b9-8d618d4f8fb9">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b8e0c30-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementHierarchy defines a relationship between a parent and child BreakdownElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown element hierarchy</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bec18000-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bec18000-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3c3b5c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductPlannedToRealized is a type of IndividualPartVersionRelationship that establishes that a version of a planned artefact, represented by PlannedIndividualPart, has been realized as a version of an actual artefact represented by RealizedIndividualPart.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">product planned to realized</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bf3a0b60-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bf3a0b60-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Project is an identified programme of work. It is a set of activities to create a product or service in accordance with specified resources and requirements.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">For the development of a new car, a project is set up that is responsible for the development decisions, as well as for the accounting of the costs.</skos:example>
        <skos:note xml:lang="en">A Project may be further characterized with planned or actual dates, allowed budget, activities or resources by attribute values of this business object or by assignments to other business objects.</skos:note>
        <skos:prefLabel xml:lang="en">project</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bfcafbb6-c6ed-49fa-8dec-b307eb7619e5 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bfcafbb6-c6ed-49fa-8dec-b307eb7619e5">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PersonName is a structured combination of name components that can represent Person names in accordance with different name pattern originating from different naming conventions and cultures. A PersonName consists of a non-empty set of PersonNameComponents.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">person name</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bfec9280-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#bfec9280-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProjectAssignment is an assignment of a Project to an item (specified by ProjectAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">project assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0354eeb-a709-44fa-842f-16c012e80f48 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0354eeb-a709-44fa-842f-16c012e80f48">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentToDefinition is a relationship between a record of a set of observations about an environment, represented by an ObservedEnvironment, and a typical environment, represented by an EnvironmentDefinition. The typical environment is the expected environment about which observations have been made.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment to definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c05d7cc0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c05d7cc0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProjectRelationship is a typed association between two Project objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">project relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0b90a40-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0b90a40-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87863f90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PromissoryAssemblyOccurrenceUsage is a type of AssemblyOccurrenceRelationship. A PromissoryAssemblyOccurrenceUsage is a relationship between the occurrence of a constituent of an assembly and a view of the assembly itself. The relationship describes the intention to use the occurrence of a constituent of an assembly in an assembly. There may not be any geometric information provided for the constituent or the assembly that are associated by a PromissoryAssemblyOccurrenceUsage.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In early design stages, the PromissoryAssemblyOccurrenceUsage may be used to create preliminary BOMs for prototyping.</skos:example>
        <skos:prefLabel xml:lang="en">promissory assembly occurrence usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0bf24c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0bf24c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88035ed0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PromissoryAssemblyViewUsage is a type of AssemblyViewRelationship. A PromissoryAssemblyViewUsage is a relationship between a view of an assembly constituent and a view of the assembly itself. The relationship describes the intention to use the view of an assembly constituent in an assembly. There may not be any geometric information provided for the view or the assembly that are associated by a PromissoryAssemblyViewUsage.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">promissory assembly view usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0c6c5e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0c6c5e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyDefinition is the definition of a specific quality.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A PropertyDefinition may reflect physics or arbitrary user defined measurements.</skos:example>
        <skos:prefLabel xml:lang="en">property definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0d8f11c-88c6-4f14-9592-511a58493e5f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c0d8f11c-88c6-4f14-9592-511a58493e5f">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Collection identifies a set of data.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1247222-6528-4897-a401-5a61bdfd511c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1247222-6528-4897-a401-5a61bdfd511c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LoopingElement is a specialization of TaskElement. It invokes a specified number of repetitions of a further TaskElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">looping element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c126ace8-0b51-44f4-83a6-6aa3116f9ced -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c126ace8-0b51-44f4-83a6-6aa3116f9ced">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecificationVersionRelationship is an association between two instances of InterfaceSpecificationVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface specification version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c12d01c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c12d01c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyDefinitionAssignment is an assignment of a PropertyDefinition to an item (specified by PropertyAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A property &apos;mass&apos; defined in &apos;kg&apos; may be assigned to a Part.</skos:example>
        <skos:prefLabel xml:lang="en">property definition assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1b96340-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1b96340-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyDefinitionAssignmentRelationship is a relationship between two PropertyDefinitionAssignment objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">property definition assignment relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c208bbc0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c208bbc0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyDefinitionRelationship is a relationship between two PropertyDefinition objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A PropertyDefinitionRelationship may be used to indicate that the value of one PropertyDefinition can be derived from the value of another PropertyDefinition.</skos:example>
        <skos:prefLabel xml:lang="en">property definition relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c2556d12-6d7c-4af8-8251-7ccb3889a773 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c2556d12-6d7c-4af8-8251-7ccb3889a773">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1247222-6528-4897-a401-5a61bdfd511c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RepeatCount is a type of LoopingElement. It invokes a specified number of repetitions of the RepeatedElement TaskElement inherited from the LoopingElement parent generalization.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">repeat count</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyValue is the representation of PropertyDefinition by a numerical or textual value.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">property value</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c2d3ace0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c2d3ace0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyValueAssignment is an assignment of a PropertyValue to an item (specified by PropertyAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">property value assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c359f3e0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c359f3e0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyValueAssignmentRelationship is a relation between PropertyValueAssignment objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">property value assignment relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c3aad300-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c3aad300-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PropertyValueRelationship is a relation between PropertyValue objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">property value relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4425810-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4425810-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProxyRelationship is a relationship between a pair of Proxy objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">proxy relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c49029f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c49029f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d66b1630-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A QualitativeUncertainty is a type of UncertaintyQualifier. The uncertainty is defined in clause 2 of &apos;The Guide to the Expression of Uncertainty in Measurement&apos;.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">qualitative uncertainty</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4a27970-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4a27970-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94453010-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A QuantifiedOccurrence is a type of DefinitionBasedOccurrence which is quantified, or whose quantity depends on certain constraints.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In a BOM where the exact amount of grease or glue can usually not be specified as a quantity, the specification of this grease or glue are examples for giving just a selection criterion instead of an exact quantity.</skos:example>
        <skos:example xml:lang="en">In a TechnicalSolution for the front left brake a certain screw is used four times.</skos:example>
        <skos:example xml:lang="en">Radiator liquid or engine oil are examples for QuantifiedOccurrence objects.</skos:example>
        <skos:example xml:lang="en">To minimize the concentricity error of a wheel, weights are attached to the rim; this set of weights is a QuantifiedOccurrence whose quantity is defined by a criterion. The quantity as well as the position of these weights depends on the concentricity behaviour of each specific wheel as manufactured and tested.</skos:example>
        <skos:prefLabel xml:lang="en">quantified occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4c19a30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c4c19a30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a3571140-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RealizedIndividualPart is a type of IndividualPartVersion that represents a version of a realized artefact.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The artefact may have been made from a version of a part design (PartVersion). If this is the case, then the relationship between the artefact (RealizedIndividualPart) and the design (PartVersion) is represented by PartVersionToIndividualPartVersionAssociation.</skos:note>
        <skos:note xml:lang="en">The artefact may have been planned and represented by PlannedIndividualPart. In which case, the actual artefact (RealizedIndividualPart) is related to the planned artefact (PlannedIndividualPart) by the ProductPlannedToRealized relationship.</skos:note>
        <skos:note xml:lang="en">Where physical parts are being represented, the RealizedIndividualPart represents the physical part - something one can touch.</skos:note>
        <skos:prefLabel xml:lang="en">realized individual part</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c54437b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c54437b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ReplacedPartViewRelationship is a type of PartViewRelationship where the Relating PartView is replaced by the Related PartView. Each ReplacedPartViewRelationship shall be referenced by an Effectivity that defines the start of the validity of the replacement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">A ReplacedPartViewRelationship may be used to build up version sequences of PartView objects.</skos:note>
        <skos:prefLabel xml:lang="en">replaced part view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c54ee610-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c54ee610-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#aeba1b40-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ReplacedUsageRelationship is a type of OccurrenceRelationship is a relationship between two Occurrence objects where the relating Occurrence is replaced by the related Occurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">replaced usage relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c565c970-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c565c970-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Representation is a collection of one or more instances of RepresentationItem that are related in the specified RepresentationContext.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">representation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6260c30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6260c30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RepresentationRelationship is an association between two instances of Representation.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">representation relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6926290-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6926290-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Requirement is an essential characteristic, condition, or capability that shall be met or exceeded by a system or a component to satisfy a contract, standard, specification, or other formally imposed document.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A requirement may be identified as &apos;NOx emissions requirement&apos;, and uniquely identified as &apos;Req2&apos;.</skos:example>
        <skos:note xml:lang="en">Systems engineering tools and organizations may use differing identification mechanisms. Multiple identifiers may be managed in Requirement using the id attribute.</skos:note>
        <skos:note xml:lang="en">The term &apos;requirement&apos; is used here in the sense that term is used in systems engineering and similar industrial domains.</skos:note>
        <skos:note xml:lang="en">There may be many versions of a Requirement through RequirementVersion. There may also be more than one domain-specific view of a given RequirementVersion (using the RequirementView entity). The Requirement entity is simply a placeholder for holding a unique requirement. Most associations and properties could be defined at the Requirement, RequirementVersion or RequirementView level - that is in the context of a domain.</skos:note>
        <skos:prefLabel xml:lang="en">requirement</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6f4a478-1902-4b34-a326-e487ef9007fa -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c6f4a478-1902-4b34-a326-e487ef9007fa">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84099bf0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodVersionRelationship is a specialization of ActivityMethodRelationship. It relates two instances of TaskMethodVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">task method version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c71722f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c71722f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementAssignment is an assignment of a Requirement (via a RequirementView) to the item (specified in RequirementAssignmentSelect) which is affected by the requirement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A requirement &apos;the vehicle shall have a maximum power output of at least 150BHP&apos; could be assigned to the item which represents the vehicle&apos;s engine.</skos:example>
        <skos:prefLabel xml:lang="en">requirement assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c78b1a70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c78b1a70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ca82fdb0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementCollectionRelationship is a type of RequirementViewRelationship. It identifies a collection relationship that is used to relate a parent (collection) requirement to its member requirements. This provides a method for collecting together a set of requirements and treating them as a single requirement, whilst still being able to refer to individual requirements.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement collection relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c7974f70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c7974f70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ca82fdb0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementDecompositionRelationship is a type of RequirementViewRelationship. It identifies a decomposition relationship. This provides a method to represent a decomposition of requirements.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement decomposition relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c79d69f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c79d69f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementRelationship is a type of relationship that is used to relate previous Requirement (related) to the Requirement that replaces it (relating).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c7f15650-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c7f15650-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementSatisfactionAssertion is a relationship between an item (specified in RequirementAssignmentSelect) and a Requirement (via the RequirementView), asserting that the item satisfies the identified requirement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A data type used to represent a vehicle&apos;s engine with a power output of 160BHP could be asserted to satisfy a requirement &apos;the vehicle shall have a maximum power output of at least 150BHP&apos;.</skos:example>
        <skos:prefLabel xml:lang="en">requirement satisfaction assertion</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c85484f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c85484f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementSource is a relationship between a requirement (via the RequirementView) and an item representing the source (specified in RequirementSourceSelect) of the requirement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement source</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c8bc4770-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c8bc4770-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ca82fdb0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementTracingRelationship is a type of RequirementViewRelationship. It identifies a tracing relationship.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A requirement on the performance of a catalytic converter in a car may be traced from a more general emissions requirement. A requirement may trace to many other requirements and vice versa - this is achieved by creating multiple instances of the tracing relationship entity.</skos:example>
        <skos:prefLabel xml:lang="en">requirement tracing relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c8c3e890-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c8c3e890-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementVersion is the identification of a specific version of a requirement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A given requirement might have versions 1.0, 1.1, 1.2 and 2.0.</skos:example>
        <skos:note xml:lang="en">This entity is used to record different versions of a requirement. In this case, the word &apos;version&apos; implies &apos;revision&apos; - that is a specific release of a requirement.</skos:note>
        <skos:prefLabel xml:lang="en">requirement version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c9504a10-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c9504a10-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementVersionRelationship is a type of relationship that is used to relate previous version (related) of a requirement to the version that replaces it (relating).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c9cbe2b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c9cbe2b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementView is a view of a requirement version relevant for one or more application domains. This view collects requirement data for specific engineering purposes. Some requirements in a RequirementView might impact on different disciplines. Multiple RequirementView instances may be used to present different views of a given requirement for each discipline. The definition of the requirement is represented by a set of definitional properties referenced from RequirementView.definitionalRepresentations. If more than one definitional property is provided each property shall be equivalent. Any other property that is associated with the RequirementView is assumed to be a non-defining property, such as an annotation etc.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An engineer may have responsibility for collecting all requirements associated with the cooling of an engine - covering engine block, tubing, water pump, electric fan.</skos:example>
        <skos:example xml:lang="en">The requirement that the weight should be less than 4 Kgs can be represented by a string representation &apos;weight must be 4Kg&apos; and a numeric representation &apos;4Kg&apos; specified as a value with units.</skos:example>
        <skos:prefLabel xml:lang="en">requirement view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ca82fdb0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ca82fdb0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequirementViewRelationship is a type of relationship that is used to relate previous view (related) of a requirement version to the view that replaces it (relating).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">requirement view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#caf921d7-c92e-43bf-988c-f606357d6089 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#caf921d7-c92e-43bf-988c-f606357d6089">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityMethodRealization is a specialization of an AssociationObject. It is a further specification of how an activity method is to be performed with the ActivityMethod.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">For a given planned activity there may be a task specification, a statement of how task performance is to be logged and a schedule that all apply.</skos:example>
        <skos:note xml:lang="en">More than one specification can be associated with the same ActivityMethod.</skos:note>
        <skos:prefLabel xml:lang="en">activity method realization</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cb07be10-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cb07be10-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RetentionPeriod is the definition of a period of time that product data needs to be maintained due to organizational policy or legal requirements.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">retention period</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cb9ecdf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cb9ecdf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SecurityClassification is the level of confidentiality that is required in order to protect product data against unauthorized usage.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">security classification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cbb3ea8a-dd04-4e2b-b66e-1e1ddc87f69b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cbb3ea8a-dd04-4e2b-b66e-1e1ddc87f69b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorView identifies a view of an InterfaceConnectorVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A reliability engineer assesses the likely failure modes of design version 3.8 for the connector between a brake unit and the hydraulic control system. The engineer generates a set of data that is a specific view of the connector. An instance of the InterfaceConnectorView entity data type collects these data together.</skos:example>
        <skos:prefLabel xml:lang="en">interface connector view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cbe99290-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cbe99290-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SecurityClassificationAssignment is an assignment of a SecurityClassification to an item (specified by SecurityClassificationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">security classification assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cc683870-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cc683870-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SerialEffectivity is a type of Effectivity for which the domain of applicability is defined as a possibly open-ended interval of serial numbers. A &apos;start&apos; value shall always be specified for SerialEffectivity, an &apos;end&apos; value may be specified.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">serial effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cc884390-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cc884390-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SetMembership is a relationship that is between a set and a thing that indicates the thing is a member of the set.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">set membership</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cea900b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cea900b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94453010-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SingleOccurrence is a subtype of DefinitionBasedOccurrence It is one specific occurrence of an object that is defined either as a PartView, or as a ProductConfiguration. A SingleOccurrence is a type of Occurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In a TechnicalSolution for the &apos;front left brake&apos;, a &apos;brake disk&apos; is used and its position is specified by a geometric Transformation.</skos:example>
        <skos:note xml:lang="en">A SingleOccurrence may or may not be associated with placement information using an OccurrencePlacement.</skos:note>
        <skos:prefLabel xml:lang="en">single occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceb138fc-fefc-4b1c-adcc-a7b54167744c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceb138fc-fefc-4b1c-adcc-a7b54167744c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Environment is an abstract object where specialization allow to identify the definition of typical environment or to represents a record of observations about the environment.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceec2430-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceec2430-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Specification is a characteristic of a product. A Specification discriminates one product from other members of the same ProductClass. A Specification refers to a SpecificationCategory that completes the semantics of the Specification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&apos;coupe&apos;, &apos;hatch back&apos;, or &apos;sedan&apos; are examples for specifications belonging to the SpecificationCategory of type &apos;car body&apos;. &apos;radio 1 with CD player&apos; and &apos;radio 2 without CD player&apos; are examples for specifications belonging to the SpecificationCategory of type &apos;radio equipment&apos;. &apos;disk brake&apos; and &apos;drum brake&apos; are examples for specifications belonging to the SpecificationCategory of type &apos;braking system&apos;.</skos:example>
        <skos:note xml:lang="en">A Specification in combination with a ConditionalConfiguration may be used to define under which conditions a Part is used in combination with a ProductClass.</skos:note>
        <skos:note xml:lang="en">A Specification may be a characteristic of the members of more than one ProductClass using BreakdownVersionAssignment objects.</skos:note>
        <skos:prefLabel xml:lang="en">specification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf6f5df0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf6f5df0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationAssignment is an assignment of a Specification to a ProductClass. The meaning of this association is specified further by the attribute AssociationType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">specification assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf85b47a-9e1e-45d7-b1ec-b209c2019468 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf85b47a-9e1e-45d7-b1ec-b209c2019468">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodAssignment is a specialization of an AssignmentObject that represents an assignment of a TaskMethod to an item (specified by TaskAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the assignment is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskMethodAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">task method assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf96c7f3-c3f6-4f8f-a640-eb05f182e1d6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf96c7f3-c3f6-4f8f-a640-eb05f182e1d6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskStep is a specialization of TaskElement that is not further sub-divided.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">task step</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cfa9fe8e-2654-4165-b9a0-f85fa5aeb597 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cfa9fe8e-2654-4165-b9a0-f85fa5aeb597">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceb138fc-fefc-4b1c-adcc-a7b54167744c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentDefinition is a specialization of Environment that is used to identify the definition of typical environment in which a product is to be, has been or is planned to be deployed in, operated in, or supported in.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cfe04830-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cfe04830-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationCategory is a definition of a set of Specification objects serving the same purpose.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The category &apos;kind of drive&apos; for the Specification objects &apos;front wheel drive&apos; and &apos;rear wheel drive&apos; or the category &apos;level of equipment&apos; for the Specification objects &apos;standard&apos;, &apos;comfortable&apos;, and &apos;luxurious&apos; are examples for SpecificationCategory objects.</skos:example>
        <skos:prefLabel xml:lang="en">specification category</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d038c870-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d038c870-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationCategoryAssignment is an assignment of a SpecificationCategory to a ProductClass. Additionally, this assignment specifies if the usage of one or more Specification objects belonging to this SpecificationCategory, is mandatory or optional for all products of that ProductClass.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The assignment of a SpecificationCategory to a ProductClass does not replace the association of single members of the SpecificationCategory to the ProductClass.</skos:note>
        <skos:prefLabel xml:lang="en">specification category assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d0a51ed0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d0a51ed0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationCategoryHierarchy is used to build up hierarchical structures of SpecificationCategory objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">specification category hierarchy</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d0da86b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d0da86b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationConditionAssignment is an assignment of a Condition to a ProductClass. The meaning of this association is specified further by the attribute ConditionType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">specification condition assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d14e7e30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d14e7e30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationInclusion is a representation of the statement that specifies that the application of a Specification or of a Condition implies the inclusion of an additional Specification or Condition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The source of such a completion may be a customer order.</skos:example>
        <skos:note xml:lang="en">The SpecificationInclusion is intended to complete the set of Specification objects for a BreakdownVersionAssignment in order to enable the manufacturing of the product on the basis of an initial set of Specification objects defined.</skos:note>
        <skos:prefLabel xml:lang="en">specification inclusion</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d1ad18f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d1ad18f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecificationInclusionAssignment is an assignment of a SpecificationInclusion to a ProductClass. This assignment contains the information that a specific SpecificationInclusion applies for all products of that ProductClass.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">specification inclusion assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d214db70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d214db70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ae1e7780-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SpecifiedOccurrence is a mechanism to identify a certain Occurrence in a multi-level assembly structure that reuses partial decompositions. A SpecifiedOccurrence is a type of Occurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A &apos;chassis&apos; consists among others of the sub-assemblies &apos;front axle&apos; and &apos;rear axle&apos;. Both axle assemblies consist, among others, of the &apos;left wheel&apos; and the &apos;right wheel&apos;. In order to identify the &apos;left wheel&apos; of the &apos;rear axle&apos;, the SpecifiedOccurrence object references &apos;left wheel&apos; as definition, and &apos;rear axle&apos; as upperUsage.</skos:example>
        <skos:prefLabel xml:lang="en">specified occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d237f3d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d237f3d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d66b1630-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StandardUncertainty is a type of UncertaintyQualifier. A StandardUncertainty may be an ExpandedUncertainty. The uncertainty is defined in clause 2 of &apos;The Guide to the Expression of Uncertainty in Measurement&apos;.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">standard uncertainty</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2a75770-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2a75770-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StringValue is a type of PropertyValue that represents a sequence of one or more alphanumeric characters.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">string value</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2bb2d90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2bb2d90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fee6ad0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StyledModel is a type of GeometricRepresentation that defines the stub for a set of styling or annotation elements for which visual characteristics are specified. The geometric or annotation elements are defined in a DigitalFile.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">styled model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2e76db0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d2e76db0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SubsetMember is a relationship that is between set A, and set B that indicates: each member of set A is also a member of set B.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Set A may be equal to set B.</skos:note>
        <skos:prefLabel xml:lang="en">subset member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d30778d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d30778d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SuppliedObjectRelationship is a relationship between two objects of the SuppliedObjectSelect list representing the same object in different organizational contexts.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Usually, PartVersions that are provided by suppliers have at the supplier&apos;s site an id different from the one at the contractor&apos;s site: a PartVersion that is identified in a company by the identifier &apos;C425&apos; and the version id &apos;V2.0&apos; may correspond to the PartVersion that the supplier identifies as &apos;2X45&apos; with the version id &apos;V3.2&apos;.</skos:example>
        <skos:note xml:lang="en">The concept of multi-identification may also be used to distinguish objects in different organizational contexts. However, SuppliedObjectRelationship shall be used if the related object corresponds to an object at the supplier&apos;s site and if a distinction of additional information management is required such as approvals, history etc..</skos:note>
        <skos:note xml:lang="en">The different organizational contexts can be represented by different OrganizationOrPersonInOrganizationAssignments.</skos:note>
        <skos:prefLabel xml:lang="en">supplied object relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d397a83b-ddfa-46be-933c-547c6b4f2f12 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d397a83b-ddfa-46be-933c-547c6b4f2f12">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnector identifies a part of a product with which one or more other products or the environment interacts.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A computer has a socket to which to connect a network cable. An instance of the InterfaceConnector entity data type identifies the role of the socket in the interface and is the subject of a specification that defines the necessary geometrical and electrical attributes to ensure a functioning interface between the computer and network hardware.</skos:example>
        <skos:note xml:lang="en">This is sometimes referred to as a &apos;port&apos;.</skos:note>
        <skos:prefLabel xml:lang="en">interface connector</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d3f940f6-b225-4934-ad98-ff71f3f3b727 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d3f940f6-b225-4934-ad98-ff71f3f3b727">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceEventCorrespondenceRelationship is an association of a resource event and a corresponding statement of RequiredResource. The meaning of the relationship is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A resource event correspondence relationship can be classified as &quot;Designated for&quot;.</skos:example>
        <skos:note xml:lang="en">A resource event can be planned or recorded without having a corresponding resource requirement statement.</skos:note>
        <skos:prefLabel xml:lang="en">resource event correspondence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d4836a70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d4836a70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TimeInterval is the specification of a unit of time.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">time interval</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d4b13130-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d4b13130-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TimeIntervalAssignment is an assignment of a TimeInterval to an item (specified by TimeIntervalAssignmentSelect). The TimeIntervalAssignment shall neither be used to convey effectivity information, such as information concerning valid use of product data, nor to convey retention information, nor duration information.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Such information is conveyed using Effectivity, RetentionPeriod, and Duration respectively.</skos:note>
        <skos:prefLabel xml:lang="en">time interval assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d524c328-0343-4776-a43a-9df8c74acc5a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d524c328-0343-4776-a43a-9df8c74acc5a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeographicalArea is a type of Locator specified through a geographical, physical or political region.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Europe, North America, Berlin and Indian Ocean.</skos:example>
        <skos:prefLabel xml:lang="en">geographical area</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d53f1950-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d53f1950-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9384ed50-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TimeIntervalEffectivity is a type of Effectivity for which the domain of applicability is defined as a Duration. Depending on which of the StartDefinition and EndDefinition inherited attributes are specified, the actual domain of time defined by a TimeIntervalEffectivity is: the time interval that starts at the start date or event; the time interval that ends at the end date or event.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">time interval effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d552ef70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d552ef70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TimeIntervalRelationship is an association between two TimeInterval objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Such information is conveyed using Effectivity, RetentionPeriod, and Duration respectively.</skos:note>
        <skos:prefLabel xml:lang="en">time interval relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d5ab2f97-854e-4272-bef6-f565c4a838f6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d5ab2f97-854e-4272-bef6-f565c4a838f6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionView represents a characterization of a CollectionVersion relevant in one or more application domains and for one or more life-cycle stages.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A set of data relevant to the design of the SS Titanic and a set of data relevant to the as-built description of the SS Titanic might be represented as two instances of CollectionView</skos:example>
        <skos:prefLabel xml:lang="en">collection view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d5ab6fb0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d5ab6fb0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d4836a70-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TimeIntervalWithBounds is a type of TimeInterval. A TimeIntervalWithBounds is bounded either on one side or both sides.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">If neither SecondaryBound nor Duration are specified, the time interval begins at the point in time identified by PrimaryBound and has no specified end point.</skos:note>
        <skos:prefLabel xml:lang="en">time interval with bounds</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d61c59f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d61c59f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fddc900-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TransformedGeometricModel is a type of GeometricModel that is the transformation result of another GeometricModel.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">transformed geometric model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d66b1630-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d66b1630-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An UncertaintyQualifier is a qualifier that specifies an uncertainty as defined in clause 2 of &apos;The Guide to the Expression of Uncertainty in Measurement&apos;.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">uncertainty qualifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d698dcf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d698dcf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Unit is a quantity chosen as a standard in terms of which other quantities may be expressed. The types of units supported by this standard are SI units as well as derived or conversion-based units as defined in ISO 10303-41.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">unit</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6d15210-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6d15210-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adfff300-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueLimit is a type of NumericalValue with a qualified numerical value representing either the lower limit or the upper limit of a specific physical characteristic.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&apos;30.5 max&apos; and &apos;5 min&apos; are examples for a ValueLimit.</skos:example>
        <skos:prefLabel xml:lang="en">value limit</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6e52830-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6e52830-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueList is a type of PropertyValue with an ordered collection of PropertyValue objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A PropertyDefinition may be composed of different property values such as &apos;mass&apos;, &apos;speed&apos;, and &apos;age&apos; which are altogether necessary in a given context. The ValueList collects all of them in a given order, such that each is identifiable by its index in the list.</skos:example>
        <skos:prefLabel xml:lang="en">value list</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6f8fe50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d6f8fe50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d75d6570-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueRange is a type of ValueWithUnit with a pair of numerical values representing the range in which the value shall lie.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">value range</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d71a9010-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d71a9010-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueSet is a type of PropertyValue with an unordered collection of PropertyValue objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">value set</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d723e1aa-0001-421b-b6a2-34253ee40ef7 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d723e1aa-0001-421b-b6a2-34253ee40ef7">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisVersionRelationship is used to establish an association between two versions of an analysis.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d72e1810-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d72e1810-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d75d6570-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueWithTolerances is a type of ValueWithUnit that specifies a range of values by specifying a single nominal value and two tolerances that are offsets from the single value. The range is defined to be the closed interval [tolerancedValue + lowerLimit, tolerancedValue + upperLimit].</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">value with tolerances</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d75d6570-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d75d6570-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueWithUnit is a type of PropertyValue with either a single numerical measure, or a range of numerical measures with upper, lower, or upper and lower bounds.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">value with unit</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d80a2030-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d80a2030-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ViewOccurrenceRelationship is an association between a PartView and a DefinitionBasedOccurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">view occurrence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d86da277-f8ae-488b-8ab6-37ab005b6109 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d86da277-f8ae-488b-8ab6-37ab005b6109">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorOccurrence is an occurrence of an InterfaceConnectorDefinition. The InterfaceConnectorOccurrence represents the place where a product used in an assembly can interact with other products in the assembly. The interaction is represented by an InterfaceConnection.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d8e90e80-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d8e90e80-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkOrder is an authorization for one or more Activity objects to be performed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">One or more means that it is controlling the main activity and any sub-activity related to the activity by ActivityRelationship with relationType of &apos;decomposition&apos;.</skos:note>
        <skos:prefLabel xml:lang="en">work order</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d96c4840-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d96c4840-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkOrderAssignment is an assignment of a WorkOrder an item (specified by WorkOrderAssignmentSelect) that is subject of this WorkOrder.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">work order assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d9e7cc39-134a-430a-92d9-bba8e9b73ca1 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d9e7cc39-134a-430a-92d9-bba8e9b73ca1">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionEvaluation is a record of the evaluation of a Condition and the subsequent result.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A Condition is defined as &quot;If the measured value of oil pressure from gauge 3 on a car is less than 2 bar then check the oil level&quot;. When the condition is evaluated it is recorded by an instance of ConditionEvaluation. The measured value of oil pressure from gauge 3 on car with VIN 12345678 is 1.9 bar. Therefore the result of the evaluated condition is true.</skos:example>
        <skos:prefLabel xml:lang="en">condition evaluation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d9ef8200-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d9ef8200-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkOrderRelationship is a relationship between two WorkOrder objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">work order relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#da480240-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#da480240-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkRequest is a solicitation for some work to be done.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">These requests may not be acted upon depending on the authorization granted to the request or its associated WorkOrder.</skos:note>
        <skos:prefLabel xml:lang="en">work request</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#dacdfd29-a895-4c18-82dd-a61924aeca84 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#dacdfd29-a895-4c18-82dd-a61924aeca84">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskObjectiveStateRelationship is a relationship between a state (specified by StateOrStateDefinitionSelect) and a TaskObjective.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the entity is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskObjectiveStateRelationship. Candidate meanings include: Intended finishing state;Alternative finishing state.</skos:note>
        <skos:prefLabel xml:lang="en">task objective state relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#daf902c0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#daf902c0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkRequestAssignment is an assignment of a WorkRequest to an item (specified by WorkRequestAssignmentSelect) that is subject of this WorkRequest.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">work request assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#db792f40-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#db792f40-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A WorkRequestRelationship is a relationship between two WorkRequest objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">work request relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#de420483-9e8a-41af-9000-69c124abb275 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#de420483-9e8a-41af-9000-69c124abb275">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A SecurityClassificationLevel is the definition of the level of confidentiality that is required in order to protect product data against unauthorized usage.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">security classification level</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#e015fbfc-69b1-4e5a-b029-2c10d08ef7d3 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#e015fbfc-69b1-4e5a-b029-2c10d08ef7d3">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceAsRealizedRelationship is a relationship between the record of used or consumed resources (via ResourceAsRealized) and the corresponding item (specified by ResourceAsRealizedRelationshipSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;Alternative&quot; and &quot;Corresponding&quot; are examples of classifications of resource as realized relationship.</skos:example>
        <skos:note xml:lang="en">A resource used or consumed can be recorded without having a corresponding resource requirement statement.</skos:note>
        <skos:prefLabel xml:lang="en">resource as realized relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#e5d2a0ed-ae68-4834-87eb-5068649e7e5d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#e5d2a0ed-ae68-4834-87eb-5068649e7e5d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisVersion identifies a specific version of an Analysis.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ea4fdce2-e3af-4863-80a6-3e4ee552487b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ea4fdce2-e3af-4863-80a6-3e4ee552487b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A JustificationSupportAssignment is the assignment of an item (specified by JustificationSupportAssignmentSelect) providing evidential support for the justification to a Justification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The support item can be the results from an analysis, a report, or professional judgement.</skos:example>
        <skos:prefLabel xml:lang="en">justification support assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eb0f45bb-2991-485b-bfe5-44f8c83f3ab4 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eb0f45bb-2991-485b-bfe5-44f8c83f3ab4">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Evidence is a collector of items used together to provide a single piece of evidence within a validation or verification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A document and its approval by a customer may be used together to provide evidence of customer acceptance.</skos:example>
        <skos:prefLabel xml:lang="en">evidence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eb56a499-cc28-42ce-9587-922e784def59 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eb56a499-cc28-42ce-9587-922e784def59">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionMembership is an association of a CollectionView with an item (specified in CollectionMemberSelect) that represents a member of the collection.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection membership</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ebae0a39-680a-4dcd-a4aa-20966bec83b1 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ebae0a39-680a-4dcd-a4aa-20966bec83b1">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StatePredictedToObserved is a type of StateRelationship. It specifies the relationship between two individual states, one of which is a StatePredicted to a second state which is a StateObserved.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state predicted to observed</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eea929c3-0513-412f-bbc4-e8c25a64efe9 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#eea929c3-0513-412f-bbc4-e8c25a64efe9">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssumptionAssignment is an assignment of an Assumption to an item (specified by AssumptionAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The following set of assumptions are relevant to the project.</skos:example>
        <skos:prefLabel xml:lang="en">assumption assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef32e7b5-d45e-46cf-a64a-8e60bb3c36f0 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef32e7b5-d45e-46cf-a64a-8e60bb3c36f0">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecificationViewRelationship is an association between two instances of InterfaceSpecificationView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface specification view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef463eb2-567e-4f5f-8437-2dbe3d82745c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef463eb2-567e-4f5f-8437-2dbe3d82745c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentView is a view of an Environment with respect to specific criteria. This is an abstract object which specializations are EnvironmentDefinitionView and ObservedEnvironmentView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f0e37d16-4d8a-480c-96dd-992edd12ea38 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f0e37d16-4d8a-480c-96dd-992edd12ea38">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RegionalGrid is a type of Locator specified through a reference grid system.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">regional grid</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f1c8c663-e95e-4f73-bfbe-a25d33889fde -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f1c8c663-e95e-4f73-bfbe-a25d33889fde">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionEvaluationAssignment is an assignment of a ConditionEvaluation to an item (specified by ConditionEvaluationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">condition evaluation assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f2636078-e46f-4dbe-b95e-f10e9c9b8a3b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f2636078-e46f-4dbe-b95e-f10e9c9b8a3b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentToDefinitionVersion is a relationship between a version of the record of a set of observations about an environment, represented by an ObservedEnvironmentVersion, and a version of the typical environment, represented by EnvironmentDefinitionVersion. The typical environment is the expected environment about which observations have been made.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment to definition version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f654698f-36fa-4a96-8680-290fd5112296 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#f654698f-36fa-4a96-8680-290fd5112296">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LocationRelationship is a relationship between two instances of Location.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">location relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fa0025d0-a9de-435f-881c-c8cc3bdbd601 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fa0025d0-a9de-435f-881c-c8cc3bdbd601">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionMembershipRelationship represents an association between two CollectionMembership instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Part &quot;smart speaker&quot; replaces part &quot;encyclopaedia Britannia&quot; in the &quot;2019 version&quot; of the consumer price index basket.</skos:example>
        <skos:prefLabel xml:lang="en">collection membership relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fb9cfd9d-166f-4c3f-9a45-ecc9b8420c6b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fb9cfd9d-166f-4c3f-9a45-ecc9b8420c6b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#835280f0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodVersion is a specialization of ActivityMethod which allows the explicit reference to versions of a TaskMethod and to track changes against a TaskMethod.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">task method version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fc5feb71-9eea-481a-aa2b-91dc0f28112a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#fc5feb71-9eea-481a-aa2b-91dc0f28112a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CompoundAddress is a type of Locator specified using structured information that allows unambiguous determination of an address for the purpose of communicating, using one or more communication methods. A CompoundAddress consists of a non-empty set of AddressComponents.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">compound address</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StructuredTaskElement is a type of TaskElement. It is made up of other TaskElements.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">structured task element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff5fba41-da02-4906-b66c-40b83e7bd99e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff5fba41-da02-4906-b66c-40b83e7bd99e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskObjective is a result or objective that is reached by undertaking a TaskMethod.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">More than one TaskMethod may be defined for a given objective if there can be several ways to accomplish the objective.</skos:note>
        <skos:prefLabel xml:lang="en">task objective</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ffb1814e-b215-4055-af04-a2808883f04e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ffb1814e-b215-4055-af04-a2808883f04e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IndividualPartEffectivity is a specialization of Effectivity for which the domain of applicability is defined as a set of instances of IndividualPart.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">individual part effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#0ccba30b-b471-4863-8f01-c941e53bcf1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#0ccba30b-b471-4863-8f01-c941e53bcf1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceItemRelationship is a specification of how a resource item may be associated with another resource item. The role of the relationship is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The relationship between a product and a package can be classified as &quot;Preferred&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource item relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#00b6d8ff-c413-4f2f-a15b-0bddcd4f5c6d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#00b6d8ff-c413-4f2f-a15b-0bddcd4f5c6d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceAsRealizedAssignment is an assignment of a resource record statement (via ResourceAsRealized) to an item (specified by ResourceAsRealizedAssignmentSelect) that used or consumed the resource. The role of the assignment is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">resource as realized assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#00d88892-01a1-4dfb-9174-b5a1e78d6696 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#00d88892-01a1-4dfb-9174-b5a1e78d6696">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssumptionRelationship is an association between two Assumptions.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assumption relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#02455f10-cdf5-4478-8388-f7a130fc98c0 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#02455f10-cdf5-4478-8388-f7a130fc98c0">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateComposition is a type of StateRelationship and it relates the nature of states in relation to one another, where two or more State parts compose a whole State; and furthermore, whole states can become parts of yet another whole State.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state composition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#02807aa8-c2ee-40ee-a043-04a73b025a08 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#02807aa8-c2ee-40ee-a043-04a73b025a08">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElementAssignment is a specialization of an AssignmentObject that represents the assignment of a TaskElement to an item (specified by TaskAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the assignment is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskElementAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">task element assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#03421784-0a9f-4bda-b862-8be628c8273c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#03421784-0a9f-4bda-b862-8be628c8273c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6067df0d-3ac2-4fc8-829c-6c59487ead9e"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionalConfiguration is a type of ConditionalEffectivity and represents an association of a SpecificationConditionAssignment or a SpecificationAssignment object with a design or with a process in order to define a valid usage of it in the context of a certain ProductClass.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The semantics of the kind of association is defined by the attributes ConfigurationType and InheritanceType.</skos:note>
        <skos:prefLabel xml:lang="en">conditional configuration</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#05ed60d9-67c4-4ae8-9464-66b002f5c387 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#05ed60d9-67c4-4ae8-9464-66b002f5c387">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1247222-6528-4897-a401-5a61bdfd511c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RepeatWhile is a type of LoopingElement. It invokes repetitions of a further TaskElement and is repeated while the specified condition is satisfied. The test condition shall be evaluated prior to invoking the method and may result in the LoopingElement not being executed at all.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">repeat while</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#065a439a-f529-4c3a-8880-f27aa45e8451 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#065a439a-f529-4c3a-8880-f27aa45e8451">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionRelationship represents an association between two Collection instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#07b7437f-0898-4d93-a88b-be12e930c991 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#07b7437f-0898-4d93-a88b-be12e930c991">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6490f437-5aff-4d04-b436-f4243e3160f8"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentVersion is a specialization of EnvironmentVersion that identifies a particular version of an ObservedEnvironment.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#07bb893c-aa0b-468d-8204-dfe864c97528 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#07bb893c-aa0b-468d-8204-dfe864c97528">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentViewRelationship is a specialization of RelationshipObject that represents an association between two ObservedEnvironmentView instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#085b6771-a1f8-4cf7-9771-8de2f3a063a1 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#085b6771-a1f8-4cf7-9771-8de2f3a063a1">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionStateAssociation is used to relate a State to a StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition state association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#0931f9ce-62c3-4fa3-857c-2ec7a5076d84 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#0931f9ce-62c3-4fa3-857c-2ec7a5076d84">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExitLoop is a type of StructuredTaskElement. It signifies a pointat which to exit from a loop.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">exit loop</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1bc8420c-9fbb-49bd-b87b-925f9889e05e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1bc8420c-9fbb-49bd-b87b-925f9889e05e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequiredResourceRelationship is a relationship between two required resource statements. The meaning of the relationship is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;alternative&quot; and &quot;realized by&quot; are examples of required resource relationship.</skos:example>
        <skos:prefLabel xml:lang="en">required resource relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1c70c4cf-4e43-4b6f-9fc4-bfd4e54749d3 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1c70c4cf-4e43-4b6f-9fc4-bfd4e54749d3">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#0ccba30b-b471-4863-8f01-c941e53bcf1a"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceGroupRelationship is a specialization of ResourceItemRelationship that specifies the means to associate two resource items that are part of a resource group. The meaning of the entity is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The relationship between a facility and compressed air could be classified as &quot;Provides&quot;.</skos:example>
        <skos:example xml:lang="en">The relationship between a tool set and a mallet could be classified as &quot;Contains&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource group relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssignmentObject is a generalization of all assignments in the Core model used to identify common properties of assignments.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">An assignment implies a direction from an object to a target object.</skos:note>
        <skos:note xml:lang="en">The object being assigned is normally, but not always, of a different type to the target of the assignment.</skos:note>
        <skos:prefLabel xml:lang="en">assignment object</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssociationObject is a generalization of all associations in the Core model use to identify common properties of associations. An association is defined as a link between two dissimilar objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">An association implies no directionality or precedence between the objects.</skos:note>
        <skos:prefLabel xml:lang="en">association object</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#10d2993b-4896-4887-8535-844467faa30d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#10d2993b-4896-4887-8535-844467faa30d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinition is a mode of being. In formal systems, a StateDefinition is the definition of a situation during which some (usually implicit) invariant condition holds.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The definition of the state, ”flying” is that the aircraft is off the ground.</skos:example>
        <skos:prefLabel xml:lang="en">state definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#11e93d03-d8a0-47c0-8163-5114ac2a0c97 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#11e93d03-d8a0-47c0-8163-5114ac2a0c97">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ManagedResource is a representation of a resource that is provided with resource management capabilities. The role of a managed resource is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A managed resource can be classified as &quot;Stock line&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">managed resource</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#122f2085-66e8-4d76-9597-e242c965b9f5 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#122f2085-66e8-4d76-9597-e242c965b9f5">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ManagedResourceRelationship is an association between two managed resources. The meaning of the relationship is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A managed resource relationship can be classified as &quot;Alternative&quot; or &quot;Preferred&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">managed resource relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1602d3ca-c730-4445-a567-3a613e730d4d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1602d3ca-c730-4445-a567-3a613e730d4d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateCauseEffect is a type of StateRelationship and it relates two or more states as one state causing particular resulting effect state(s). In turn, an effect state can become a new causing state yielding in yet more effect states.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state cause effect</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#187e23b5-bc20-4c72-802a-49198ab0c9d7 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#187e23b5-bc20-4c72-802a-49198ab0c9d7">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorVersion identifies a version of an InterfaceConnector. The value of this attribute need not be specified.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#19573db2-1baa-4bad-acc6-010eef852d49 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#19573db2-1baa-4bad-acc6-010eef852d49">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A State is a mode of being in which something does, could, or did exist for a period of time.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">1 Main Engine No. 1 is in &apos;operation&apos;.</skos:example>
        <skos:example xml:lang="en">2 When Generator No. 2 surpasses 5,000 service hours, it will enter &apos;maintenance&apos; mode.</skos:example>
        <skos:example xml:lang="en">3 The portable computer&apos;s power supply was attached after it displayed a &apos;low-battery&apos; warning.</skos:example>
        <skos:note xml:lang="en">1 A state&apos;s existence can be just a state that an object is currently in, a predicted state that an object will eventually be in, or an observed state that an object has been in.</skos:note>
        <skos:note xml:lang="en">2 The period of existence may be an instant or longer.</skos:note>
        <skos:prefLabel xml:lang="en">state</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2a1e05d9-75de-4a93-9628-fdcee577f278 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2a1e05d9-75de-4a93-9628-fdcee577f278">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionEvaluationRelationship is a relationship between two instances of ConditionEvaluation.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">condition evaluation relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2bb924a1-788a-417e-a7c8-d1fa06ce3a2b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2bb924a1-788a-417e-a7c8-d1fa06ce3a2b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#53e20541-4d83-4902-a059-b807ec6e0f42"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionTransition represents a transition between two StateDefinition, identified respectively as a start and an end.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition transition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2158251b-c18b-450a-9337-ce796af6c252 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#2158251b-c18b-450a-9337-ce796af6c252">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceItemRealization is a specification of how a resource item may be associated with an item that serves as the resource.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A product may serve as a resource.</skos:example>
        <skos:prefLabel xml:lang="en">resource item realization</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#24b43cfd-4090-42e8-8875-7e127a7b934b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#24b43cfd-4090-42e8-8875-7e127a7b934b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionAssignment is the assignment of a CollectionView to an item (specified by CollectionMemberSelect) to which the CollectionView has relevance.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#29dc8412-b2ec-410c-acf1-3fcdd53338ed -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#29dc8412-b2ec-410c-acf1-3fcdd53338ed">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionVersionRelationship represents an association between two CollectionVersion instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3a0c34b7-f2df-4e90-9b4b-54d23080b748 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3a0c34b7-f2df-4e90-9b4b-54d23080b748">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An OrganizationOrganizationTypeRelationship is a relationship between an Organization and an OrganizationType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">organization organization type relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3a7c473d-13f3-443b-b683-d2ae546c7fbc -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3a7c473d-13f3-443b-b683-d2ae546c7fbc">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceItemAssignment is an assignment of a resource item to an item (specified by ResourceItemAssignmentSelect). The role of the assignment is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The assignment can be classified as &quot;applicable to&quot; or &quot;acquired for&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource item assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3b3e1d82-b5b5-4547-8e97-2f50f8d66dd0 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3b3e1d82-b5b5-4547-8e97-2f50f8d66dd0">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A MessageRelationship is a link between two related messages. The meaning of the association depends on RelationType inherited from RelationshipObject.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">If messageB replaces messageA, then MessageRelationship.Related points to messageB and MessageRelationship.Relating points to messageA with MessageRelationship.RelationType set to &apos;replaces&apos; either as a string or standard reference data.</skos:example>
        <skos:prefLabel xml:lang="en">message relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3cacd2cf-c4b8-4eb4-b756-6886cb44f3ea -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3cacd2cf-c4b8-4eb4-b756-6886cb44f3ea">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentToDefinitionView is a relationship between a view of the record of a set of observations about an environment, represented by an ObservedEnvironmentView, and a view of the typical environment, represented by EnvironmentDefinitionView. The typical environment is the expected environment about which observations have been made.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment to definition view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3d6b6422-7842-4b40-9c83-df8e3b7b1c4a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3d6b6422-7842-4b40-9c83-df8e3b7b1c4a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequiredResource is an identified need for resource. The role of a RequiredResource is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;facility&quot;, &quot;test equipment&quot;, &quot;supervisor&quot; are examples ofclassifications of a required resource.</skos:example>
        <skos:prefLabel xml:lang="en">required resource</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3e054bb3-7936-4694-9975-791156d04a22 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3e054bb3-7936-4694-9975-791156d04a22">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorViewRelationship is an association between two instances of InterfaceConnectorView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3ef97697-54b0-4208-9211-99906a761896 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3ef97697-54b0-4208-9211-99906a761896">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef463eb2-567e-4f5f-8437-2dbe3d82745c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentDefinitionView is a specialization of EnvironmentView that provides a view of a version of an environment definition relevant for one or more application domains. This view collects the characteristics that define an Environment.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en"> The characteristics include the resources available, the locations in which the product is to operate as well as climatic conditions such temperature ranges.</skos:note>
        <skos:prefLabel xml:lang="en">environment definition view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3facfed7-173e-46ee-b552-f72395931191 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3facfed7-173e-46ee-b552-f72395931191">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6490f437-5aff-4d04-b436-f4243e3160f8"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentDefinitionVersion is a specialization of EnvironmentVersion that identifies a particular version of an EnvironmentDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment definition version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#31d0a87f-d5c4-4a90-b963-f5b26fd45acf -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#31d0a87f-d5c4-4a90-b963-f5b26fd45acf">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#835280f0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethod is a specialization of ActivityMethod. It is a specification of work.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The task method may be implemented using people, machines or a combination.</skos:note>
        <skos:prefLabel xml:lang="en">task method</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3316072f-8cd7-415c-9c5f-6c5d7eb4b5d3 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#3316072f-8cd7-415c-9c5f-6c5d7eb4b5d3">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9a99abd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RelativeEvent is a type of Event the start of which will occur, respectively has occurred, with a time offset from the start of another Event.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">relative event</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#36a3188d-b596-4fe2-8eda-51e075853728 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#36a3188d-b596-4fe2-8eda-51e075853728">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentAssignment is an assignment of an item (specified in EnvironmentAssignmentSelect) to the environment (via EnvironmentDefinitionView) in which it operates or is supported.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#38bc05e3-1d21-4054-8559-5c054fa73826 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#38bc05e3-1d21-4054-8559-5c054fa73826">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A VerificationRelationship is an association between two Verifications.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the relationship is determined by classification which is identified by the RelationType property.</skos:note>
        <skos:prefLabel xml:lang="en">verification relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#38946a3f-8296-4297-aff4-1350bafc45c1 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#38946a3f-8296-4297-aff4-1350bafc45c1">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceItem is an item that can occur in the role of a resource within the application context.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A ResourceItem may be classified as &quot;Facility&quot;, &quot;Replaceable unit&quot;, or &quot;Package&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource item</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4b61e195-8c82-4e94-adec-a0bc457a30c2 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4b61e195-8c82-4e94-adec-a0bc457a30c2">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2719b60-dbf3-48e7-be31-ebb8c09491de"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An IncreasingResourceEvent is a type of ResourceEvent that increases the balance of a managed resource.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Purchasing new stock increases an inventory.</skos:example>
        <skos:prefLabel xml:lang="en">increasing resource event</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4b7fa44d-ebf6-4376-955f-898315ced722 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4b7fa44d-ebf6-4376-955f-898315ced722">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#53e20541-4d83-4902-a059-b807ec6e0f42"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionCauseEffect is a type of StateDefinitionRelationship that is used to define a causal relationship between two sets of StateDefinition entities. At least one StateDefinition acts as a cause and at least one StateDefinition acts as an effect.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition cause effect</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4f8985a9-5970-415e-8a13-bdfa544ac176 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4f8985a9-5970-415e-8a13-bdfa544ac176">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ef463eb2-567e-4f5f-8437-2dbe3d82745c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentView is a specialization of EnvironmentView that provides a view of a version of an observed environment relevant for one or more application domains. This view collects the characteristics of the observations on the environment.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4fed74bc-5a1e-447d-b033-07896c8f0593 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#4fed74bc-5a1e-447d-b033-07896c8f0593">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LocatorRelationship is a relationship between Locators.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">locator relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#423cc1ad-039d-430d-b59e-1a399fd7bcd7 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#423cc1ad-039d-430d-b59e-1a399fd7bcd7">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#cf96c7f3-c3f6-4f8f-a640-eb05f182e1d6"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AdvisoryTaskStep is a type of TaskStep. It conveys information.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;Beware of hot exhausts&quot;, &quot;do not use tool X this way&quot; and similar messages.</skos:example>
        <skos:note xml:lang="en">Some TaskMethods may not require any action to be undertaken.</skos:note>
        <skos:prefLabel xml:lang="en">advisory task step</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#424807d3-8425-49a4-be82-ce9ff2a5eb6b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#424807d3-8425-49a4-be82-ce9ff2a5eb6b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EndTask is a type of TaskElement. It signifies a point at which to end the task.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">end task</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#43cb580d-8cb9-4fa4-b37c-38d3868f21bd -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#43cb580d-8cb9-4fa4-b37c-38d3868f21bd">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecificationVersion identifies a version of an InterfaceSpecification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In 1999, BSI issues a new version of a standard for connecting domestic electrical equipment to the electricity supply.</skos:example>
        <skos:prefLabel xml:lang="en">interface specification version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#44f308d7-e1ce-4953-813a-37290f4b890b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#44f308d7-e1ce-4953-813a-37290f4b890b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#085b6771-a1f8-4cf7-9771-8de2f3a063a1"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionPredictedAssociation is a statement that a StatePredicted is expected to conform to a particular StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition predicted association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#46774e46-22a8-48e1-8a0c-d6af49cfd59e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#46774e46-22a8-48e1-8a0c-d6af49cfd59e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84099bf0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskMethodRelationship is a specialization of ActivityMethodRelationship. It relates two task methods.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The meaning of the relationship is determined by classification which is identified by the ClassifiedAs property. This information is held as reference data. The ReferenceData tab provides definitions of the Reference Data Individuals currently standardized for TaskMethodRelationship.</skos:note>
        <skos:prefLabel xml:lang="en">task method relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#48196645-acdb-4b2f-8eca-0d596b4cd693 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#48196645-acdb-4b2f-8eca-0d596b4cd693">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An OrganizationType is a recognized kind of Organization.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Change control board.</skos:example>
        <skos:example xml:lang="en">Department.</skos:example>
        <skos:example xml:lang="en">Legal entity.</skos:example>
        <skos:example xml:lang="en">Manufacturing organization.</skos:example>
        <skos:example xml:lang="en">Sales organization.</skos:example>
        <skos:prefLabel xml:lang="en">organization type</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#49063745-edcf-40bf-9fce-99ff6d720590 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#49063745-edcf-40bf-9fce-99ff6d720590">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Assumption is the identification of something assumed to be true without proof. The reason or justification for an assumption being made shall be represented by a JustificationAssignment being assigned to the Assumption. The item that is assumed shall be related to the Assumption by an ItemAssumed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An activity is planned based on the assumption that the resource required to perform the activity is available at a location.</skos:example>
        <skos:prefLabel xml:lang="en">assumption</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5a261d60-7f8f-4fae-a0ae-4fba3cb4b4fb -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5a261d60-7f8f-4fae-a0ae-4fba3cb4b4fb">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e922e0a-8f1d-4650-a0d8-5aaeadccbb0e"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A HierarchicalInterfaceConnection is a specialization of InterfaceConnection that provides an interconnection between components at different levels in an assembly. Each connection point in the assembly is represented by an InterfaceConnectorOccurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An appliance such as a television has a power lead and attached plug. The plug and power lead could be represented as an assembly of parts such as the plug pins and wires. Each connection point of the pins and wires in the assembly is represented by an InterfaceConnectorOccurrence, and an instance of the HierarchicalInterfaceConnection entity data type identifies the connection of the pins (the parts) to the plug (the assembly) in the assembly.</skos:example>
        <skos:prefLabel xml:lang="en">hierarchical interface connection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5aafd14f-6efd-4991-9d74-40c779aa2a13 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5aafd14f-6efd-4991-9d74-40c779aa2a13">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c27698c0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExternalValue is a PropertyValue held in an external system. This could include standard values such as &quot;A4&quot; as a paper size. This would be held as reference data that refers to ISO 216 where A4 is defined.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">external value</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5ade596e-2b7f-4811-b983-a594d88dbfc8 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5ade596e-2b7f-4811-b983-a594d88dbfc8">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LocatorAssignment is an assignment of a Locator to an item (specified by LocatorAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">There may be distinct assignment for each qualification for example planned, scheduled or actual. Each assignment may have a start and end date or time. A locator may have multiple assignments.</skos:note>
        <skos:prefLabel xml:lang="en">locator assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5b2f693a-2444-4c40-a392-fa1eae4186a2 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5b2f693a-2444-4c40-a392-fa1eae4186a2">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisRepresentationContext defines the context for the items (AnalysisModelItemsSelect) used in an AnalysisModel.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis representation context</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e1e2b4e-4284-48f1-9bad-a9c12cb18d07 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e1e2b4e-4284-48f1-9bad-a9c12cb18d07">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Analysis is the process of studying or examining something in an organized way to learn more about it, or a specific study or examination of something.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The full range of the Analysis process includes mathematical, physical testing, cognitive, chemical, etc.</skos:note>
        <skos:prefLabel xml:lang="en">analysis</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e33cc1f-7f90-44f1-9bbf-14e0b01f08a5 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e33cc1f-7f90-44f1-9bbf-14e0b01f08a5">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9665ed30-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PartialDocumentAssignment is an assignment of an identified portion of a document to an item (specified by DocumentAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Clause 5 of a Contract document, dealing with project administration, may be assigned to a Project.</skos:example>
        <skos:prefLabel xml:lang="en">partial document assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e922e0a-8f1d-4650-a0d8-5aaeadccbb0e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5e922e0a-8f1d-4650-a0d8-5aaeadccbb0e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnection is an interconnection between a connected pair of InterfaceConnectorOccurrences. Each InterfaceConnectorOccurrence represents the place where a product used in an assembly can interact with other products in the assembly.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An appliance such as a television has a power lead and attached plug. The plug and power lead could be represented as an assembly of parts such as the plug pins and wires. Each connection point of the pins and wires in the assembly is represented by an InterfaceConnectorOccurrence, and an instance of the InterfaceConnection entity data type identifies the connection of the pins to the wires in the assembly.</skos:example>
        <skos:prefLabel xml:lang="en">interface connection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5f758d1e-21e1-4374-90d1-7edcedd1ba90 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#5f758d1e-21e1-4374-90d1-7edcedd1ba90">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#085b6771-a1f8-4cf7-9771-8de2f3a063a1"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionHypothesisAssociation is a subjective statement without supporting evidence that a StateObserved is comparable with a particular StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition hypothesis association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#53e20541-4d83-4902-a059-b807ec6e0f42 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#53e20541-4d83-4902-a059-b807ec6e0f42">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionRelationship is an association between two or more objects of StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Relationships between StateDefinition entities may be used to support fault diagnosis.</skos:note>
        <skos:prefLabel xml:lang="en">state definition relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#537e6225-29d7-4028-8397-096cdae5b9b2 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#537e6225-29d7-4028-8397-096cdae5b9b2">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RequiredResourceAssignment is an assignment of a resource requirement statement to one or more items (specified by RequiredResourceAssignmentSelect) that requires the resource. The role of the assignment is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A resource required by the activity &quot;12&quot; needs to be calibrated prior to usage. The calibration activity &quot;21&quot; is associated with the same required resource.</skos:example>
        <skos:example xml:lang="en">A resource required by the task &quot;123&quot; needs to be disposed after its usage. This disposal task &quot;456&quot; is associated with the same required resource.</skos:example>
        <skos:example xml:lang="en">Task, task step, activity, activity method, organization are examples of entities to which the resource requirement statement could be related.</skos:example>
        <skos:example xml:lang="en">The assignment can be classified as &quot;required by&quot;.</skos:example>
        <skos:note xml:lang="en">An association between a required resource and actions that are needed prior to its usage.</skos:note>
        <skos:prefLabel xml:lang="en">required resource assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#56fb7e1d-d3d9-415b-83e7-1d6dec561a2e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#56fb7e1d-d3d9-415b-83e7-1d6dec561a2e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceDefinitionConnection is an interconnection between a connected pair of InterfaceConnectorDefinitions or, if the point of interconnection is not specified, the interconnection between a pair of views (PartView) on products.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A socket in the wall provides access to the domestic electricity supply. An appliance such as a television has a power lead and plug that fits into the socket. An instance of the InterfaceDefinitionConnection entity data type identifies this fitting of the plug into the socket.</skos:example>
        <skos:prefLabel xml:lang="en">interface definition connection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#57bfc15f-8822-42c2-9259-0bcf8e28f9dd -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#57bfc15f-8822-42c2-9259-0bcf8e28f9dd">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorOccurrenceRelationship is an association between two instances of InterfaceConnectorOccurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector occurrence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#57f5782d-8378-4465-8dc9-aa244dfd667f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#57f5782d-8378-4465-8dc9-aa244dfd667f">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Message is a collection of information, brought together by an originator (the message definer) for some specific purpose, generally the fulfilment of a process. A Message is an historical record, intended to be sent using an Envelope and in consequence, is not versioned.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The same Message can be sent several times using different Envelope. Once it has been sent once, it cannot be further changed. However, it should not remain unsent, since that is to confuse its functions and therefore its meaning with other entities such as document.</skos:note>
        <skos:prefLabel xml:lang="en">message</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#571cd187-bb98-479c-ac89-9e1806639328 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#571cd187-bb98-479c-ac89-9e1806639328">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateAssignment is an assignment of a State to an item (specified by StateAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RelationshipObject is a generalization of all relationships in the Core model used to identify common properties of relationships. A Relationship is defined to be a dependency between two objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The objects being related are normally, but not always, of the same type or specializations.</skos:note>
        <skos:prefLabel xml:lang="en">relationship object</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59cf1733-c833-4af3-9a46-faeec7a3301c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59cf1733-c833-4af3-9a46-faeec7a3301c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AddressComponent is a constituent part of an address. A non-empty set of AddressComponents makes up an address.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;The Hills&quot; is a constituent part of the address &quot;99 Lombardy Street, The Hills, United Kingdom&quot;</skos:example>
        <skos:prefLabel xml:lang="en">address component</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6e9d6828-a81d-4472-9caf-9d47f240d6d6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6e9d6828-a81d-4472-9caf-9d47f240d6d6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceAsRealized is a record of a resource that has been used or consumed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A resource as realized can be classified as &quot;Used&quot; or &quot;Consumed&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource as realized</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6067df0d-3ac2-4fc8-829c-6c59487ead9e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6067df0d-3ac2-4fc8-829c-6c59487ead9e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionalEffectivity is a type of Effectivity for which the domain of applicability is defined by an explicit condition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">conditional effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#618e4ba7-0616-48c2-a221-ae93e4c57ba6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#618e4ba7-0616-48c2-a221-ae93e4c57ba6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecification provides a definition of necessary attributes for one or more items that participate in an interface.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">BSI develops a standard for connecting domestic electrical equipment to the electricity supply.</skos:example>
        <skos:prefLabel xml:lang="en">interface specification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6490f437-5aff-4d04-b436-f4243e3160f8 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#6490f437-5aff-4d04-b436-f4243e3160f8">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentVersion is an identification of a version of an Environment. This is an abstract object which specializations are EnvironmentDefinitionVersion and ObservedEnvironmentVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A PersonNameComponent is a constituent part of a PersonName. A non-empty set ofPersonNameComponents makes up a person name.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&quot;Peter&quot; is a constituent part of the person name &quot;Peter, Pan&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">person name component</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#67676460-111d-40b5-bf37-b3bb54dff1f5 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#67676460-111d-40b5-bf37-b3bb54dff1f5">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElementLevels is a type of TaskElement that provides two or more different descriptions in place of a single method. The actual work will be the same whichever alternative TaskElement is followed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">This can be used to provide different levels of description of a task for people with varying levels of experience or expertise.</skos:note>
        <skos:prefLabel xml:lang="en">task element levels</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Locator is a means of representing a Location.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">locator</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#69990b0c-8944-4601-8a54-d3b344628d08 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#69990b0c-8944-4601-8a54-d3b344628d08">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a2719b60-dbf3-48e7-be31-ebb8c09491de"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DecreasingResourceEvent is a specialization of ResourceEvent that decreases the balance of a managed resource.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Filling a requisition reduces an inventory.</skos:example>
        <skos:prefLabel xml:lang="en">decreasing resource event</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7c082e33-57b4-465b-aaad-04c8977d2353 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7c082e33-57b4-465b-aaad-04c8977d2353">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConcurrentElements is a specialization of StructuredTaskElement thatcomprises a set of actions to be performed during the time required for the longesttask. No specific order is required.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">concurrent elements</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7f866c1a-ce53-4052-96f8-c74746255d9b -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7f866c1a-ce53-4052-96f8-c74746255d9b">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#19573db2-1baa-4bad-acc6-010eef852d49"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StatePredicted is a type of State. It represents an occurrence of the State of something in the future. Where a predicted state needs to be related to a StateObserved, the StatePredictedToObserved entity shall be used.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">It is anticipated that the aircraft will land in an un-serviceable state. Hence a set of maintenance activities are started.</skos:example>
        <skos:prefLabel xml:lang="en">state predicted</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#73ca1764-db10-4d1f-a975-80514004effa -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#73ca1764-db10-4d1f-a975-80514004effa">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f36b81-3d5e-48dd-90fc-80eaf4d96f3e"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExternalAnalysisModel is a specialization of AnalysisModel whose content is provided in an external file.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">external analysis model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#76641a10-826c-4e2b-a8ff-241402c358ab -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#76641a10-826c-4e2b-a8ff-241402c358ab">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisDisciplineDefinition is a definition or view of an AnalysisVersion taken from the perspective of the analysing organization. The AnalysisDisciplineDefinition is controlled by the analysing organization. The entity may be used to capture the definition of a specific version of an Analysis at any intermediate stage of its development where the definition is not formally released by an organization at the Analysis version level. It may be used to capture the various stages in the definition cycle of a product. If the Analysis is explicitly represented by a model, then the model is referenced from AnalysisDisciplineDefinition.DefinitionalRepresentations.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">analysis discipline definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7861dd43-6cc5-4491-9d04-b14d256c3e90 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#7861dd43-6cc5-4491-9d04-b14d256c3e90">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StartTask is a type of TaskElement. It signifies the start point of the task.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Not all formal task description require start and end elements, their inclusion is in a sequence is optional.</skos:note>
        <skos:prefLabel xml:lang="en">start task</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#794abe5a-7e64-4202-98df-17ee5c792702 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#794abe5a-7e64-4202-98df-17ee5c792702">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ProductBasedLocator is a type of Locator specified through a product-related referential.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The frame numbering inside an aircraft.</skos:example>
        <skos:prefLabel xml:lang="en">product based locator</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a3cd410-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a3cd410-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementRelationship is an association between two instances of BreakdownElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown element relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a785670-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a785670-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementVersion is a revision of a BreakdownElement. It is a collector of the views of this revision of the BreakdownElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The set of all instances of BreakdownElementVersion of the same BreakdownElement represents the history of the BreakdownElement.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown element version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ad25d50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ad25d50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementVersionRelationship is an association between two instances of BreakdownElementVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Such a relationship may exist between two BreakdownElementVersion instances of the same BreakdownElement instance or of different BreakdownElement instances.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown element version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b21b5d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b21b5d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementView is a characterization of a BreakdownElementVersion in one or more application domains and for one or more life-cycle stages. A BreakdownElementView is a collector of the properties that characterize the BreakdownElementVersion in the initialContext and the additionalContexts.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The design function of a pump and its as-built function can be represented by two objects of BreakdownElementView.</skos:example>
        <skos:prefLabel xml:lang="en">breakdown element view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b8e0c30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b8e0c30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementViewRelationship is an association between two instances of BreakdownElementView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Such a relationship may exist between two BreakdownElementView instances of the same BreakdownElementVersion instance or of different BreakdownElementVersion instances.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown element view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8be071f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8be071f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownRelationship is an association between two instances of Breakdown.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c15d9d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c15d9d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownVersion is a revision of a Breakdown.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The set of all instances of BreakdownVersion of the same Breakdown represents the history of the Breakdown.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c284ede-a307-4818-8ef9-3c85376c3ee8 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c284ede-a307-4818-8ef9-3c85376c3ee8">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#29dc8412-b2ec-410c-acf1-3fcdd53338ed"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionVersionSequenceRelationship is a specialization of CollectionVersionRelationship that represents a sequential association between two CollectionVersion instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection version sequence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c6b4cd0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c6b4cd0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownOf is a relationship between a BreakdownVersion and an item (specified in BreakdownOfSelect) of which the BreakdownVersion is a view.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown of</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ca97b6c-c669-45d8-9851-867e50427242 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ca97b6c-c669-45d8-9851-867e50427242">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorVersionRelationship is an association between two instances of InterfaceConnectorVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8cb91eb0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8cb91eb0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownVersionRelationship is a relationship between two instances of BreakdownVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Such relationship may exist between two BreakdownVersion instances of the same Breakdown or of different Breakdown instances.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d31f24a-08bb-4632-8261-89e8dbabe6ee -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d31f24a-08bb-4632-8261-89e8dbabe6ee">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#085b6771-a1f8-4cf7-9771-8de2f3a063a1"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionConfirmedAssociation is a statement confirmed by evidence such as a measurement assertion that a StateObserved is in conformance with a particular StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition confirmed association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d765430-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d765430-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Certification is a written assurance by a third party that a product, process or service conforms to specified requirements. A Certification may be associated with a document that asserts the satisfaction of specific quality criteria.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Certification information may be attached to a product, tool, process, activity, service or the skill of a person for a certain task.</skos:note>
        <skos:prefLabel xml:lang="en">certification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d823b22-d4d9-46f6-aebb-d082e6b8d45d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d823b22-d4d9-46f6-aebb-d082e6b8d45d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvironmentDefinitionViewRelationship is a specialization of RelationshipObject that represents an association between two EnvironmentDefinitionView instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">environment definition view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d941a6d-b602-42c0-846c-1c8058074312 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8d941a6d-b602-42c0-846c-1c8058074312">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Envelope is an historical record of the transmission of a Message. It is used to record the audit data for sending and acknowledging a Message. Each Envelope is only used once because it is a historical record and is not versioned.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">envelope</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8db495b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8db495b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CertificationAssignment is an assignment of a Certification to an item (specified by CertificationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">certification assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8eb0f710-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8eb0f710-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Classification is an object that associates a Class with one or more objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">classification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ed59610-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8ed59610-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ClassificationRelationship is a relationship between two Classification objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">classification relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f1732f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f1732f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d80a2030-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectedPartRelationship is a type of ViewOccurrenceRelationship that is a mechanism to associate Occurrence objects with a CollectionDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collected part relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f24ee90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f24ee90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b3911ec0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionDefinition is a type of PartView that is the definition of a PartVersion that serves as a collector for Occurrence objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Objects that are mounted in the same vehicle but may not be assembled together.</skos:example>
        <skos:prefLabel xml:lang="en">collection definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f543bf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8f543bf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fddc900-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ComposedGeometricModel is a type of GeometricModel that is the result of composing other GeometricModels into a single one.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">composed geometric model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8fb45d50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8fb45d50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Condition is a definition of the precedent that must be fulfilled before a statement or relationship becomes valid.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&apos;If the engine has been running for 10000 hours then it requires a service&apos; is an example of a conditional statement. The conditional part of the statement is &apos;If the engine has been running for 10000 hours&apos; which is stored in definition attribute on Condition. The parameter or subject of the condition is &apos;the engine&apos; which is represented by a ConditionParameter identifying the IndividualPart which represents the engine. The consequence of the condition is &apos;then it requires a service&apos;. This is represented by ConditionAssignment identifying the activity to perform the service.</skos:example>
        <skos:note xml:lang="en">The condition is defined as a text-based expression that is represented by the description attribute. The parameters against which the condition is to be evaluated are identified by ConditionParameter. The target or consequence of a condition is represented by ConditionAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">condition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#815e62dc-6223-42f9-af5c-166dbec77d8f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#815e62dc-6223-42f9-af5c-166dbec77d8f">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ItemAssumed is an association between an Assumption and the item (specified by AssumedItemSelect) that is being assumed. The facility shall be represented by a ResourceItemAssignment, the location by a Location, and the existence of the facility at the location, by a LocationAssignment assigning a location to the resource.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A facility is assumed to exist at a given location.</skos:example>
        <skos:prefLabel xml:lang="en">item assumed</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8192782a-76cc-4acd-9f1e-3b4d52188105 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8192782a-76cc-4acd-9f1e-3b4d52188105">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84099bf0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElementRelationship is a specialization of ActivityMethodRelationship. It relates two instances of TaskElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">It can be used to capture a time dependency that cuts across the structure of the method.</skos:example>
        <skos:prefLabel xml:lang="en">task element relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#82f3e630-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#82f3e630-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityAssignment is an assignment of an Activity to an item (specified by ActivityAssignmentSelect). It characterizes the role of the related data with respect to the activity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">This should not be used to represent the association of an activity with the people or organizations that are responsible for its execution or its management. That kind of information should be represented by instances of PersonOrganizationAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">activity assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8276c6f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8276c6f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Activity represents an occurrence of an action that has taken place, is taking place, or is expected to take place in the future. The mechanism by which the Activity is performed is identified by an ActivityMethod that is referred to by the ChosenMethod property.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Change, distilling, design, a process to drill a hole, and a task such as training someone, are examples of activities.</skos:example>
        <skos:note xml:lang="en">The items that are affected by an Activity are identified by instances of ActivityAssignment.</skos:note>
        <skos:prefLabel xml:lang="en">activity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#83b2a250-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#83b2a250-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityMethodAssignment is an ActivityMethod of an item (specified by ActivityMethodAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">activity method assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#833eaad0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#833eaad0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#844b38d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityHappeningRelationship is a type of ActivityRelationship that relates a PlannedActivity and its ActualActivity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">a single defined activity is recorded historically by several sub-activities.</skos:example>
        <skos:example xml:lang="en">a single servicing activity takes the opportunity to make additional checks and repairs.</skos:example>
        <skos:note xml:lang="en">A single ActualActivity may fulfil several PlannedActivity objects.</skos:note>
        <skos:note xml:lang="en">Many ActualActivity objects may be the actual for a single PlannedActivity.</skos:note>
        <skos:prefLabel xml:lang="en">activity happening relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#835280f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#835280f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityMethod is a way to carry out an Activity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">There may be more than one method for producing a required result.</skos:note>
        <skos:note xml:lang="en">This definition may be used to characterize a way to resolve a request for action.</skos:note>
        <skos:prefLabel xml:lang="en">activity method</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#837acc56-e28d-4eb0-8b03-98c1a6215f61 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#837acc56-e28d-4eb0-8b03-98c1a6215f61">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RelatedConditionParameter is a relationship between a ConditionParameter and a parameter (specified by EvaluationParameterSelect). This relationship is used to record the relationship between the parameters used to define a condition and the parameters used to evaluate it.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">related condition parameter</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#83730b79-1452-431f-b7b3-9055c2e8ca3c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#83730b79-1452-431f-b7b3-9055c2e8ca3c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectorRelationship is an association between two instances of InterfaceConnector.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connector relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84cff930-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84cff930-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#68242b94-82e8-4841-8005-89981113e22f"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Address is a type of Locator specified using the information necessary for communicating, using one or more communication methods.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">address</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84099bf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84099bf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityMethodRelationship is a relationship between two instances of ActivityMethod.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">activity method relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#844b38d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#844b38d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActivityRelationship is a relationship between two Activity objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The activity required to complete a work order, may be decomposed into a series of activities. Their corresponding instances would be Related using instances of the ActivityRelationship entity.</skos:example>
        <skos:prefLabel xml:lang="en">activity relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84853490-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#84853490-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8276c6f0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ActualActivity is a type of Activity that is a record of the occurrence of an Activity taking place. The ActualActivity may be related through an ActivityHappeningRelationship to the PlannedActivity of which it is an occurrence. The existence of an ActualActivity instance means that the ActualActivity has commenced.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The replacement of the tyres of my bicycle, frame number ZH002342, on October 25, 2011.</skos:example>
        <skos:prefLabel xml:lang="en">actual activity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#85c10ff0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#85c10ff0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a785670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AlternativeSolution is an object that identifies one of potentially many mutually exclusive implementations of a BreakdownElement.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">alternative solution</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#854f6570-2cd0-4c4e-8d29-d87bc1a0fbf0 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#854f6570-2cd0-4c4e-8d29-d87bc1a0fbf0">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ceb138fc-fefc-4b1c-adcc-a7b54167744c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironment is a specialization of Environment that represents a record of observations about the environment in which a product is or has been operating.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#85564030-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#85564030-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AddressAssignment is an assignment of an Address to an item (specified by PersonOrganizationSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">address assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#859c70f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#859c70f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b1611f60-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AlternatePartRelationship is a type of PartRelationship where the relating part represents the base part and the related part represents the alternate part. It specifies that any version of the alternate part, may be used in place of any version of the base part, regardless of its usages and of its versions. The relationship established by the AlternatePartRelationship is not symmetric: if part B is an alternate part for part A, part A is not implied to be an alternate part for part B.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Two bolts of the same size are parts. One bolt has a square head and the other has a hexagonal head. The two bolts are considered equivalent with respect to form, fit, and function: they both have sufficiently close physical shape, they take up the same space when used, and they both serve to fasten two things together. Thus, one of these two bolts could be considered to be an alternate part for the other bolt.</skos:example>
        <skos:note xml:lang="en">An AlternatePartRelationship for which the base part is an assembly involves that the entire part structure of the alternate part may be used in place of the base part and its part structure.</skos:note>
        <skos:note xml:lang="en">An AlternatePartRelationship may relate parts of any kind, provided both related Part objects identify parts of the same part category.</skos:note>
        <skos:note xml:lang="en">An organization may track design changes for a base part and establish effectivity conditions for the use of that base part in various assemblies to be manufactured. The use of an alternate part implies that an organization does not specify any specific version of the alternate part nor establish effectivities relating to it.</skos:note>
        <skos:note xml:lang="en">If a part is an alternate for another part, it is understood that there is no interest in keeping track of which part, the base or any alternates specified, is used as a specific instance of the base part within a part structure.</skos:note>
        <skos:note xml:lang="en">This concept usually refers to form, fit, function, and quality. Additional properties such as performance, noise, endurance, or reliability may also be considered as a prerequisite for the replacement.</skos:note>
        <skos:prefLabel xml:lang="en">alternate part relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#86b3ad50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#86b3ad50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ApprovalAssignment is an assignment of an Approval to an item (specified by ApprovalAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">approval assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#86f3c390-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#86f3c390-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ApprovalRelationship is a typed association between two Approval objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">approval relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8659a670-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8659a670-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ApplicationDomain is an identification of the applications for which an object may be relevant.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">application domain</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#866a6f50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#866a6f50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Approval is a judgement and formal confirmation of the quality of those product or activity data that are subject of the Approval. An Approval represents a statement made by technical personnel or management personnel whether certain requirements are met. The absence of approval information does not imply any approval status by default.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Approval purposes are defined within a given life-cycle stage view and are typically dependent upon the approval cycles within an individual business process. For each defined purpose, generally there is a defined sequence of values for the status, usually leading towards the status value &apos;approved&apos; indicating achievement of the specific purpose.</skos:note>
        <skos:prefLabel xml:lang="en">approval</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87a4c410-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87a4c410-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyOccurrenceRelationshipSubstitution is a relationship that indicates that one AssemblyOccurrenceRelationship may be substituted for another AssemblyOccurrenceRelationship. The subjects of the substitution are the related Occurrence objects of both AssemblyOccurrenceRelationship objects. The Relating AssemblyDefinition shall be the same in both AssemblyOccurrenceRelationship objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly occurrence relationship substitution</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87e353b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87e353b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyRealizationContext is an association between an individual assembly and the design.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly realization context</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#875b871a-25c1-4e6d-bdcc-b413e99f5998 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#875b871a-25c1-4e6d-bdcc-b413e99f5998">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceConnectionToDefinitionAssociation is an association between an InterfaceConnection the instance of InterfaceDefinitionConnection that represents the definition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface connection to definition association</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87556b90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87556b90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b3911ec0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyDefinition is a type of PartView that is a definition of a PartVersion that contains other subordinate components.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8768f395-4d2c-4d62-85b3-4de1f1240458 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8768f395-4d2c-4d62-85b3-4de1f1240458">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A JustificationAssignment is an assignment of a Justification to an item (specified by JustificationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The item can be an activity or a product design.</skos:example>
        <skos:prefLabel xml:lang="en">justification assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87863f90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#87863f90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d80a2030-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyOccurrenceRelationship is the relation between an AssemblyDefinition and an Occurrence representing a constituent of the assembly. The AssemblyDefinition and the PartView that serves as &apos;definition&apos; of the Occurrence shall share at least one ViewContext. An AssemblyOccurrenceRelationship is a type of ViewOccurrenceRelationship. Each AssemblyOccurrenceRelationship is a NextAssemblyOccurrenceUsage or a PromissoryAssemblyOccurrenceUsage.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The constituent may also be an assembly.</skos:note>
        <skos:prefLabel xml:lang="en">assembly occurrence relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8792b992-6e58-4cf2-8d3e-2e9dee39fc52 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8792b992-6e58-4cf2-8d3e-2e9dee39fc52">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionStateAssociationRelationship is a relationship between StateDefinitionStateAssociation objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition state association relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88035ed0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88035ed0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyViewRelationship is the relation between an AssemblyDefinition and a PartView representing a view of the assembly. An AssemblyViewRelationship is a type of PartViewRelationship. The AssemblyDefinition and the PartView shall share at least one ViewContext.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8835b970-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8835b970-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssemblyViewRelationshipSubstitution is a relationship that indicates that one AssemblyViewRelationship may be substituted for another AssemblyViewRelationship. The subjects of the substitution are the related Occurrence objects of both AssemblyViewRelationship objects. The Relating AssemblyDefinition shall be the same in both AssemblyViewRelationship objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly view relationship substitution</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88744910-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#88744910-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AssignmentObjectRelationship is a relationship between two assignment objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assignment object relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f36b81-3d5e-48dd-90fc-80eaf4d96f3e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f36b81-3d5e-48dd-90fc-80eaf4d96f3e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An AnalysisModelObject represents the results of an Analysis.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">This capability is generic and should not be confused with the capabilities of ISO 10303-209.</skos:note>
        <skos:prefLabel xml:lang="en">analysis model object</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f39610-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89f39610-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElementRealization is a relationship between a breakdown element (specified in BreakdownElementWithRealizationSelect) and the item (specified in BreakdownElementRealizationSelect) that realizes that element.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A pump realizes the &apos;provide fuel to engine&apos; element in a functional breakdown for a ship.</skos:example>
        <skos:prefLabel xml:lang="en">breakdown element realization</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89084bb0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89084bb0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Breakdown is a set of breakdown elements chosen in order to partition a product in a desired way, together with the hierarchical relationships between these breakdown elements. The hierarchical relationships, a parent-child view, is represented by BreakdownElementHierarchy instances relating the elements in the breakdown that are represented by BreakdownElement instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8958e8e3-abc5-404e-bccc-ab0847100d71 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8958e8e3-abc5-404e-bccc-ab0847100d71">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A LocationAssignment is an assignment of a location to an item (specified by LocationAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">There may be distinct assignment for each qualification for example planned, scheduled or actual. Each assignment may have a start and end date or time. A location may have multiple assignments.</skos:note>
        <skos:prefLabel xml:lang="en">location assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89626e2d-7cb7-439c-aef7-7cec58014c80 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89626e2d-7cb7-439c-aef7-7cec58014c80">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecificationView provides a view of an InterfaceSpecification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">When developing a BSI standard for connecting domestic electrical equipment to the electricity supply, collected comments from experts form a new view on a version of the standard.</skos:example>
        <skos:prefLabel xml:lang="en">interface specification view</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8966e670-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8966e670-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1d59c650-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownMember is a membership relationship between a BreakdownVersion and a member BreakdownElementView.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">breakdown member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89919ff0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89919ff0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A BreakdownElement is a constituent in one or more Breakdown instances. In such structure a BreakdownElement may play the role of a parent or a child or both.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">A BreakdownElement may be referenced from several Breakdown instances.</skos:note>
        <skos:note xml:lang="en">The type of BreakdownElement is specified by the BreakdownElementType attribute; there are no sub-classes of BreakdownElement.</skos:note>
        <skos:prefLabel xml:lang="en">breakdown element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9a26ed01-5416-4604-ba20-79712280b5bb -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9a26ed01-5416-4604-ba20-79712280b5bb">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8792b992-6e58-4cf2-8d3e-2e9dee39fc52"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateHypothesisToConfirmationRelationship is a relationship representing the fact that a StateObserved (via StateDefinitionHypothesisAssignment) has moved from being hypothesized as conforming to a StateDefinition to being confirmed (via StateDefinitionConfirmedAssignment) as conforming to a StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state hypothesis to confirmation relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9a99abd0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9a99abd0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Event is the fact of the existence of a state at some point in time.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">event</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9aa74d8d-d41a-4ff2-9b3f-3800cb0580e2 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9aa74d8d-d41a-4ff2-9b3f-3800cb0580e2">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#53e20541-4d83-4902-a059-b807ec6e0f42"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateDefinitionComposition is a type of StateDefinitionRelationship. It relates StateDefinition entities to one another, when two or more StateDefinition entities act as parts to compose a whole StateDefinition; and furthermore, whole StateDefinition entities can become parts of yet another whole StateDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state definition composition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9ae0adae-6359-4fc0-9160-35e429d7a380 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9ae0adae-6359-4fc0-9160-35e429d7a380">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ValueFormatTypeQualifier is the specification of the allowed formats for presentation of the string and numeric values that may be associated with a property.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">value format type qualifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9aed9830-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9aed9830-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EventAssignment is the assignment of an Event to an item (specified by EventAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">event assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9b461870-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9b461870-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EventRelationship is a relationship which exists between two Event objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An instance of this entity data type with RelationType &apos;sequence&apos; may be used to specify that an event shall end before another event starts.</skos:example>
        <skos:prefLabel xml:lang="en">event relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9bb92a27-6557-48a4-a762-e23918ff4f6c -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9bb92a27-6557-48a4-a762-e23918ff4f6c">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Verification is an objective assertion of a claim, that a requirement is satisfied by a specific item represented in a RequirementSatisfactionAssertion, has been verified. Verification is commonly understood to mean the answer to, &apos;Have we built the system right?&apos;. Verification ensures that the specified requirements have been met. Verification uses the methods of Test, Analysis, Inspection, Demonstration, and Similarity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A data type used to represent a vehicle&apos;s engine with a power output of 160BHP could be asserted to satisfy a requirement &apos;the vehicle shall have a maximum power output of at least 150BHP&apos;. This assertion may be verified by analysis results on simulations of the engine. In this case the analysis results would be identified in the items collection of an evidence instance, possibly including the approval of the analysis. The Evidence instance would identify that it is used to support the required Verification.</skos:example>
        <skos:note xml:lang="en">It is assumed that meta data supporting the verification will be applied using assignment entities, such as identification assignment, person and organization assignment etc..</skos:note>
        <skos:note xml:lang="en">Just because an item is verified does not ensure that it meets all stakeholder needs or expectations, many of these are never specified, or are of an untestable nature, such as &apos;the car should look sporty&apos;.</skos:note>
        <skos:prefLabel xml:lang="en">verification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9bbd1d30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9bbd1d30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#d237f3d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExpandedUncertainty is a type of StandardUncertainty that specifies the factor of an uncertainty.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">expanded uncertainty</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9c98fe40-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9c98fe40-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fddc900-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExternalGeometricModel is a type of GeometricModel that contains geometry in a three-dimensional context only.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">external geometric model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9daedb10-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9daedb10-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ExternalUnit is an external specification of a quantity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">external unit</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9dba1851-6682-4143-9fb1-c4dd0bf75be7 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9dba1851-6682-4143-9fb1-c4dd0bf75be7">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EnvelopeRelationship is an association of one Envelope with another. The meaning of the relationship may be specified using the RelationType attribute inherited from the RelationshipObject.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">The most obvious use of the association is to link an Envelope to its acknowledgements.</skos:note>
        <skos:prefLabel xml:lang="en">envelope relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9dc2b049-3c4d-414e-b125-883e393d9b14 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9dc2b049-3c4d-414e-b125-883e393d9b14">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c1247222-6528-4897-a401-5a61bdfd511c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A RepeatUntil is a type of LoopingElement. It invokes repetitions of a further TaskElement and is repeated until the specified condition is satisfied. The element being repeated shall be executed at least once and the condition tested after the first execution.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">repeat until</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e16c4a0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e16c4a0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A File is one of potentially more files on a computer system or in actual stacks of paper that may make up a DocumentDefinition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">file</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e971830-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e971830-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A FileRelationship is a relationship between two File objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">file relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f656069-ff2c-4f09-9091-f91388a14764">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A StateRelationship is a relationship between two or more State.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">state relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f8cc2d0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9f8cc2d0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#a014de90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeneralGeometricRepresentationRelationship is a type of GeometricRepresentationRelationship that defines a user-defined association between two GeometricModel objects whose meaning is defined by the attribute relationType.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">general geometric representation relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fbf4480-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fbf4480-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricalRelationship is the relationship between two PartViewRelationship objects specifying two parts that are geometrically related. Therefore, the shape of the related parts may be represented only once and can be reused for the geometrically related situation. In this case the shape of the relating PartView is derived from the shape of the related PartView. The two PartViewRelationship objects that are related by this relationship shall belong to different PartVersion objects. Other properties except shape are not subject to this relationship and therefore are not &apos;inherited&apos; from the related PartView to the relating PartView. geometricalrelationship.png Mudguard illustration of GeometricalRelationship</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The following figure shows an example for a GeometricalRelationship: in this case the left mudguard of a car is symmetrical to the right mudguard. A given plane mirroring transformation specifies the location of the left mudguard regarding the location of the right mudguard.</skos:example>
        <skos:prefLabel xml:lang="en">geometrical relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fddc900-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fddc900-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fee6ad0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricModel is a type of GeometricRepresentation that represents the geometric shape of a product.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric model</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fee6ad0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9fee6ad0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#c565c970-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A GeometricRepresentation is a type of Representation which is defined in a GeometricCoordinateSpace.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">geometric representation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#90dc6290-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#90dc6290-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConfiguredAssemblyEffectivity is an effectivity controlled association of a ProductDesignAssociation with an item (specified by AssemblyDesignSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">configured assembly effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9029db70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9029db70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionAssignment is an assignment of a Condition to an item (specified by ConditionAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">condition assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#907933f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#907933f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionParameter is a representation of an item (specified by ConditionParameterSelect) that is used to specify a Condition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">condition parameter</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#909dd2f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#909dd2f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ConditionRelationship is a relationship between two instances of Condition.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">condition relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#91af796a-c733-4d0a-8de2-ada45ba26d63 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#91af796a-c733-4d0a-8de2-ada45ba26d63">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A CollectionViewRelationship represents an association between two CollectionView instances.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">collection view relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#91d08690-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#91d08690-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Contract is a binding agreement between two or more parties.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Contracts may concern the design of part version objects, the delivery of drawing objects, or the execution of activity objects.</skos:example>
        <skos:prefLabel xml:lang="en">contract</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#913c1856-862f-4f77-ba95-3a2f1c9c573a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#913c1856-862f-4f77-ba95-3a2f1c9c573a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Validation is a subjective assertion that an item is &apos;fit for purpose&apos;. Validation is commonly understood to mean &apos;Have we built the right system?&apos;. Validation is concerned with ensuring that the system will meet the customer’s objectives and expectations. Validation usually includes testing under normal usage conditions.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Every flight of every Space Shuttle has been a &apos;Validation&apos; flight to test the new design under actual conditions. No two shuttles have flown in the same configuration and many systems cannot be validated except under actual conditions.</skos:example>
        <skos:note xml:lang="en">An item may pass validation even though some requirements fail verification.</skos:note>
        <skos:note xml:lang="en">It is assumed that meta data supporting the validation will be applied using assignment entities, such as identification assignment, person and organization assignment etc..</skos:note>
        <skos:prefLabel xml:lang="en">validation</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9225f990-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9225f990-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ContractAssignment is an assignment of a Contract to an item (specified by ContractAssignmentSelect).</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">contract assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#925c9f2b-76ff-4dce-9ce8-4dc1e4dc8234 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#925c9f2b-76ff-4dce-9ce8-4dc1e4dc8234">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An InterfaceSpecificationRelationship is an association between two instances of InterfaceSpecification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">interface specification relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9279e5f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9279e5f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ContractRelationship is an association between two different instances of Contract.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A sub-contract may be related to the main contract with the customer.</skos:example>
        <skos:prefLabel xml:lang="en">contract relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#93f143b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#93f143b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DateTimeAssignment is an association of point in time specified as a DateTimeString with product data. This assignment provides additional information for the associated object. The provision of such data through this assignment has an organizational character whereas some objects require the same kind of data mandatorily in order to be semantically complete. This assignment shall not be used to associate the corresponding organizational data with an object whose attributes are referencing the organizational data directly.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An example for the requirement stated is that there shall not exist a DateTimeAssignment with a role of &apos;actual start date&apos; that refers to an Activity, since this object refers directly to DateTimeString in that role.</skos:example>
        <skos:example xml:lang="en">If applied to an instance of Part with role &apos;creation&apos;, the DateTimeAssignment specifies the creation date of the part, tool, or raw material as a new object in the activity domain, and not the creation date of the instance of Part in a product management system.</skos:example>
        <skos:note xml:lang="en">In the context of the object DateTimeAssignment, the expression &apos;referenced object&apos; means a concept that is conveyed within one of the instances referred to by the attribute assignedTo and not one of the instances referred to by this attribute.</skos:note>
        <skos:prefLabel xml:lang="en">date time assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9384ed50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9384ed50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DatedEffectivity is a specialization of Effectivity for which the domain of applicability is defined as an interval of time bounded by dates or events. The time bounds are defined by its inherited attributes StartDefinition or EndDefinition. The interval may be open-ended. Depending on which of the StartDefinition and EndDefinition attributes are specified, the actual domain of time defined by a DatedEffectivity is: the time interval between the start and end date or event; the open time interval that starts at the start date or event; the open time interval that ends at the end date or event (i.e. the start is unknown). If the EndDefinition is an event that actually identifies a point in time that comes before the StartDefinition, then the actual domain of effectivity is empty.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Events may be used to bound a DatedEffectivity period, at planning phase.</skos:example>
        <skos:prefLabel xml:lang="en">dated effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94e25a70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94e25a70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Descriptor is a set of words that describe something.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The same thing may have multiple descriptions associated with it. Assigning both a short description and a long description to an activity or an organization are examples of multiple descriptions applied to the same item.</skos:example>
        <skos:prefLabel xml:lang="en">descriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94453010-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#94453010-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ae1e7780-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DefinitionBasedOccurrence is a type of Occurrence that uses a PartView or a ProductConfiguration as its definition. It is either a SingleOccurrence or a QuantifiedOccurrence.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">definition based occurrence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9452ebb0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9452ebb0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b44098a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DefinitionalPartViewUsage is a type of PartViewRelationship where all the elements of the Related PartView are then available to the Relating PartView. These elements are specifically all PartShapeElements, properties and NextAssemblyOccurrenceUsages on the Related PartView. These elements are either direct or indirect. A direct element references explicitly a PartView. An indirect element is available to a PartView via a DefinitionalPartViewUsage of another PartView. All DefinitionalPartViewUsages must describe an acyclic graph.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">A related PartView can be a definitional constituent of the relating PartView only once.</skos:note>
        <skos:prefLabel xml:lang="en">definitional part view usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f1bde5-b263-4ca1-89df-33e1205800dd">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#835280f0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElement is a specialization of ActivityMethod. It is a representation of all or part of how to undertake a task.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">task element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f502f0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#95f502f0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Document is a logical container for documentation data under configuration control.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9520cf55-f02b-47f8-9c2b-257553036333 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9520cf55-f02b-47f8-9c2b-257553036333">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A ResourceEventRelationship is a specification of how a ResourceEvent may be associated with another ResourceEvent. The meaning of the relationship is determined by classification.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A managed resource relationship can be classified as &quot;realized by&quot; or &quot;replaces&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">resource event relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9520ea10-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9520ea10-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DescriptorRelationship is a relationship between two Descriptor objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">descriptor relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#956ebbf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#956ebbf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96c60e90-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DigitalDocumentDefinition is a type of DocumentDefinition that collects files that are archived on an optical computer disc, magnetic, electronic storage, or a combination thereof. A DigitalDocumentDefinition may consist of one or many component DigitalFile.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">digital document definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#957c7790-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#957c7790-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9e16c4a0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DigitalFile is a type of File that contains computer interpretable data and is stored on an electronic device.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">digital file</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#959c82b0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#959c82b0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#b72f5420-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DirectedPlannedActivity is a type of PlannedActivity that identifies a PlannedActivity governed by a WorkOrder.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">directed planned activity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96c60e90-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96c60e90-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentDefinition is one of potentially more alternative views of a DocumentVersion.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A version of a logical document, which contains a shape model, may be represented in the different native formats of two three-dimensional CAD systems.</skos:example>
        <skos:note xml:lang="en">A DocumentVersion may have more than one view.</skos:note>
        <skos:prefLabel xml:lang="en">document definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96d3588c-c6cf-461c-ae07-9d343a97238e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96d3588c-c6cf-461c-ae07-9d343a97238e">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An ObservedEnvironmentAssignment is an assignment of an item (specified in ObservedEnvironmentAssignmentSelect) to the environment (via ObservedEnvironmentView) in which item is observed.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">observed environment assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96562395-fe55-4cc6-a59d-1c71f880097a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#96562395-fe55-4cc6-a59d-1c71f880097a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ff04d2c5-cea4-41a6-be35-821c1495d8ba"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A TaskElementSequence is a specialization of TaskElement that comprises a sequence of steps to be followed in a specified order.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">task element sequence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9665ed30-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9665ed30-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentAssignment is an assignment of a Document to an item (specified by DocumentAssignmentSelect), where the assigned document provides information about the object it is assigned to.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97b41810-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97b41810-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentRelationship is a relationship between two Document objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97ef9a70-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97ef9a70-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentVersion identifies a particular version of a Document.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97557d50-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#97557d50-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentDefinitionRelationship is a relationship between two DocumentDefinition objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document definition relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#98b47110-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#98b47110-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#adfff300-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A Duration is the definition of a period of time.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">duration</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#98575cf0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#98575cf0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">A DocumentVersionRelationship is a relationship between two DocumentVersion objects.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">document version relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99d96910-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99d96910-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59b11220-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EffectivityRelationship is a relationship between two Effectivity objects. The meaning of the relationship is represented by the RelationType attribute.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">Sometimes effectivity is not dependent on specific dates or serial numbers, but on the effectivity of other items. In this case end values are not instantiated but are derived via an EffectivityRelationship to the reference Effectivity.</skos:note>
        <skos:prefLabel xml:lang="en">effectivity relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#99130bd0-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#STEPThing"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An Effectivity is an identification of the valid use of an aspect of product data tracked by date, event, serial number or lot size. An Effectivity may &apos;inherit&apos; its interval from another Effectivity through an EffectivityRelationship with ./4_info_reqs_CommonResources.htm#EffectivityRelationship.RelationType RelationType &apos;inheritance&apos;. If a &apos;start&apos; and no &apos;end&apos; is specified, the period is then added to &apos;start&apos; in order to get the actual &apos;end&apos; of the effectivity or ineffectivity.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:note xml:lang="en">An instance of Effectivity may define a period or a part of ineffectivity, i.e., of invalid use, if it is referred to by an instance of EffectivityAssignment with EffectivityIndication set to &apos;false&apos;.</skos:note>
        <skos:prefLabel xml:lang="en">effectivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9977c110-130a-0135-b552-598f1b1392ae -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#9977c110-130a-0135-b552-598f1b1392ae">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#1cfca290-3279-0135-b58f-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator xml:lang="en">Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-4000</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">An EffectivityAssignment is an assignment of an Effectivity to an item (specified by EffectivityAssignmentSelect) whose effectivity is controlled by the assigned Effectivity. The association of an Effectivity to product or activity data does not imply any statement concerning effectivity outside of the specified interval. The same applies in the absence of any AssignedEffectivity, that is, no statement concerning effectivity is implied.</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Phil Spiby, Eurostep: Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">effectivity assignment</skos:prefLabel>
    </owl:Class>
</rdf:RDF>



