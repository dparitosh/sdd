        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-242:2020</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">specification assignment in which the Specification is a characteristic of a product if explicitly chosen</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&apos;Sun roof&apos; or &apos;radio with CD player&apos; are common options proposed to a customer buying a car.</skos:example>
        <skos:prefLabel xml:lang="en">option specification assignment</skos:prefLabel>
    </owl:Class>
    


