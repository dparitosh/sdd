        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">interface connector version that identifies a design version of an interface connector</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">BuildAWidget Incorporated creates design version 2.10 for an electrical supply connector.</skos:example>
        <skos:prefLabel xml:lang="en">interface connector design</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad823550-46b2-0138-6478-78b156d8ad1a -->

