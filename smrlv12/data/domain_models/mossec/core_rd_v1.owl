        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In a system breakdown, the fuel system might include a fuel storage system and a fuel injection system as components.</skos:example>
        <skos:prefLabel xml:lang="en">system element usage</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#149dadf0-394a-0138-62a2-78b156d8ad1a -->

