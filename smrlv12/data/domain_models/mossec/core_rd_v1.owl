        <skos:prefLabel xml:lang="en">mathematical description document assignment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#6497012e-29db-4e03-888c-47de083ef9d9 -->

