        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-242:2020</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">document relationship in which the Related Document provides information that is supplementary or collateral to that provided by the Relating Document</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">addition document relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#42a5263c-bfbc-4f66-af3b-13dc4d77b6c6 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#42a5263c-bfbc-4f66-af3b-13dc4d77b6c6">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#03421784-0a9f-4bda-b862-8be628c8273c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-242:2020</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">conditional configuration in which no inheritance scheme is applicable and all required configuration information must be attached locally at the business object</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A situation where the InheritanceType &apos;exception&apos; is applicable is a technical solution released for one particular customer without support in higher structure levels.</skos:example>
        <skos:prefLabel xml:lang="en">exception conditional configuration</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#429cc008-12c4-4f23-a40b-bf1c83348c9f -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#429cc008-12c4-4f23-a40b-bf1c83348c9f">
