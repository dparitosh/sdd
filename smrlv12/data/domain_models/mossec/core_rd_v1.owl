        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component designating the postal operator or other authority responsible for the definition and maintenance of the delivery point specification concerned</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In </skos:example>
        <skos:prefLabel xml:lang="en">defining authority</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac06-9a46-faeec7a3301c -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac06-9a46-faeec7a3301c">
