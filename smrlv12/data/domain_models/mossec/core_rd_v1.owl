        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component designates a delivery point or a group of delivery points from which the postal operator may choose one, by reference to a defined identifier, rather than by reference to its physical location</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Post office box numbers, BP (Boîte Postale), PRIVATE BAG, poste restante and business reply services.</skos:example>
        <skos:prefLabel xml:lang="en">delivery service identifier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac07-9a46-faeec7a3301c -->

