    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ac0ba629-aca8-4d33-8632-dc1e41feaa39 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ac0ba629-aca8-4d33-8632-dc1e41feaa39">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#86f3c390-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-242:2020</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">approval relationship in which the issuing of the Related Approval is subject to the issuing of the Relating Approval</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In two parallel sequences of Approval objects for two assemblies, a certain Approval object of one assembly may be dependent on a certain Approval object of the second assembly.</skos:example>
        <skos:example xml:lang="en">The Approval of an assembly may be dependent on the Approval of all of the constituents of the assembly.</skos:example>
        <skos:prefLabel xml:lang="en">dependency approval relationship</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad2c470d-ba06-4f63-87b5-ec635df89920 -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad2c470d-ba06-4f63-87b5-ec635df89920">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#4b7f5e38-ab33-4398-a264-458b9e2ba0d3"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Internet Assigned Numbers Authority (IANA)</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">MIME media type for Adobe Portable Document Format (PDF)</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">application/pdf</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad821a00-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad821a00-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89084bb0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown comprising functional elements s</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A functional breakdown provides a decomposition of an aircraft in terms of high-level processes such as &quot;flight&quot; and &quot;taxiing&quot; all the way down to low-level functions such as &quot;detect onboard fuel level&quot;, &quot;move tail rudder&quot;, and &quot;provide standard tow attachment point&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">functional breakdown</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad821a80-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad821a80-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8966e670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown member that links a functional element to a functional breakdown of which includes the functional element as a member</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A function &apos;provide load lifting capability&apos; is a member of the functional breakdown of a helicopter.</skos:example>
        <skos:prefLabel xml:lang="en">functional breakdown member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad821b00-46b2-0138-6478-78b156d8ad1a -->

