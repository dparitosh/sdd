        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname derived from an honoured ancestor</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In Arabic practice, an ancestral name typically begins with Al- or ibn, like in Al-Husain or ibn Sau’d.</skos:example>
        <skos:prefLabel xml:lang="en">ancestral name</skos:prefLabel>
    </owl:NamedIndividual>
    


