    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65be356a-4115-41de-b161-874ab6dc4d7e -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65be356a-4115-41de-b161-874ab6dc4d7e">
