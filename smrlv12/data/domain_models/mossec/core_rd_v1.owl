        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component providing additional data or instructions intended to facilitate access to, or designation of, a delivery point</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">“Opposite number 23”, “50 metres to the left of the main door”, “Cruce Con Calle Obregon”</skos:example>
        <skos:prefLabel xml:lang="en">supplementary delivery point data</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac19-9a46-faeec7a3301c -->

