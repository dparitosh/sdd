        <skos:example xml:lang="en">An internal organizational mail distribution code or mail stop.</skos:example>
        <skos:prefLabel xml:lang="en">supplementary despatch information</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac20-9a46-faeec7a3301c -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac20-9a46-faeec7a3301c">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59cf1733-c833-4af3-9a46-faeec7a3301c"/>
