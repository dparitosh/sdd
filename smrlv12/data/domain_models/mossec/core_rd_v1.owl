        <skos:example xml:lang="en">A physical breakdown of a motor car into body, roof, bonnet, bumpers etc.</skos:example>
        <skos:prefLabel xml:lang="en">physical breakdown</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8235d0-46b2-0138-6478-78b156d8ad1a -->

