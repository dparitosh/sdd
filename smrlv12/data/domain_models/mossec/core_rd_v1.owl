        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An engineer changes the details describing the undercarriage that is an element in a physical breakdown of an aircraft.</skos:example>
        <skos:prefLabel xml:lang="en">physical element version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad826130-46b2-0138-6478-78b156d8ad1a -->

