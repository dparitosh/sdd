        <skos:prefLabel xml:lang="en">delivery service qualifier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac08-9a46-faeec7a3301c -->

