        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8966e670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown member that is a membership relationship between a system element and a system breakdown of which the system element is a member</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A heating system is a member of the breakdown of a climate control system.</skos:example>
        <skos:prefLabel xml:lang="en">system breakdown member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad826230-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad826230-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c15d9d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown version that identifies a version of a system breakdown</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A logistics engineer modifies the current systems breakdown for an aircraft and associated support equipment on the basis of results from a level of repair analysis.</skos:example>
        <skos:prefLabel xml:lang="en">system breakdown version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8262b0-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8262b0-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89919ff0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element that represents a system</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">system element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad826330-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad826330-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b21b5d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element view that identifies a view of a version (system element version) of a system element</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The collision avoidance system element of a system breakdown is subject to a level of repair analysis to support implementation of optimized maintenance for an aircraft.</skos:example>
        <skos:prefLabel xml:lang="en">system element definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8263e0-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8263e0-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a785670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element version that identifies a version of a system element</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A sound engineer changes the details describing the public address system that is an element in a system breakdown of an aircraft.</skos:example>
        <skos:prefLabel xml:lang="en">system element version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827290-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827290-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89084bb0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown comprising zone elements</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A zonal breakdown provides a decomposition of an aircraft in terms of spaces or high-level conceptual parts such as &apos;wing&apos; - which might further decompose into lower-level zones such as &apos;inner-wing&apos;, and &apos;outer wing&apos;.</skos:example>
        <skos:prefLabel xml:lang="en">zonal breakdown</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827320-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827320-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8966e670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown member that is a membership relationship between a zone element and a zonal breakdown of which the zonal element is a member</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A &apos;fire-check zone&apos; might be a member of the zonal breakdown of a building.</skos:example>
        <skos:prefLabel xml:lang="en">zonal breakdown member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827390-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827390-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8c15d9d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown version that identifies a version of a zonal breakdown</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An architect modifies the current fire-check zonal breakdown for a building on the basis of reports from a buildings inspector.</skos:example>
        <skos:prefLabel xml:lang="en">zonal breakdown version</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827410-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827410-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#89919ff0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element that represents a 3-dimensional space</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">&apos;Empennage&apos;, &apos;Right vertical stabilizer and rudder&apos; and &apos;Lower rudder&apos; are all elements in a zonal breakdown of an aircraft.</skos:example>
        <skos:prefLabel xml:lang="en">zone element</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8274a0-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8274a0-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8b21b5d0-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element view that identifies a view of a version (zone element version) of a zone element</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">For an aircraft, an element &apos;Right vertical stabilizer tip&apos; is in a zonal breakdown that an engineer uses for reliability-centred maintenance analysis.</skos:example>
        <skos:prefLabel xml:lang="en">zone element definition</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827550-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad827550-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8a785670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown element version that identifies a version of a zone element</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An engineer defines an inspection task on a breakdown element &apos;Upper rudder&apos; that is part of a zonal breakdown of an aircraft. The engineer identifies the corresponding view of the breakdown element.</skos:example>
