        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component which identifies the road or part of a road or other access route along which a delivery point can be accessed, either directly or via a secondary or tertiary road or access route</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">San Marcos, Pine Ridge, Main, 6th, Charles de Gaulle.</skos:example>
        <skos:prefLabel xml:lang="en">thoroughfare</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac21-9a46-faeec7a3301c -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac21-9a46-faeec7a3301c">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59cf1733-c833-4af3-9a46-faeec7a3301c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component indicating the name of the populated place in which a delivery point is located or near to or via which the delivery point is accessed</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">town</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac22-9a46-faeec7a3301c -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac22-9a46-faeec7a3301c">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#59cf1733-c833-4af3-9a46-faeec7a3301c"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component identifying, for a delivery point, the building section in which it is housed and/or the main entry door through which it is accessed</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">wing</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#6eeed168-d624-44e1-bd23-892bbff38e6f -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#6eeed168-d624-44e1-bd23-892bbff38e6f">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#ab417830-0eae-45bb-9b47-efb2d6d99faa"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>OASIS PLCS v1.0</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">a request for confirmation that a message has arrived in the recipient&apos;s mailbox</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">ask message arrival</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#62a8ea82-589c-4636-baca-e82ef56793f8 -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#62a8ea82-589c-4636-baca-e82ef56793f8">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#8659a670-130a-0135-b552-598f1b1392ae"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-242:2020</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">set of activities and processes required to define or analyse an assembly</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">assembly study</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-ca19-1119-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-ca19-1119-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">alias derived from a name of the person</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Greek family names can often be abbreviated. The name PAPPAS is a good example of this. PAPPAS can be a family name in itself; however, it is often used as an abbreviation of a longer name such as PAPACHRISTODOULOPOULOS.</skos:example>
        <skos:example xml:lang="en">In Czech practices, diminutives are often used for personal names. These are often longer than the original name, like Vĕra becomes Vĕruška, Petra becomes Petruška. Some also look different from the original name, e.g. Jan may become Honza, Josef may become Pepík.</skos:example>
        <skos:prefLabel xml:lang="en">diminutive</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1101-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1101-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that is shared by all members of the person&apos;s family</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Czech female family names are often their male equivalents with the ending -OVÁ attached, like (m) CAMEK, (f) CAMKOVÁ (note ‘E’ is removed before the female ending) or (m) NOVÁK, (f) NOVÁKOVÁ.</skos:example>
        <skos:example xml:lang="en">Some Greek family names have a masculine and feminine form, like (m) KYPRIANOS, (f) KYPRIANOU.</skos:example>
        <skos:prefLabel xml:lang="en">family name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1102-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1102-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that is derived from personal name of father</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In Russia, the patronymic is derived from the father’s personal name and applies equally to children of both genders, but with different endings. For a man, it will usually end -OVICH (‘son of’), -EVICH, or -YEVICH, e.g. Ivan’s son will have the patronymic Ivanovich; For a woman, it will be -OVNA (‘daughter of’), -EVNA, or -YEVNA, e.g. Ivan’s daughter will have the patronymic Ivanovna.</skos:example>
        <skos:example xml:lang="en">In bulgaria practices, patronymics are built by adding endings (-ov, -ev, -ski/-sky, -in for male, -ova, -eva, -ska or -ina for female) to father&apos;s personal name. Emil Petrov CHRISTOV’s father would have been Petr. The –ov ending forms the patronymic.</skos:example>
        <skos:example xml:lang="en">Traditionally in Greece, a patronymic is used derived from the father’s personal name, usually with the ending –ou, meaning ‘of’, for example Spyros Georgiou means ‘Spyros (the son) of Georgios’.</skos:example>
        <skos:prefLabel xml:lang="en">patronymic</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1103-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1103-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname given to, or used by, a person according to the tradition of the person’s religion</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Common Pakistan religious names include Abdul, Allah / Ullah, Saeed (Syed), Muhammad, Ahmad, and Rahman.</skos:example>
        <skos:example xml:lang="en">In Sikh naming practice, the religious name is always Singh for men and Kaur for women.</skos:example>
        <skos:prefLabel xml:lang="en">religious name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1104-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1104-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that corresponds to the personal name of the person&apos;s father</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">father’s personal name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1105-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1105-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that corresponds to the family name of the person&apos;s father</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">father’s paternal family name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1106-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1106-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that corresponds to the family name of the person&apos;s mother</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A Portuguese name is made of personal name(s), mother&apos;s paternal family name and fathers&apos;s paternal family name(s). In the name Luiz João PAZOS SILVA, PAZOS is the mother&apos;s paternal family name</skos:example>
        <skos:prefLabel xml:lang="en">mother’s paternal family name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1107-4ec7-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1107-4ec7-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that corresponds to the personal name of the person&apos;s grandmother</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">grandmother’s personal name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1107-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1107-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that corresponds to the personal name of the person&apos;s grandfather</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">grandfather’s personal name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1108-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1108-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">name component, similar in use to a family name, that denotes social standing, or membership to a particular clan or region</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">South Asian Muslims do not necessarily have family names. However, some men may have a hereditary honorific name/title. The most common of these include KHAN, CHAUDHRY and SHAH. They can appear in any position within a name, but are most commonly at the end.</skos:example>
        <skos:prefLabel xml:lang="en">honorific name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1109-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1109-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname that comes from the clan or house of the person</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The Sinhalese house/clan name ends in GE, e.g. Kaluhandhilage.</skos:example>
        <skos:prefLabel xml:lang="en">house or clan name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1110-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1110-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">surname coming from the name of a region, town or village</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In some regions of Southern India and Sri Lanka a place name (of a town or village of ancestral origin) may be used in addition to the father’s personal name.</skos:example>
        <skos:prefLabel xml:lang="en">region or village name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1111-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1111-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">quantity</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In some Chinese families, one of the two characters in the personal name is shared among members of a generation, either of the same sex, or less frequently for both sexes. These generation names may be an indicator for a familial relationship or help to determine generations within a family, but this is by no means a definitive way to link individuals: e.g. 1st child = YANG Qingzhao, 2nd child = YANG Qingxi (Qing is the generation name).</skos:example>
        <skos:prefLabel xml:lang="en">generation name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1112-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1112-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">quantity</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">In Bulgaria, wives typically take their husband’s family name, with the feminine ending, although many continue to use their maiden name: Emil Petrov CHRISTOV’s wife may be &apos;Iva Stefanova CHRISTOVA&apos;.</skos:example>
        <skos:example xml:lang="en">Married Russian women are most often known by their husband’s family name, with the feminine ending to the name: e.g. if &apos;Alexandra Ivanovna KARLOV&apos; married &apos;Mikhail Sergeyevich BORISOV&apos;, then she would become &apos;Alexandra Ivanovna BORISOVA&apos;.</skos:example>
        <skos:prefLabel xml:lang="en">married name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1113-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1113-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf06-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">alias that is a descriptive name added to or replacing the actual name of a person</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">English nicknames are generally represented in quotes between the bearer&apos;s first and last names: Dwight David &quot;Ike&quot; Eisenhower.</skos:example>
        <skos:example xml:lang="en">Somalis commonly use nicknames (‘naanays’), as many Somalis have similar names. As there no distinct family names, all names come from the same ‘pool’ of personal names.</skos:example>
        <skos:prefLabel xml:lang="en">nickname</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1114-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1114-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf06-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">a name someone uses in place of his or her real name</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">pseudonym</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1115-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1115-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf06-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">a name that an actor or an artist uses for their work</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">stage name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1116-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1116-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">given name that precedes the surname</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">forename</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1117-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1117-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">given name that appears first in the person&apos;s name</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">first name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1118-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1118-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">given name that appears in second place in person&apos;s name, between the first name and the surname(s)</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">middle name</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1119-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1119-ab10-579559edb59d">
        <rdf:type rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>A Guide to Names and Naming Practices</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">a name or title given to, or used by, a person as a mark of status or respect</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">An Arab name may include honorific name as parent, e.g. Abu Mustafa, Umm Mustafa.</skos:example>
        <skos:prefLabel xml:lang="en">honorific title</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1120-ab10-579559edb59d -->

    <owl:NamedIndividual rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-1120-ab10-579559edb59d">
