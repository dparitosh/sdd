    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf01-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf01-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component indicating through a word, group of words, acronyms or abbreviations, an individual civil status or condition</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Mr., Mrs., Miss, Herr (Mr. in German), Señora (Mrs. in Spanish), Agha (Mr. in Iranian or Kurdish), Anesa (Miss in Arabic), Despinis (Miss in Greek).</skos:example>
        <skos:prefLabel xml:lang="en">form of address</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf02-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf02-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component used in some countries to distinguish between persons with the same surname(s) which have similar given names or initials</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">III, Senior, the Third.</skos:example>
        <skos:prefLabel xml:lang="en">name qualifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf03-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component specifying the name used to distinguish between persons having the same surname(s)</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Jean-Claude</skos:example>
        <skos:prefLabel xml:lang="en">given name</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf04-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf04-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component indicating an individual’s professional or academic qualification or rank in a professional group or society, or religious status</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Arab names can include the title al-Hajj / Haj / Hajji / Hadj to indicate that the person has undergone the Muslim pilgrimage to Mecca.</skos:example>
        <skos:example xml:lang="en">PhD, Fellow of the Royal Society, FRS, Barrister at Law.</skos:example>
        <skos:prefLabel xml:lang="en">qualification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf05-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component which identifies the family or parentage of an individual</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">The spanish name &quot;Juan Luis LÓPEZ DE ARRIORTUA GARCÍA&quot; includes two surnames: &quot;LÓPEZ DE ARRIORTUA&quot; (father’s paternal family name) and &quot;GARCÍA&quot; (mother’s paternal family name).</skos:example>
        <skos:prefLabel xml:lang="en">surname</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf06-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf06-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component which identifies an alternative or substitute for a proper name</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">alias</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf07-45e4-ab10-579559edb59d -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#65fd71db-cf07-45e4-ab10-579559edb59d">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#65fd71da-4f9c-4fd0-892d-d85274c29fd0"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>Adapted from ISO 19160-4:2017</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">person name component which identifies a customer of a delivery service provider (postal operator)</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">customer identifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#656cf0ff-0eb1-4696-99bd-168debb65446 -->

