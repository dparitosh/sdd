        <rdfs:comment xml:lang="en">breakdown member that links a physical element and a physical breakdown of which it is a member</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A wheel is a member of the physical breakdown of an automobile.</skos:example>
        <skos:prefLabel xml:lang="en">physical breakdown member</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8236a0-46b2-0138-6478-78b156d8ad1a -->

