        <rdfs:comment xml:lang="en">address component designating the name of the distribution office used for delivery services</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
