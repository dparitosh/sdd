    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad822220-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad822220-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#187e23b5-bc20-4c72-802a-49198ab0c9d7"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">interface connector version that identifies an individual that is the subject of a plan to realize an interface connector</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Company Acme Limited is planning to produce an aircraft with serial number 1234 next month. This aircraft has connectors on each engine for fuel pipes. The company wishes to plan when each connector will be realized and then identify a date on which an inspector can test all the realized connectors.</skos:example>
        <skos:prefLabel xml:lang="en">interface connector as planned</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8222b0-46b2-0138-6478-78b156d8ad1a -->

    <owl:Class rdf:about="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8222b0-46b2-0138-6478-78b156d8ad1a">
        <rdfs:subClassOf rdf:resource="http://standards.iso.org/iso/10303/-4000/tech/refdata/core_v1#187e23b5-bc20-4c72-802a-49198ab0c9d7"/>
        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">interface connector version that identifies an individual that is a realized interface connector</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">Company WeFlySafest Corporation owns and operates an aircraft with serial number 1234. When landing at Heathrow airport, the pilot reports a loss of fuel pressure on engine number 4 with serial number A9876 and recommends that an inspector tests the realized connector on the engine.</skos:example>
        <skos:prefLabel xml:lang="en">interface connector as realized</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad822360-46b2-0138-6478-78b156d8ad1a -->

