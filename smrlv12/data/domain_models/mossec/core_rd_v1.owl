        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">address component indicating the apartment, room or office in, at or adjacent to which a delivery point, situated within a building, is located</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:prefLabel xml:lang="en">door</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#59cf1733-c833-ac10-9a46-faeec7a3301c -->

