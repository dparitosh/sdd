        <skos:example xml:lang="en">Body, roof, bonnet, bumpers etc. are examples of physical elements of the physical breakdown of an motor car.</skos:example>
        <skos:prefLabel xml:lang="en">physical element</skos:prefLabel>
    </owl:Class>
    


