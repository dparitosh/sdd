        <dc:contributor>STEP Harmonization Team</dc:contributor>
        <dc:creator>Phil Spiby, Eurostep</dc:creator>
        <dc:date>2021-07-30</dc:date>
        <dc:source>ISO 10303-239ed2 transformed to AP239AP233 PSM</dc:source>
        <dc:type>InWork</dc:type>
        <rdfs:comment xml:lang="en">breakdown comprising system elements</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
        <skos:changeNote>[2021-07-30] Initial definition.</skos:changeNote>
        <skos:example xml:lang="en">A system breakdown provides a decomposition of an aircraft in terms of high-level systems s such as &quot;fuel system&quot; or &quot;flight control system&quot; - which might, in the second example, further decompose into low-level systems such as &quot;autopilot system&quot; and &quot;instrument landing system&quot;.</skos:example>
        <skos:prefLabel xml:lang="en">system breakdown</skos:prefLabel>
    </owl:Class>
    


    <!-- http://standards.iso.org/iso/10303/-4000/tech/refdata/core_rd_v1#ad8261b0-46b2-0138-6478-78b156d8ad1a -->

