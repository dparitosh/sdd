# ================================================================
# MBSE Neo4j Graph Representation - Production Environment
# ================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control!

# ================================================================
# NEO4J DATABASE CONFIGURATION
# ================================================================
NEO4J_URI=neo4j+s://your-neo4j-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_RETRY_TIME=30

# ================================================================
# APPLICATION CONFIGURATION
# ================================================================
SECRET_KEY=your-256-bit-secret-key-here-use-secrets-token-hex-32
API_PORT=5000
API_HOST=0.0.0.0

# ================================================================
# SECURITY CONFIGURATION
# ================================================================
# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here-use-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_STORAGE=redis  # memory or redis

# Redis Configuration (if using redis for rate limiting)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-redis-password

# ================================================================
# OAUTH2/OIDC AUTHENTICATION
# ================================================================
# OAuth2 Provider (azure, google, okta, generic)
OAUTH_PROVIDER=azure

# Azure AD Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-application-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# Google Workspace Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# Okta Configuration
OKTA_DOMAIN=your-org.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret
OKTA_ISSUER=https://your-org.okta.com/oauth2/default

# Generic OIDC Configuration
OIDC_DISCOVERY_URL=https://your-oidc-provider.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Callback URL (adjust to your domain)
OAUTH_CALLBACK_URL=https://yourdomain.com/auth/callback

# ================================================================
# PLM SYSTEM INTEGRATIONS
# ================================================================
# Teamcenter Configuration
TEAMCENTER_ENABLED=false
TEAMCENTER_URL=https://teamcenter.company.com
TEAMCENTER_USERNAME=plm_service_account
TEAMCENTER_PASSWORD=secure-password
TEAMCENTER_AUTH_TYPE=oauth2
TEAMCENTER_CLIENT_ID=teamcenter-client-id
TEAMCENTER_CLIENT_SECRET=teamcenter-client-secret

# Windchill Configuration
WINDCHILL_ENABLED=false
WINDCHILL_URL=https://windchill.company.com
WINDCHILL_USERNAME=plm_service_account
WINDCHILL_PASSWORD=secure-password
WINDCHILL_AUTH_TYPE=basic
WINDCHILL_VERIFY_SSL=true

# SAP PLM Configuration
SAP_PLM_ENABLED=false
SAP_URL=https://sap.company.com:8000
SAP_USERNAME=PLM_USER
SAP_PASSWORD=secure-password
SAP_AUTH_TYPE=basic
SAP_API_VERSION=v1
SAP_VERIFY_SSL=true

# PLM Sync Configuration
PLM_SYNC_ENABLED=true
PLM_SYNC_INTERVAL_MINUTES=60
PLM_SYNC_BATCH_SIZE=100
PLM_SYNC_MAX_RETRIES=3

# ================================================================
# MONITORING & OBSERVABILITY
# ================================================================
# Prometheus Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENDPOINT=/metrics

# Grafana Configuration
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/mbse-neo4j/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# ================================================================
# WEBSOCKET CONFIGURATION
# ================================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws
WEBSOCKET_CORS_ALLOWED_ORIGINS=https://yourdomain.com
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=60

# ================================================================
# AI AGENT CONFIGURATION
# ================================================================
# LangChain/LangGraph Configuration
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_PROJECT=mbse-neo4j-production
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Agent Configuration
AGENT_ENABLED=true
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300

# ================================================================
# DOCKER DEPLOYMENT
# ================================================================
COMPOSE_PROJECT_NAME=mbse-neo4j-prod
DOCKER_NETWORK=mbse-network
DOCKER_RESTART_POLICY=unless-stopped

# Neo4j Docker image (Community by default; no commercial license required)
# Examples:
#   NEO4J_DOCKER_IMAGE=neo4j:5.15
#   NEO4J_DOCKER_IMAGE=neo4j:5.15-enterprise   # Only if you have an Enterprise license
NEO4J_DOCKER_IMAGE=neo4j:5.15

# Container Resource Limits
BACKEND_MEMORY_LIMIT=2g
BACKEND_CPU_LIMIT=2
FRONTEND_MEMORY_LIMIT=512m
FRONTEND_CPU_LIMIT=1
NEO4J_MEMORY_LIMIT=4g
NEO4J_CPU_LIMIT=4

# ================================================================
# BACKUP & DISASTER RECOVERY
# ================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/backups
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# ================================================================
# FEATURE FLAGS
# ================================================================
FEATURE_EXPORT_ENABLED=true
FEATURE_AGENT_ENABLED=true
FEATURE_PLM_SYNC_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_OAUTH_ENABLED=true
FEATURE_METRICS_ENABLED=true

# ================================================================
# PERFORMANCE TUNING
# ================================================================
# Worker Configuration
WORKER_PROCESSES=4
WORKER_THREADS=2
WORKER_TIMEOUT=120

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=10000
CACHE_BACKEND=redis  # memory or redis

# Connection Pool
CONNECTION_POOL_SIZE=50
CONNECTION_POOL_TIMEOUT=30
CONNECTION_MAX_LIFETIME=3600

# ================================================================
# SECURITY HEADERS
# ================================================================
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# ================================================================
# HEALTH CHECK CONFIGURATION
# ================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30

# ================================================================
# NOTIFICATION CONFIGURATION
# ================================================================
NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL=admin@company.com
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=notifications@company.com
SMTP_PASSWORD=smtp-password
SMTP_USE_TLS=true

# ================================================================
# END OF CONFIGURATION
# ================================================================
